---
/**
 * Outil d'annotation (DÉVELOPPEMENT UNIQUEMENT) — trace des RÉGIONS sur n'importe
 * quelle carte et rattache chacune à un SYMBOLE (`symbols.ts`). Une région peut
 * comporter PLUSIEURS formes (polygones disjoints). « Enregistrer » réécrit
 * `src/data/card-regions.ts` via le middleware Vite `annotateSavePlugin`
 * (voir astro.config.mjs). Non liée dans la navigation.
 *
 * Vit sous `[lang]` (servi sur `/fr/annotate`) : en dev, les routes non préfixées
 * par la locale renvoient 404 (prefixDefaultLocale). L'UI reste en français.
 */
export function getStaticPaths() {
  return [{ params: { lang: 'fr' } }];
}
const isDev = import.meta.env.DEV;
---

<!-- Page de dev autonome : document complet (pas de layout), non indexée. -->
<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Annotation des cartes — dev</title>
</head>
<body>
{
  !isDev ? (
    <main class="dev-only">
      <p>Outil d'annotation — disponible en développement uniquement (<code>npm run dev</code>).</p>
    </main>
  ) : (
    <main id="annotate-app">
      <header class="bar">
        <h1>Annotation des cartes</h1>
        <label class="field">
          <span>Carte</span>
          <select id="card-select"></select>
        </label>
        <span id="status" class="status" role="status" aria-live="polite"></span>
      </header>

      <div class="work">
        <section class="stage">
          <div class="canvas" id="canvas">
            <div class="img-wrap" id="img-wrap">
              <img id="card-img" alt="" />
              <svg id="draw" viewBox="0 0 1000 1000" preserveAspectRatio="none"></svg>
              <div class="handles" id="handles"></div>
            </div>
            <div class="zoom-ctrl" role="group" aria-label="Zoom">
              <button type="button" id="zoom-out" aria-label="Dézoomer">−</button>
              <button type="button" id="zoom-reset" aria-label="Ajuster (100 %)">100 %</button>
              <button type="button" id="zoom-in" aria-label="Zoomer">+</button>
            </div>
          </div>
          <div class="toolbar">
            <button type="button" id="btn-new" class="primary">+ Nouvelle région</button>
            <button type="button" id="btn-add" hidden>+ Ajouter une forme</button>
            <button type="button" id="btn-done" hidden>Terminer le tracé (Entrée)</button>
          </div>
          <p class="hint" id="hint"></p>
        </section>

        <aside class="panel">
          <div class="coverage">
            <p class="list-title">Symboles à annoter (<span id="todo-count">0/0</span>)</p>
            <div class="chips" id="todo-chips"></div>
          </div>

          <div class="editor" id="editor" hidden>
            <p class="editor-title">Région <span id="form-num"></span></p>
            <label class="field">
              <span>Symbole</span>
              <select id="ref-select"></select>
            </label>
            <p class="preview" id="preview"></p>
            <button type="button" id="btn-delete" class="danger">Supprimer la région</button>
          </div>
          <p class="editor-empty" id="editor-empty">Aucune région sélectionnée.</p>

          <div class="list-wrap">
            <p class="list-title">Régions de la carte (<span id="count">0</span>)</p>
            <ol class="reg-list" id="reg-list"></ol>
          </div>
        </aside>
      </div>
    </main>
  )
}

<style is:global>
  /* Page de dev autonome : styles globaux (pas de scope, une seule route). */
  :root {
    --bg: #14101c;
    --panel: #1e1830;
    --line: #3a3350;
    --text: #efe6d6;
    --muted: #a99fbf;
    --gold: #c9a44c;
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    font: 15px/1.5 system-ui, sans-serif;
  }
  .dev-only { padding: 2rem; }
  #annotate-app { padding: 1rem 1.25rem 3rem; max-width: 1280px; margin: 0 auto; }
  .bar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.9rem 1.2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--line);
  }
  .bar h1 { font-size: 1.15rem; margin: 0; margin-right: auto; }
  .field { display: inline-flex; flex-direction: column; gap: 0.2rem; font-size: 0.75rem; color: var(--muted); }
  .field select {
    font: inherit;
    padding: 0.4rem 0.5rem;
    background: var(--panel);
    color: var(--text);
    border: 1px solid var(--line);
    border-radius: 8px;
    min-width: 14rem;
    max-width: 22rem;
  }
  button {
    font: inherit;
    cursor: pointer;
    padding: 0.5rem 1rem;
    border-radius: 8px;
    border: 1px solid var(--line);
    background: var(--panel);
    color: var(--text);
  }
  button.primary { border-color: var(--gold); background: rgba(201, 164, 76, 0.18); color: var(--gold); }
  button.danger { border-color: #a5566a; color: #e79ab0; background: transparent; }
  button:hover { filter: brightness(1.15); }
  button:disabled { opacity: 0.4; cursor: default; }
  .status { font-size: 0.85rem; color: var(--muted); }

  .work { display: grid; grid-template-columns: minmax(0, 1fr) 20rem; gap: 1.5rem; margin-top: 1.25rem; align-items: start; }
  @media (max-width: 60rem) { .work { grid-template-columns: 1fr; } }

  .stage { display: grid; gap: 0.7rem; }
  /* Viewport : masque le débordement du zoom. Sa hauteur est celle de .img-wrap
     à l'échelle 1 (les transforms n'affectent pas la mise en page) → le zoom
     agrandit visuellement sans casser le flux. */
  .canvas {
    position: relative;
    overflow: hidden;
    width: min(760px, 64vw);
    margin: 0 auto;
    border-radius: 12px;
    background: #0d0a14;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.5), inset 0 0 0 1px var(--line);
    user-select: none;
    touch-action: none;
  }
  @media (max-width: 60rem) { .canvas { width: min(760px, 92vw); } }
  /* Couche transformée : le zoom (échelle) et le pan (translation) sont pilotés
     par --z / --tx / --ty. transform-origin en haut-gauche pour un calcul simple. */
  .img-wrap {
    --z: 1;
    --tx: 0px;
    --ty: 0px;
    position: relative;
    width: 100%;
    transform-origin: 0 0;
    transform: translate(var(--tx), var(--ty)) scale(var(--z));
  }
  #card-img {
    display: block;
    width: 100%;
    height: auto;
  }
  /* Contrôle de zoom flottant (pastille bas-droite du viewport). */
  .zoom-ctrl {
    position: absolute;
    right: 0.6rem;
    bottom: 0.6rem;
    display: flex;
    align-items: stretch;
    gap: 1px;
    padding: 2px;
    border-radius: 999px;
    background: rgba(13, 10, 20, 0.82);
    border: 1px solid var(--line);
    backdrop-filter: blur(4px);
  }
  .zoom-ctrl button {
    padding: 0.25rem 0.6rem;
    border: none;
    background: transparent;
    border-radius: 999px;
    color: var(--text);
    font-variant-numeric: tabular-nums;
    min-width: 2.1rem;
  }
  .zoom-ctrl button:hover:not(:disabled) { background: rgba(201, 164, 76, 0.18); }
  #zoom-reset { font-size: 0.8rem; color: var(--muted); }
  /* Calque de tracé (SVG) : polygones + fond capteur de clics. */
  #draw { position: absolute; inset: 0; width: 100%; height: 100%; }
  #draw.is-drawing { cursor: crosshair; }
  .draw-bg { fill: transparent; pointer-events: fill; }
  /* Remplissage evenodd par région : révèle les trous (boucles imbriquées).
     Non interactif — les contours .shape captent les clics par-dessus. */
  .rfill { fill: rgba(201, 164, 76, 0.12); pointer-events: none; }
  .rfill.is-selected { fill: rgba(201, 164, 76, 0.24); }
  /* Contour + cible de clic par boucle (remplissage transparent : la couleur
     vient de .rfill, sinon un trou serait repeint par la boucle intérieure). */
  .shape {
    fill: transparent;
    stroke: var(--gold);
    stroke-width: 1.5;
    vector-effect: non-scaling-stroke;
    pointer-events: fill;
    cursor: pointer;
  }
  #draw.is-drawing .shape { pointer-events: none; opacity: 0.45; }
  .shape.is-selected { stroke: #fff; stroke-width: 2; }
  .draft {
    fill: transparent;
    stroke: var(--gold);
    stroke-width: 1.5;
    stroke-dasharray: 5 3;
    vector-effect: non-scaling-stroke;
    pointer-events: none;
  }
  /* Poignées de sommets (HTML au-dessus du SVG, pour rester rondes). */
  .handles { position: absolute; inset: 0; pointer-events: none; }
  /* Taille/épaisseur divisées par le zoom → constantes à l'écran quel que soit --z. */
  .handle {
    position: absolute;
    width: calc(0.8rem / var(--z, 1));
    height: calc(0.8rem / var(--z, 1));
    transform: translate(-50%, -50%);
    border-radius: 50%;
    background: #fff;
    border: calc(2px / var(--z, 1)) solid var(--gold);
    pointer-events: auto;
    cursor: grab;
  }
  .handle:active { cursor: grabbing; }
  .handle.draft-pt { background: var(--gold); border-color: #fff; cursor: default; }
  .toolbar { display: flex; gap: 0.5rem; justify-content: center; flex-wrap: wrap; }
  .hint { font-size: 0.8rem; color: var(--muted); text-align: center; margin: 0; max-width: 40rem; justify-self: center; }

  .panel { display: grid; gap: 1.2rem; }
  .editor { display: grid; gap: 0.75rem; padding: 1rem; border: 1px solid var(--line); border-radius: 10px; background: var(--panel); }
  .editor[hidden] { display: none; }
  .editor .field { color: var(--muted); }
  .editor .field select { min-width: 0; width: 100%; max-width: none; }
  .editor-title { margin: 0; font-weight: 700; }
  .editor-empty { margin: 0; color: var(--muted); font-style: italic; }
  .preview { margin: 0; font-size: 0.85rem; color: var(--muted); line-height: 1.5; min-height: 1.2rem; }

  .list-title { margin: 0 0 0.5rem; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); }
  .reg-list { list-style: none; margin: 0; padding: 0; display: grid; gap: 0.35rem; }
  .reg-list li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.5rem;
    border: 1px solid var(--line);
    border-radius: 8px;
    cursor: pointer;
    font-size: 0.85rem;
  }
  .reg-list li.is-selected { border-color: var(--gold); background: rgba(201, 164, 76, 0.1); }
  .reg-list .badge {
    flex: none;
    width: 1.4rem; height: 1.4rem;
    border-radius: 50%;
    display: grid; place-items: center;
    font-size: 0.72rem; font-weight: 700; color: #14101c;
    background: var(--gold);
  }
  .reg-list .lbl { flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .reg-list .del {
    flex: none;
    padding: 0.1rem 0.4rem;
    border: none;
    background: transparent;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1;
    border-radius: 6px;
  }
  .reg-list .del:hover { color: #e79ab0; background: rgba(165, 86, 106, 0.16); filter: none; }
  .canvas.is-panning { cursor: grabbing; }

  /* « Symboles à annoter » : puces cliquables (lance un tracé pré-affecté). */
  .coverage { display: grid; gap: 0.5rem; }
  .chips { display: flex; flex-wrap: wrap; gap: 0.35rem; }
  .chips .chip {
    padding: 0.3rem 0.6rem;
    font-size: 0.8rem;
    border-radius: 999px;
    border: 1px dashed var(--line);
    background: transparent;
    color: var(--muted);
  }
  .chips .chip:hover { border-style: solid; border-color: var(--gold); color: var(--text); background: rgba(201, 164, 76, 0.1); }
  .chips .chip::before { content: '+ '; color: var(--gold); }
  .chips .all-done { color: #7fd6a0; font-size: 0.85rem; }
</style>

<script>
  import { cards } from '../../data/cards';
  import { SYMBOLS } from '../../data/symbols';
  import { CARD_REGIONS, type Region, type Point } from '../../data/card-regions';

  function init() {
    const BASE = import.meta.env.BASE_URL;
    const SVGNS = 'http://www.w3.org/2000/svg';
    const $ = <T extends HTMLElement>(id: string) => document.getElementById(id) as T;

    const cardSelect = $<HTMLSelectElement>('card-select');
    const img = $<HTMLImageElement>('card-img');
    const draw = document.getElementById('draw') as unknown as SVGSVGElement;
    const handlesEl = $<HTMLElement>('handles');
    const editor = $<HTMLElement>('editor');
    const editorEmpty = $<HTMLElement>('editor-empty');
    const formNum = $<HTMLElement>('form-num');
    const refSelect = $<HTMLSelectElement>('ref-select');
    const preview = $<HTMLElement>('preview');
    const btnDelete = $<HTMLButtonElement>('btn-delete');
    const statusEl = $<HTMLElement>('status');
    const list = $<HTMLOListElement>('reg-list');
    const count = $<HTMLElement>('count');
    const btnNew = $<HTMLButtonElement>('btn-new');
    const btnAdd = $<HTMLButtonElement>('btn-add');
    const btnDone = $<HTMLButtonElement>('btn-done');
    const hint = $<HTMLElement>('hint');
    const canvas = $<HTMLElement>('canvas');
    const imgWrap = $<HTMLElement>('img-wrap');
    const zoomIn = $<HTMLButtonElement>('zoom-in');
    const zoomOut = $<HTMLButtonElement>('zoom-out');
    const zoomReset = $<HTMLButtonElement>('zoom-reset');
    const todoCount = $<HTMLElement>('todo-count');
    const todoChips = $<HTMLElement>('todo-chips');

    // Copie de travail (le fichier reste la source de vérité).
    const store: Record<string, Region[]> = structuredClone(CARD_REGIONS);
    let cardId = cards[0].id;
    let selected = -1; // index de région
    let mode: 'idle' | 'draw' = 'idle';
    // Tracé « live » : on ajoute les points directement à une forme réelle de la
    // région en cours (déjà dans le store) — pas de brouillon à valider. drawShape
    // est l'index de cette forme dans la région `selected`.
    let drawShape = -1;
    let dragS = -1; // forme en cours de déplacement
    let dragV = -1; // sommet en cours de déplacement
    let pendingNewRef = 0; // symbole pré-affecté à la prochaine région « new »

    // ---- Zoom / déplacement (molette + flèches) ----
    const MIN_Z = 1;
    const MAX_Z = 8;
    let zoom = 1;
    let panX = 0;
    let panY = 0;

    // Borne le pan pour que l'image couvre toujours le viewport (origine 0,0).
    function clampPan() {
      const cw = canvas.clientWidth;
      const ch = canvas.clientHeight;
      panX = Math.min(0, Math.max(cw * (1 - zoom), panX));
      panY = Math.min(0, Math.max(ch * (1 - zoom), panY));
    }
    function applyView() {
      clampPan();
      imgWrap.style.setProperty('--z', String(zoom));
      imgWrap.style.setProperty('--tx', `${panX}px`);
      imgWrap.style.setProperty('--ty', `${panY}px`);
      zoomReset.textContent = `${Math.round(zoom * 100)} %`;
      zoomOut.disabled = zoom <= MIN_Z + 1e-3;
      zoomIn.disabled = zoom >= MAX_Z - 1e-3;
    }
    // Zoom en gardant fixe le point (sx,sy) exprimé dans le repère du viewport.
    function zoomAt(sx: number, sy: number, factor: number) {
      const prev = zoom;
      zoom = Math.min(MAX_Z, Math.max(MIN_Z, zoom * factor));
      if (zoom === prev) return;
      panX = sx - (zoom / prev) * (sx - panX);
      panY = sy - (zoom / prev) * (sy - panY);
      applyView();
    }
    function resetView() {
      zoom = 1;
      panX = 0;
      panY = 0;
      applyView();
    }
    canvas.addEventListener(
      'wheel',
      (e) => {
        e.preventDefault();
        const r = canvas.getBoundingClientRect();
        zoomAt(e.clientX - r.left, e.clientY - r.top, Math.exp(-e.deltaY * 0.0015));
      },
      { passive: false },
    );
    zoomIn.addEventListener('click', () =>
      zoomAt(canvas.clientWidth / 2, canvas.clientHeight / 2, 1.3),
    );
    zoomOut.addEventListener('click', () =>
      zoomAt(canvas.clientWidth / 2, canvas.clientHeight / 2, 1 / 1.3),
    );
    zoomReset.addEventListener('click', resetView);

    // Déplacement au clic-molette maintenu (glisser-déposer). Le bouton du milieu
    // (button 1) déclenche autrement l'autoscroll : on le neutralise.
    let panning = false;
    let panFromX = 0;
    let panFromY = 0;
    let panOrigX = 0;
    let panOrigY = 0;
    canvas.addEventListener('mousedown', (e) => {
      if (e.button === 1) e.preventDefault();
    });
    canvas.addEventListener('pointerdown', (e) => {
      if (e.button !== 1) return;
      e.preventDefault();
      panning = true;
      panFromX = e.clientX;
      panFromY = e.clientY;
      panOrigX = panX;
      panOrigY = panY;
      canvas.setPointerCapture(e.pointerId);
      canvas.classList.add('is-panning');
    });
    canvas.addEventListener('pointermove', (e) => {
      if (!panning) return;
      panX = panOrigX + (e.clientX - panFromX);
      panY = panOrigY + (e.clientY - panFromY);
      applyView();
    });
    const endPan = (e: PointerEvent) => {
      if (!panning) return;
      panning = false;
      canvas.releasePointerCapture?.(e.pointerId);
      canvas.classList.remove('is-panning');
    };
    canvas.addEventListener('pointerup', endPan);
    canvas.addEventListener('pointercancel', endPan);

    for (const c of cards) {
      const o = document.createElement('option');
      o.value = c.id;
      o.dataset.base = `${c.name.fr} (${c.id})`;
      cardSelect.append(o);
    }

    const regionsOf = (): Region[] => (store[cardId] ??= []);
    // Nombre de symboles distincts couverts par au moins une région.
    const distinctRefs = (regs: Region[]) => new Set(regs.map((r) => r.ref)).size;
    // Suffixe de couverture pour l'option d'une carte (« — 3/9 » ou « ✓ »).
    function cardCovLabel(id: string): string {
      const total = (SYMBOLS[id] ?? []).length;
      if (!total) return '';
      const cov = distinctRefs(store[id] ?? []);
      return cov >= total ? '  ✓' : `  — ${cov}/${total}`;
    }
    function refreshCardOptions() {
      for (const o of Array.from(cardSelect.options)) {
        o.textContent = (o.dataset.base ?? '') + cardCovLabel(o.value);
      }
    }
    const refLabel = (rg: Region) => SYMBOLS[cardId]?.[rg.ref]?.label.fr ?? `symbole ${rg.ref}`;
    const refOptions = (): [number, string][] =>
      (SYMBOLS[cardId] ?? []).map((s, i) => [i, `${i + 1}. ${s.label.fr}`]);
    const status = (m: string) => (statusEl.textContent = m);
    const svgEl = (n: string) => document.createElementNS(SVGNS, n);
    const pts = (shape: Point[]) => shape.map(([x, y]) => `${x * 1000},${y * 1000}`).join(' ');
    // Chemin evenodd d'une région (une sous-boucle `M…L…Z` par forme) : sert au
    // remplissage qui révèle les trous (boucles imbriquées).
    const pathD = (shapes: Point[][]) =>
      shapes.map((shape) => 'M' + shape.map(([x, y]) => `${x * 1000},${y * 1000}`).join('L') + 'Z').join('');

    // Position normalisée (0–1) d'un pointeur, relative à l'image.
    function normPos(e: PointerEvent): Point {
      const r = draw.getBoundingClientRect();
      const x = Math.min(1, Math.max(0, (e.clientX - r.left) / r.width));
      const y = Math.min(1, Math.max(0, (e.clientY - r.top) / r.height));
      return [Math.round(x * 1e4) / 1e4, Math.round(y * 1e4) / 1e4];
    }

    // Distance d'un point au segment [a,b] (espace normalisé, approximatif).
    function segDist(p: Point, a: Point, b: Point): number {
      const dx = b[0] - a[0];
      const dy = b[1] - a[1];
      const l2 = dx * dx + dy * dy;
      let t = l2 ? ((p[0] - a[0]) * dx + (p[1] - a[1]) * dy) / l2 : 0;
      t = Math.max(0, Math.min(1, t));
      return Math.hypot(p[0] - (a[0] + t * dx), p[1] - (a[1] + t * dy));
    }

    // Insère un sommet dans une forme, sur l'arête la plus proche du clic (affinage).
    function insertVertex(shape: Point[], p: Point) {
      let best = 0;
      let bestD = Infinity;
      for (let i = 0; i < shape.length; i++) {
        const d = segDist(p, shape[i], shape[(i + 1) % shape.length]);
        if (d < bestD) {
          bestD = d;
          best = i;
        }
      }
      shape.splice(best + 1, 0, p);
    }

    function renderSvg() {
      draw.replaceChildren();
      draw.classList.toggle('is-drawing', mode === 'draw');
      const bg = svgEl('rect');
      bg.setAttribute('class', 'draw-bg');
      bg.setAttribute('x', '0');
      bg.setAttribute('y', '0');
      bg.setAttribute('width', '1000');
      bg.setAttribute('height', '1000');
      bg.addEventListener('pointerdown', (e) => {
        if ((e as PointerEvent).button !== 0) return; // molette = pan, géré ailleurs
        if (mode === 'draw') {
          // Ajout LIVE : le point va directement dans la forme en cours (déjà réelle).
          const shape = regionsOf()[selected]?.shapes[drawShape];
          if (!shape) return;
          shape.push(normPos(e as PointerEvent));
          render();
          if (shape.length >= 3) scheduleSave(); // prise en compte dès 3 points
        } else if (selected !== -1) {
          selected = -1;
          render();
        }
      });
      draw.append(bg);

      // Remplissage par région : un `<path>` evenodd regroupant toutes ses boucles.
      // Combiné à fill-rule="evenodd", une boucle imbriquée dans une autre s'affiche
      // comme un TROU (forme négative). Non interactif : les contours/poignées, eux,
      // restent par boucle (polygones ci-dessous). Inclut la forme en cours de tracé
      // → l'aperçu du remplissage (et du trou) se met à jour au fil des clics.
      regionsOf().forEach((rg, ri) => {
        const fill = svgEl('path');
        fill.setAttribute('d', pathD(rg.shapes));
        fill.setAttribute('fill-rule', 'evenodd');
        fill.setAttribute('class', 'rfill' + (ri === selected ? ' is-selected' : ''));
        draw.append(fill);
      });

      regionsOf().forEach((rg, ri) => {
        rg.shapes.forEach((shape, si) => {
          // La forme en cours de tracé s'affiche en pointillé (« draft »), non cliquable.
          const drafting = mode === 'draw' && ri === selected && si === drawShape;
          const poly = svgEl('polygon');
          poly.setAttribute('points', pts(shape));
          poly.setAttribute('class', drafting ? 'draft' : 'shape' + (ri === selected ? ' is-selected' : ''));
          if (!drafting) {
            poly.dataset.s = String(si);
            poly.addEventListener('pointerdown', (e) => {
              if (mode === 'draw' || (e as PointerEvent).button !== 0) return;
              e.stopPropagation();
              if (ri === selected) {
                // clic dans la région déjà sélectionnée → ajoute un point (affinage)
                insertVertex(shape, normPos(e as PointerEvent));
                render();
                scheduleSave();
              } else {
                selected = ri;
                render();
              }
            });
            // Clic droit sur une forme → la supprimer, APRÈS confirmation (un clic
            // droit accidentel ne doit rien détruire). La dernière forme retire la région.
            poly.addEventListener('contextmenu', (e) => {
              if (mode === 'draw') return;
              e.preventDefault();
              const last = rg.shapes.length <= 1;
              const msg = last
                ? `Supprimer la région « ${refLabel(rg)} » (sa dernière forme) ?`
                : `Supprimer cette forme de « ${refLabel(rg)} » ?`;
              if (confirm(msg)) deleteShape(ri, si);
            });
          }
          draw.append(poly);
        });
      });
    }

    function renderHandles() {
      handlesEl.replaceChildren();
      const mk = (p: Point, cls: string, s: number, v: number) => {
        const h = document.createElement('div');
        h.className = cls;
        h.style.left = `${p[0] * 100}%`;
        h.style.top = `${p[1] * 100}%`;
        if (v >= 0) {
          h.dataset.s = String(s);
          h.dataset.v = String(v);
          h.addEventListener('pointerdown', (e) => startVertexDrag(e, s, v));
          h.addEventListener('dblclick', () => removeVertex(s, v));
        }
        handlesEl.append(h);
      };
      if (mode === 'draw') {
        regionsOf()[selected]?.shapes[drawShape]?.forEach((p) => mk(p, 'handle draft-pt', -1, -1));
      } else if (selected !== -1) {
        regionsOf()[selected].shapes.forEach((shape, si) =>
          shape.forEach((p, v) => mk(p, 'handle', si, v)),
        );
      }
    }

    function renderList() {
      count.textContent = String(regionsOf().length);
      list.replaceChildren();
      regionsOf().forEach((rg, i) => {
        const li = document.createElement('li');
        if (i === selected) li.classList.add('is-selected');
        const badge = document.createElement('span');
        badge.className = 'badge';
        badge.textContent = String(i + 1);
        const lbl = document.createElement('span');
        lbl.className = 'lbl';
        lbl.textContent = `${refLabel(rg)}${rg.shapes.length > 1 ? ` (${rg.shapes.length} formes)` : ''}`;
        const del = document.createElement('button');
        del.type = 'button';
        del.className = 'del';
        del.textContent = '✕';
        del.title = 'Supprimer la région';
        del.setAttribute('aria-label', `Supprimer la région ${i + 1}`);
        del.disabled = mode === 'draw';
        del.addEventListener('click', (e) => {
          e.stopPropagation();
          deleteRegion(i);
        });
        li.append(badge, lbl, del);
        li.addEventListener('click', () => {
          finishDraw(); // clôt un tracé en cours avant de changer de sélection
          if (i < regionsOf().length) {
            selected = i;
            render();
          }
        });
        list.append(li);
      });
    }

    function renderEditor() {
      const rg = regionsOf()[selected];
      const show = mode === 'idle' && !!rg;
      editor.hidden = !show;
      editorEmpty.hidden = show;
      if (!show || !rg) return;
      formNum.textContent = String(selected + 1);
      refSelect.replaceChildren();
      for (const [val, label] of refOptions()) {
        const o = document.createElement('option');
        o.value = String(val);
        o.textContent = label;
        refSelect.append(o);
      }
      refSelect.value = String(rg.ref);
      preview.textContent = refLabel(rg);
    }

    function renderToolbar() {
      const drawing = mode === 'draw';
      btnNew.hidden = false; // toujours dispo : démarrer une région clôt le tracé en cours
      btnAdd.hidden = drawing || selected === -1;
      btnDone.hidden = !drawing;
      hint.textContent = drawing
        ? 'Clique pour poser les points : la région est prise en compte et enregistrée dès 3 points, sans validation. Entrée / Échap (ou « Terminer ») pour arrêter d’ajouter des points. Molette = zoom, flèches ou clic-molette glissé = déplacement.'
        : 'Molette = zoom, flèches ou clic-molette glissé = déplacement, « 0 » = ajuster. Sélectionne une région (glisse ses poignées ; clic dans la forme = ajouter un point ; double-clic sur une poignée = la retirer). Clic droit sur une forme = la supprimer (confirmation) ; « Suppr » = supprimer la région.';
    }

    // Symboles de la carte sans aucune région : puces cliquables (→ tracé pré-affecté).
    function renderCoverage() {
      const syms = SYMBOLS[cardId] ?? [];
      const covered = new Set(regionsOf().map((r) => r.ref));
      const missing = syms.map((s, i) => ({ s, i })).filter(({ i }) => !covered.has(i));
      todoCount.textContent = `${syms.length - missing.length}/${syms.length}`;
      todoChips.replaceChildren();
      if (!syms.length) {
        const p = document.createElement('span');
        p.className = 'all-done';
        p.textContent = 'Aucun symbole défini pour cette carte.';
        todoChips.append(p);
        return;
      }
      if (!missing.length) {
        const p = document.createElement('span');
        p.className = 'all-done';
        p.textContent = 'Tous les symboles sont annotés ✓';
        todoChips.append(p);
        return;
      }
      for (const { s, i } of missing) {
        const b = document.createElement('button');
        b.type = 'button';
        b.className = 'chip';
        b.textContent = `${i + 1}. ${s.label.fr}`;
        b.title = 'Tracer une région pour ce symbole';
        b.addEventListener('click', () => {
          pendingNewRef = i;
          startDraw('new');
        });
        todoChips.append(b);
      }
    }

    function render() {
      renderSvg();
      renderHandles();
      renderList();
      renderEditor();
      renderToolbar();
      renderCoverage();
      refreshCardOptions();
      // Mémorise l'état d'édition : l'auto-enregistrement réécrit card-regions.ts,
      // ce qui recharge la page (HMR) → on restaure la carte et la région au boot.
      try {
        sessionStorage.setItem('annotate:card', cardId);
        sessionStorage.setItem('annotate:sel', String(selected));
      } catch {
        /* stockage indisponible : sans effet */
      }
    }

    // Déplacement d'un sommet (re-render du SVG seulement — les poignées gardent
    // leur capture de pointeur ; on repositionne juste celle qu'on glisse).
    function startVertexDrag(e: PointerEvent, s: number, v: number) {
      if (e.button !== 0) return; // laisse la molette (pan) passer
      e.stopPropagation();
      e.preventDefault();
      dragS = s;
      dragV = v;
      (e.target as HTMLElement).setPointerCapture?.(e.pointerId);
    }
    document.addEventListener('pointermove', (e) => {
      if (dragV < 0 || selected === -1) return;
      regionsOf()[selected].shapes[dragS][dragV] = normPos(e);
      const h = handlesEl.querySelector<HTMLElement>(`[data-s="${dragS}"][data-v="${dragV}"]`);
      if (h) {
        h.style.left = `${regionsOf()[selected].shapes[dragS][dragV][0] * 100}%`;
        h.style.top = `${regionsOf()[selected].shapes[dragS][dragV][1] * 100}%`;
      }
      renderSvg();
    });
    document.addEventListener('pointerup', () => {
      if (dragV >= 0) scheduleSave(); // un sommet vient d'être déplacé
      dragS = -1;
      dragV = -1;
    });

    function removeVertex(s: number, v: number) {
      const rg = regionsOf()[selected];
      if (!rg) return;
      if (rg.shapes[s].length > 3) rg.shapes[s].splice(v, 1);
      else if (rg.shapes.length > 1) rg.shapes.splice(s, 1);
      render();
      scheduleSave();
    }

    // Supprime une région entière, en gardant `selected` cohérent.
    function deleteRegion(i: number) {
      const regs = regionsOf();
      if (i < 0 || i >= regs.length) return;
      regs.splice(i, 1);
      if (selected === i) selected = -1;
      else if (selected > i) selected -= 1;
      render();
      scheduleSave();
    }

    // Supprime une forme (zone) d'une région ; la dernière forme retire la région.
    function deleteShape(ri: number, si: number) {
      const rg = regionsOf()[ri];
      if (!rg) return;
      rg.shapes.splice(si, 1);
      if (rg.shapes.length === 0) {
        deleteRegion(ri);
      } else {
        render();
        scheduleSave();
      }
    }

    // Clôt le tracé en cours : abandonne une forme de moins de 3 points (et la région
    // si elle devient vide), puis repasse en « idle ». Une région ≥ 3 points est déjà
    // dans le store et enregistrée — il n'y a rien à « valider ».
    function finishDraw() {
      if (mode !== 'draw') return;
      const rg = regionsOf()[selected];
      if (rg) {
        const sh = rg.shapes[drawShape];
        if (!sh || sh.length < 3) {
          rg.shapes.splice(drawShape, 1);
          if (rg.shapes.length === 0) {
            regionsOf().splice(selected, 1);
            selected = -1;
          }
        }
      }
      mode = 'idle';
      drawShape = -1;
      render();
      scheduleSave();
    }

    // Démarre un tracé LIVE : la forme réelle est créée tout de suite (région neuve,
    // ou forme ajoutée à la région `target`) ; les points s'y ajoutent au fil des clics.
    function startDraw(target: 'new' | number) {
      finishDraw(); // clôt proprement un tracé éventuellement en cours
      if (target === 'new') {
        regionsOf().push({ shapes: [[]], ref: pendingNewRef });
        selected = regionsOf().length - 1;
        pendingNewRef = 0;
      } else {
        selected = target;
        regionsOf()[target].shapes.push([]);
      }
      drawShape = regionsOf()[selected].shapes.length - 1;
      mode = 'draw';
      render();
    }
    btnNew.addEventListener('click', () => {
      pendingNewRef = 0;
      startDraw('new');
    });
    btnAdd.addEventListener('click', () => {
      if (mode === 'idle' && selected !== -1) startDraw(selected);
    });
    btnDone.addEventListener('click', finishDraw);
    document.addEventListener('keydown', (e) => {
      if ((e.key === 'Escape' || e.key === 'Enter') && mode === 'draw') return void finishDraw();
      // Déplacement/zoom/suppression clavier — inactif quand un champ a le focus.
      const tag = (document.activeElement?.tagName ?? '').toLowerCase();
      if (tag === 'select' || tag === 'input' || tag === 'textarea') return;
      if ((e.key === 'Delete' || e.key === 'Backspace') && mode === 'idle' && selected >= 0) {
        deleteRegion(selected);
        e.preventDefault();
        return;
      }
      const step = 48;
      const pans: Record<string, [number, number]> = {
        ArrowLeft: [step, 0],
        ArrowRight: [-step, 0],
        ArrowUp: [0, step],
        ArrowDown: [0, -step],
      };
      if (pans[e.key]) {
        panX += pans[e.key][0];
        panY += pans[e.key][1];
        applyView();
        e.preventDefault();
      } else if (e.key === '+' || e.key === '=') {
        zoomAt(canvas.clientWidth / 2, canvas.clientHeight / 2, 1.3);
        e.preventDefault();
      } else if (e.key === '-') {
        zoomAt(canvas.clientWidth / 2, canvas.clientHeight / 2, 1 / 1.3);
        e.preventDefault();
      } else if (e.key === '0') {
        resetView();
        e.preventDefault();
      }
    });

    refSelect.addEventListener('change', () => {
      const rg = regionsOf()[selected];
      if (!rg) return;
      rg.ref = Number(refSelect.value);
      render();
      scheduleSave();
    });
    btnDelete.addEventListener('click', () => deleteRegion(selected));

    function loadCard(id: string) {
      cardId = id;
      selected = -1;
      mode = 'idle';
      drawShape = -1;
      img.src = `${BASE}cards/${id}.webp`;
      img.alt = id;
      resetView();
      render();
    }
    cardSelect.addEventListener('change', () => {
      finishDraw(); // clôt un tracé en cours (sur la carte courante) avant de changer
      loadCard(cardSelect.value);
    });

    // Auto-enregistrement : réécrit card-regions.ts après une courte pause (debounce),
    // à chaque mutation. Plus de bouton — le statut affiche l'état.
    let saveTimer = 0;
    function scheduleSave() {
      status('Modifié…');
      clearTimeout(saveTimer);
      saveTimer = window.setTimeout(save, 700);
    }
    async function save() {
      status('Enregistrement…');
      try {
        const res = await fetch(`${BASE}__save-pins`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(store),
        });
        const j = await res.json();
        status(j.ok ? 'Enregistré ✓' : `Erreur : ${j.error}`);
      } catch (err) {
        status(`Erreur réseau : ${err}`);
      }
    }

    // Reprend la carte et la région d'avant le rechargement (capturées AVANT le
    // premier render, qui réécrirait sessionStorage à selected = -1).
    let startCard = cards[0].id;
    let startSel = -1;
    try {
      const c = sessionStorage.getItem('annotate:card');
      if (c && cards.some((x) => x.id === c)) startCard = c;
      const s = Number(sessionStorage.getItem('annotate:sel'));
      if (Number.isInteger(s)) startSel = s;
    } catch {
      /* stockage indisponible */
    }
    cardSelect.value = startCard;
    loadCard(startCard);
    if (startSel >= 0 && startSel < regionsOf().length) {
      selected = startSel;
      render();
    }
  }

  if (document.getElementById('annotate-app')) init();
</script>
</body>
</html>
