---
import Base from '../../layouts/Base.astro';
import History from '../../components/History.astro';
import { LOCALES, type Locale, t } from '../../lib/i18n';

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;
const heading = t(locale, 'history.heading');
---

<Base locale={locale} title={heading} description={t(locale, 'seo.history')} active="historique">
  <h1 class="page-title">{heading}</h1>
  <History locale={locale} />
</Base>
