---
import Base from '../../layouts/Base.astro';
import Grammar from '../../components/Grammar.astro';
import { LOCALES, type Locale, t } from '../../lib/i18n';

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;
const heading = t(locale, 'grammar.heading');
---

<Base locale={locale} title={heading} description={t(locale, 'seo.grammar')} active="grammaire">
  <h1 class="page-title">{heading}</h1>
  <Grammar locale={locale} />
</Base>
