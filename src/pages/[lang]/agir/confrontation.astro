---
import Base from '../../../layouts/Base.astro';
import { LOCALES, type Locale, type UIKey, t } from '../../../lib/i18n';
import { PRISMS } from '../../../lib/profile';

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;
const slots = [0, 1, 2];
const winSegs = [0, 1, 2, 3, 4]; // Victoire : premier à 5
const loseSegs = [0, 1, 2]; // Échec : premier à 3
---

<Base locale={locale} title={t(locale, 'confront.heading')}>
  <section class="confront" data-locale={locale}>
    <div class="lede">
      <h1>{t(locale, 'confront.heading')}</h1>
      <p class="intro" id="intro">{t(locale, 'confront.intro')}</p>
    </div>

    <div class="gauges">
      <div class="gauge gauge-win">
        <span class="gauge-label">{t(locale, 'confront.gaugeWin')}</span>
        <div class="gauge-track" id="track-win">
          {winSegs.map(() => <span class="seg" />)}
          <span class="float" id="float-win" aria-hidden="true" />
        </div>
      </div>
      <span class="gauge-vs" aria-hidden="true">✦</span>
      <div class="gauge gauge-lose">
        <div class="gauge-track" id="track-lose">
          {loseSegs.map(() => <span class="seg" />)}
          <span class="float" id="float-lose" aria-hidden="true" />
        </div>
        <span class="gauge-label">{t(locale, 'confront.gaugeLose')}</span>
      </div>
    </div>

    <div class="play" id="play">
      <p class="round-label" id="round-label" aria-live="polite" />

      <fieldset class="prism-pick" id="prism-pick">
        <legend>{t(locale, 'agir.pick')}</legend>
        <div class="pcards">
          {
            PRISMS.map((p) => (
              <label class="pcard">
                <input type="radio" name="prism" value={p} />
                <span class="pcard-in">
                  <span class:list={['dot', `dot-${p}`]} aria-hidden="true" />
                  <span class="pcard-name">{t(locale, `prism.${p}` as UIKey)}</span>
                  <span class="pcard-bal" data-prism={p} />
                  <span class="pcard-pips" data-prism={p} aria-hidden="true" />
                </span>
              </label>
            ))
          }
        </div>
      </fieldset>

      <div class="arena">
        <div class="slots" id="slots">
          {
            slots.map((i) => (
              <div class="slot idle" data-index={i} hidden>
                <div class="coin">
                  <div class="face face-sun"><svg viewBox="0 0 120 120" class="cface"><use href="#cf-sun" /></svg></div>
                  <div class="face face-moon"><svg viewBox="0 0 120 120" class="cface"><use href="#cf-moon" /></svg></div>
                </div>
              </div>
            ))
          }
        </div>
        <button type="button" class="btn-act" id="btn-act" disabled>{t(locale, 'agir.act')}</button>
      </div>
    </div>

    <ol class="log" id="log" aria-label="Journal des rounds" />

    <div class="verdict" id="verdict" aria-live="polite" hidden>
      <span class="verdict-main" id="verdict-main" />
      <span class="verdict-sub" id="verdict-sub" />
    </div>
    <button type="button" class="btn-reset" id="btn-reset" hidden>{t(locale, 'confront.again')}</button>

    <svg class="cf-defs" width="0" height="0" aria-hidden="true">
      <defs>
        <mask id="cf-crescent">
          <rect width="120" height="120" fill="#fff" />
          <circle cx="76" cy="52" r="28" fill="#000" />
        </mask>
        <symbol id="cf-sun" viewBox="0 0 120 120">
          <circle cx="60" cy="60" r="13" fill="#6a4e1f" />
          <circle cx="60" cy="60" r="20" fill="none" stroke="#6a4e1f" stroke-width="3" opacity="0.75" />
          <g stroke="#6a4e1f" stroke-width="5" stroke-linecap="round">
            <line x1="60" y1="14" x2="60" y2="29" /><line x1="60" y1="91" x2="60" y2="106" />
            <line x1="14" y1="60" x2="29" y2="60" /><line x1="91" y1="60" x2="106" y2="60" />
            <line x1="27" y1="27" x2="38" y2="38" /><line x1="93" y1="27" x2="82" y2="38" />
            <line x1="27" y1="93" x2="38" y2="82" /><line x1="93" y1="93" x2="82" y2="82" />
          </g>
        </symbol>
        <symbol id="cf-moon" viewBox="0 0 120 120">
          <circle cx="58" cy="62" r="31" fill="#6a4e1f" mask="url(#cf-crescent)" />
        </symbol>
      </defs>
    </svg>
  </section>
</Base>

<script>
  import { ui, type Locale } from '../../../lib/i18n';
  import { loadProfile, PRISMS, type Prism, type Balance } from '../../../lib/profile';
  import { flipCoin } from '../../../lib/coin';

  const WIN_TARGET = 5;
  const LOSE_TARGET = 3;
  const ATTEMPTS: Record<Balance, number> = { risky: 1, balanced: 2, confident: 3 };
  const PRISM_COLOR: Record<Prism, string> = {
    instinct: '#e0564c',
    perseverance: '#e8cf55',
    eloquence: '#5fb573',
    concentration: '#5b8fd6',
    creativity: '#a578d6',
  };

  const section = document.querySelector<HTMLElement>('.confront')!;
  const locale = section.dataset.locale as Locale;
  const T = ui[locale];
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const FLIP_MS = 850;

  const introEl = document.querySelector<HTMLElement>('#intro')!;
  const pick = document.querySelector<HTMLElement>('#prism-pick')!;
  const roundLabel = document.querySelector<HTMLElement>('#round-label')!;
  const slotEls = Array.from(document.querySelectorAll<HTMLElement>('.slot'));
  const btn = document.querySelector<HTMLButtonElement>('#btn-act')!;
  const play = document.querySelector<HTMLElement>('#play')!;
  const logEl = document.querySelector<HTMLOListElement>('#log')!;
  const verdict = document.querySelector<HTMLElement>('#verdict')!;
  const verdictMain = document.querySelector<HTMLElement>('#verdict-main')!;
  const verdictSub = document.querySelector<HTMLElement>('#verdict-sub')!;
  const btnReset = document.querySelector<HTMLButtonElement>('#btn-reset')!;
  const winSegs = Array.from(document.querySelectorAll<HTMLElement>('#track-win .seg'));
  const loseSegs = Array.from(document.querySelectorAll<HTMLElement>('#track-lose .seg'));
  const floatWin = document.querySelector<HTMLElement>('#float-win')!;
  const floatLose = document.querySelector<HTMLElement>('#float-lose')!;

  const profile = loadProfile();
  let selected: Prism | null = null;
  let selectedBalance: Balance = 'balanced';
  let attempts = 0;
  let win = 0;
  let lose = 0;
  let round = 1;
  let busy = false;
  let over = false;
  const rot = [0, 0, 0];

  const delay = (ms: number) => new Promise((r) => window.setTimeout(r, ms));

  if (profile.name.trim()) introEl.textContent = `${profile.name.trim()} — ${T['confront.intro']}`;
  for (const p of PRISMS) {
    const n = ATTEMPTS[profile.prisms[p]];
    const bal = section.querySelector<HTMLElement>(`.pcard-bal[data-prism="${p}"]`);
    if (bal) bal.textContent = T[`balance.${profile.prisms[p]}`];
    const pipsEl = section.querySelector<HTMLElement>(`.pcard-pips[data-prism="${p}"]`);
    if (pipsEl) {
      pipsEl.style.color = PRISM_COLOR[p];
      for (let k = 0; k < 3; k++) {
        const pip = document.createElement('span');
        pip.className = k < n ? 'pip pip-on' : 'pip';
        pipsEl.appendChild(pip);
      }
    }
  }

  function setRoundLabel() {
    roundLabel.textContent = `${T['confront.round']} ${round}`;
  }
  setRoundLabel();

  // Allume les crans [from, to) avec la couleur du prisme du round.
  function fillSegs(segsArr: HTMLElement[], from: number, to: number, color: string) {
    for (let i = from; i < to; i++) {
      const s = segsArr[i];
      if (!s) continue;
      s.style.setProperty('--c', color);
      s.classList.add('on', 'just');
    }
    window.setTimeout(() => segsArr.forEach((s) => s.classList.remove('just')), 500);
  }

  function clearSegs(segsArr: HTMLElement[]) {
    segsArr.forEach((s) => {
      s.classList.remove('on', 'just');
      s.style.removeProperty('--c');
    });
  }

  function floatPoints(el: HTMLElement, pts: number, color: string) {
    el.textContent = `+${pts}`;
    el.style.color = color;
    el.classList.remove('go');
    void el.offsetWidth;
    el.classList.add('go');
  }

  function addLog(prism: Prism, success: boolean, pts: number, crit: boolean) {
    const li = document.createElement('li');
    li.className = `log-item ${success ? 'win' : 'lose'}${crit ? ' crit' : ''}`;
    li.style.setProperty('--c', PRISM_COLOR[prism]);
    li.innerHTML =
      `<span class="log-dot"></span>` +
      `<span class="log-name">${T[`prism.${prism}`]}</span>` +
      `<span class="log-face">${success ? '☀' : '☾'}</span>` +
      `<span class="log-pts">+${pts}</span>`;
    logEl.appendChild(li);
  }

  function resetSlots() {
    slotEls.forEach((s) => s.classList.remove('is-sun', 'is-moon', 'active'));
    slotEls.forEach((s) => s.classList.add('idle'));
  }

  pick.addEventListener('change', (e) => {
    const target = e.target as HTMLInputElement;
    if (target.type !== 'radio' || over) return;
    selected = target.value as Prism;
    selectedBalance = profile.prisms[selected];
    attempts = ATTEMPTS[selectedBalance];
    section.style.setProperty('--prism', PRISM_COLOR[selected]);
    slotEls.forEach((s, i) => (s.hidden = i >= attempts));
    resetSlots();
    btn.disabled = false;
  });

  async function flipSlot(i: number, side: 'heads' | 'tails') {
    const slot = slotEls[i];
    const coin = slot.querySelector<HTMLElement>('.coin')!;
    slot.classList.remove('idle');
    slot.classList.add('active');
    const targetDeg = side === 'heads' ? 0 : 180;
    const spins = 3 + Math.floor(Math.random() * 2);
    rot[i] += spins * 360;
    rot[i] += ((targetDeg - (rot[i] % 360)) + 360) % 360;
    if (reduceMotion) coin.style.transition = 'none';
    coin.style.transform = `rotateX(${rot[i]}deg)`;
    await delay(reduceMotion ? 120 : FLIP_MS);
    slot.classList.add(side === 'heads' ? 'is-sun' : 'is-moon');
  }

  btn.addEventListener('click', async () => {
    if (busy || over || !selected) return;
    busy = true;
    btn.disabled = true;
    resetSlots();
    await delay(reduceMotion ? 0 : 140);

    let success = false;
    for (let i = 0; i < attempts; i++) {
      const side = flipCoin();
      await flipSlot(i, side);
      if (side === 'heads') {
        success = true;
        break;
      }
      await delay(reduceMotion ? 0 : 220);
    }

    const crit = success ? selectedBalance === 'risky' : selectedBalance === 'confident';
    const pts = crit ? 2 : 1;
    const color = PRISM_COLOR[selected];
    if (success) {
      const prev = win;
      win = Math.min(WIN_TARGET, win + pts);
      fillSegs(winSegs, prev, win, color);
      floatPoints(floatWin, pts, color);
    } else {
      const prev = lose;
      lose = Math.min(LOSE_TARGET, lose + pts);
      fillSegs(loseSegs, prev, lose, color);
      floatPoints(floatLose, pts, color);
    }
    addLog(selected, success, pts, crit);

    await delay(reduceMotion ? 0 : 420);

    if (win >= WIN_TARGET || lose >= LOSE_TARGET) {
      over = true;
      const won = win >= WIN_TARGET;
      verdictMain.textContent = won ? T['confront.win'] : T['confront.lose'];
      verdictSub.textContent = won ? T['confront.win.sub'] : T['confront.lose.sub'];
      verdict.className = 'verdict';
      verdict.hidden = false;
      void verdict.offsetWidth;
      verdict.classList.add(won ? 'is-win' : 'is-lose');
      play.hidden = true;
      btnReset.hidden = false;
      busy = false;
      return;
    }

    round += 1;
    setRoundLabel();
    busy = false;
    if (selected) btn.disabled = false;
  });

  btnReset.addEventListener('click', () => {
    win = 0;
    lose = 0;
    round = 1;
    over = false;
    selected = null;
    clearSegs(winSegs);
    clearSegs(loseSegs);
    logEl.replaceChildren();
    resetSlots();
    slotEls.forEach((s) => (s.hidden = true));
    section.querySelectorAll<HTMLInputElement>('input[name="prism"]').forEach((r) => (r.checked = false));
    section.style.removeProperty('--prism');
    verdict.hidden = true;
    btnReset.hidden = true;
    play.hidden = false;
    btn.disabled = true;
    setRoundLabel();
  });
</script>

<style>
  .confront {
    display: grid;
    gap: 2.25rem;
    max-width: 46rem;
    margin: 0 auto;
    --prism: var(--accent);
  }
  .lede {
    text-align: center;
  }
  .eyebrow {
    margin: 0 0 0.35rem;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.24em;
    color: var(--accent);
  }
  .lede h1 {
    font-size: clamp(2.6rem, 6vw, 3.6rem);
    margin: 0 0 0.5rem;
  }
  .intro {
    color: var(--muted);
    margin: 0;
  }

  /* ---- Jauges ---- */
  .gauges {
    display: grid;
    justify-items: center;
    gap: 0.6rem;
    max-width: 34rem;
    width: 100%;
    margin: 0 auto;
  }
  .gauge {
    width: 100%;
    display: grid;
    gap: 0.4rem;
  }
  .gauge-label {
    text-align: center;
    font-family: var(--font-display);
    font-size: 1.35rem;
    letter-spacing: 0.04em;
  }
  .gauge-win .gauge-label {
    color: var(--accent);
  }
  .gauge-lose .gauge-label {
    color: var(--accent-2);
  }
  .gauge-track {
    position: relative;
    display: flex;
    gap: 0.5rem;
    justify-content: center;
  }
  .seg {
    flex: 1 1 0;
    height: 1.1rem;
    border-radius: 5px;
    border: 1px solid var(--line);
    background: rgba(240, 226, 196, 0.04);
    transition: background-color 0.35s ease, box-shadow 0.35s ease, transform 0.35s ease;
  }
  /* crans vides : teinte discrète propre à la jauge (identité Victoire/Échec) */
  .gauge-win .seg {
    border-color: color-mix(in srgb, var(--accent) 30%, var(--line));
  }
  .gauge-lose .seg {
    border-color: color-mix(in srgb, var(--accent-2) 30%, var(--line));
  }
  /* cran allumé : couleur du prisme qui a marqué ce point */
  .seg.on {
    background: var(--c, var(--accent));
    border-color: var(--c, var(--accent));
    box-shadow: 0 0 12px -1px var(--c, var(--accent));
  }
  .seg.just {
    transform: translateY(-3px) scaleY(1.15);
  }
  .gauge-vs {
    color: var(--muted);
    font-family: var(--font-display);
    font-size: 1.2rem;
  }
  .float {
    position: absolute;
    top: -0.4rem;
    right: 0;
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    opacity: 0;
    pointer-events: none;
  }
  .gauge-win .float {
    color: var(--accent);
  }
  .gauge-lose .float {
    color: var(--accent-2);
  }
  .float.go {
    animation: float-up 0.9s ease-out;
  }
  @keyframes float-up {
    0% {
      opacity: 0;
      transform: translateY(6px);
    }
    25% {
      opacity: 1;
    }
    100% {
      opacity: 0;
      transform: translateY(-22px);
    }
  }

  /* ---- Round + choix du prisme ---- */
  .play {
    display: grid;
    justify-items: center;
    gap: 1.5rem;
  }
  .round-label {
    margin: 0;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--muted);
  }
  .prism-pick {
    border: none;
    margin: 0;
    padding: 0;
    width: 100%;
  }
  .prism-pick legend {
    padding: 0;
    width: 100%;
    text-align: center;
    font-family: var(--font-display);
    font-size: 1.35rem;
    margin-bottom: 0.85rem;
  }
  .pcards {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.65rem;
  }
  .pcard {
    flex: 1 1 7.5rem;
    max-width: 9.5rem;
    cursor: pointer;
  }
  .pcard input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  .pcard-in {
    display: grid;
    justify-items: center;
    gap: 0.4rem;
    text-align: center;
    padding: 1rem 0.7rem 0.85rem;
    height: 100%;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: linear-gradient(180deg, rgba(240, 226, 196, 0.06), rgba(240, 226, 196, 0.015));
    transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }
  .pcard:hover .pcard-in {
    transform: translateY(-2px);
  }
  .pcard input:checked + .pcard-in {
    border-color: var(--prism, var(--accent));
    background: linear-gradient(180deg,
      color-mix(in srgb, var(--prism, var(--accent)) 14%, transparent), rgba(240, 226, 196, 0.02));
    box-shadow: 0 0 24px -8px var(--prism, var(--accent));
  }
  .pcard input:focus-visible + .pcard-in {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .pcard-name {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 600;
    line-height: 1.1;
  }
  .pcard-bal {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
  }
  .pcard-pips {
    display: inline-flex;
    gap: 0.28rem;
  }
  .pip {
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 50%;
    border: 1px solid currentColor;
    opacity: 0.35;
  }
  .pip-on {
    background: currentColor;
    opacity: 1;
    box-shadow: 0 0 6px currentColor;
  }
  .dot {
    width: 0.85rem;
    height: 0.85rem;
    border-radius: 50%;
    box-shadow: 0 0 9px currentColor;
  }
  .dot-instinct { color: #e0564c; background: #e0564c; }
  .dot-perseverance { color: #e8cf55; background: #e8cf55; }
  .dot-eloquence { color: #5fb573; background: #5fb573; }
  .dot-concentration { color: #5b8fd6; background: #5b8fd6; }
  .dot-creativity { color: #a578d6; background: #a578d6; }

  /* ---- Arène (pièces) ---- */
  .arena {
    display: grid;
    justify-items: center;
    gap: 1.25rem;
  }
  .slots {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
    min-height: 80px;
  }
  .slot {
    width: 80px;
    height: 80px;
    perspective: 560px;
    transition: opacity 0.3s ease;
  }
  .slot.idle {
    opacity: 0.4;
  }
  .slot.idle .cface {
    opacity: 0;
  }
  .slot.is-sun {
    filter: drop-shadow(0 0 8px var(--accent));
  }
  .coin {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    transition: transform 0.85s cubic-bezier(0.32, 0.02, 0.18, 1);
  }
  .face {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    overflow: hidden;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    background: radial-gradient(circle at 38% 28%,
      #fbeeb8 0%, #ecd68e 24%, #d4b25c 48%, #bd9743 72%, #94742f 90%, #6f571f 100%);
    box-shadow:
      inset 0 0 0 2px rgba(111, 82, 31, 0.55),
      inset 0 4px 9px rgba(255, 246, 214, 0.4),
      inset 0 -6px 11px rgba(80, 58, 20, 0.5),
      0 8px 18px rgba(0, 0, 0, 0.5);
  }
  .face-sun { transform: rotateX(0deg) translateZ(4px); }
  .face-moon { transform: rotateX(180deg) translateZ(4px); }
  .cface {
    width: 100%;
    height: 100%;
    transition: opacity 0.2s ease;
  }

  .btn-act,
  .btn-reset {
    font-family: var(--font-body);
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    padding: 0.7rem 1.9rem;
    border-radius: 999px;
    cursor: pointer;
    transition: background-color 0.2s ease, box-shadow 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }
  .btn-act {
    border: 1px solid var(--accent);
    background: var(--accent);
    color: var(--ground);
  }
  .btn-act:hover:not(:disabled) {
    background: #d9b45c;
    box-shadow: 0 0 24px rgba(201, 164, 76, 0.35);
  }
  .btn-act:disabled {
    opacity: 0.5;
    cursor: default;
  }
  .btn-reset {
    justify-self: center;
    border: 1px solid var(--line);
    background: transparent;
    color: var(--muted);
  }
  .btn-reset:hover {
    color: var(--text);
    border-color: var(--accent);
  }

  /* ---- Journal ---- */
  .log {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.4rem;
  }
  .log-item {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
    border: 1px solid var(--line);
    font-size: 0.8rem;
  }
  .log-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: var(--c);
    box-shadow: 0 0 6px var(--c);
  }
  .log-name {
    color: var(--muted);
  }
  .log-pts {
    font-weight: 600;
  }
  .log-item.win .log-pts,
  .log-item.win .log-face {
    color: var(--accent);
  }
  .log-item.lose .log-pts,
  .log-item.lose .log-face {
    color: var(--accent-2);
  }
  .log-item.crit {
    border-color: currentColor;
  }

