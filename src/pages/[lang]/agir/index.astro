---
import Base from '../../../layouts/Base.astro';
import { LOCALES, type Locale, t } from '../../../lib/i18n';

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;
---

<Base locale={locale} title={t(locale, 'nav.agir')}>
  <section class="hub">
    <div class="hub-lede">
      <h1>{t(locale, 'nav.agir')}</h1>
      <p class="hub-tagline">{t(locale, 'agir.intro')}</p>
    </div>

    <nav class="portals" aria-label={t(locale, 'nav.agir')}>
      <a class="portal" href={`/${locale}/agir/action/`}>
        <span class="portal-emblem" aria-hidden="true">
          <svg viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="1.6">
            <circle cx="40" cy="40" r="28" />
            <path d="M40 55 V27 M30 37 l10 -10 l10 10" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </span>
        <span class="portal-title">{t(locale, 'agir.heading')}</span>
        <span class="portal-desc">{t(locale, 'agir.action.desc')}</span>
        <span class="portal-enter">{t(locale, 'hub.enter')} →</span>
      </a>

      <a class="portal" href={`/${locale}/agir/confrontation/`}>
        <span class="portal-emblem" aria-hidden="true">
          <svg viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="1.6">
            <circle cx="40" cy="40" r="28" />
            <path d="M32 30 l-10 10 l10 10 M48 30 l10 10 l-10 10" stroke-linecap="round" stroke-linejoin="round" />
            <line x1="40" y1="22" x2="40" y2="58" opacity="0.5" />
          </svg>
        </span>
        <span class="portal-title">{t(locale, 'confront.heading')}</span>
        <span class="portal-desc">{t(locale, 'agir.confront.desc')}</span>
        <span class="portal-enter">{t(locale, 'hub.enter')} →</span>
      </a>
    </nav>
  </section>
</Base>

<style>
  .hub {
    display: grid;
    gap: 3rem;
    padding-top: 2rem;
  }
  .hub-lede {
    text-align: center;
    max-width: 40rem;
    margin: 0 auto;
  }
  .hub-lede h1 {
    font-size: clamp(2.8rem, 7vw, 4.2rem);
    margin: 0 0 0.5rem;
  }
  .hub-tagline {
    color: var(--muted);
    font-size: 1.15rem;
    font-style: italic;
    margin: 0;
  }
  .portals {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem;
    max-width: 46rem;
    width: 100%;
    margin: 0 auto;
  }
  .portal {
    display: grid;
    justify-items: center;
    gap: 0.6rem;
    text-align: center;
    text-decoration: none;
    color: var(--text);
    padding: 2.5rem 1.75rem 2rem;
    border: 1px solid var(--line);
    border-radius: 16px;
    background: var(--panel);
    transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
  }
  .portal:hover,
  .portal:focus-visible {
    transform: translateY(-4px);
    border-color: var(--accent);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.45), 0 0 30px rgba(201, 164, 76, 0.15);
  }
  .portal-emblem {
    color: var(--accent);
    width: 5rem;
    height: 5rem;
  }
  .portal-emblem svg {
    width: 100%;
    height: 100%;
  }
  .portal-title {
    font-family: var(--font-display);
    font-size: 2.2rem;
    font-weight: 600;
    line-height: 1;
  }
  .portal-desc {
    color: var(--muted);
    max-width: 16rem;
  }
  .portal-enter {
    margin-top: 0.4rem;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--accent);
  }

  @media (max-width: 40rem) {
    .portals {
      grid-template-columns: 1fr;
    }
  }
</style>
