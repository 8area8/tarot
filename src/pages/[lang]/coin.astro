---
import Base from '../../layouts/Base.astro';
import { LOCALES, type Locale, t } from '../../lib/i18n';

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;
---

<Base locale={locale} title={t(locale, 'nav.coin')}>
  <section class="coin-app" data-locale={locale}>
    <div class="lede">
      <h1>{t(locale, 'coin.heading')}</h1>
      <p class="intro">{t(locale, 'coin.intro')}</p>
    </div>

    <div class="coin-stage">
      <div class="coin-toss" id="toss">
        <div class="coin" id="coin">
          <div class="coin-face face-sun">
            <svg viewBox="0 0 120 120" aria-hidden="true">
              <circle class="emblem" cx="60" cy="60" r="13" />
              <circle class="emblem-ring" cx="60" cy="60" r="20" />
              <g class="emblem-stroke">
                <line x1="60" y1="14" x2="60" y2="29" />
                <line x1="60" y1="91" x2="60" y2="106" />
                <line x1="14" y1="60" x2="29" y2="60" />
                <line x1="91" y1="60" x2="106" y2="60" />
                <line x1="27" y1="27" x2="38" y2="38" />
                <line x1="93" y1="27" x2="82" y2="38" />
                <line x1="27" y1="93" x2="38" y2="82" />
                <line x1="93" y1="93" x2="82" y2="82" />
              </g>
            </svg>
          </div>
          <div class="coin-face face-moon">
            <svg viewBox="0 0 120 120" aria-hidden="true">
              <defs>
                <mask id="crescent-mask">
                  <rect width="120" height="120" fill="#fff" />
                  <circle cx="76" cy="52" r="28" fill="#000" />
                </mask>
              </defs>
              <circle class="emblem" cx="58" cy="62" r="31" mask="url(#crescent-mask)" />
            </svg>
          </div>
        </div>
      </div>
    </div>

    <div class="coin-result" aria-live="polite">
      <p class="placeholder" id="placeholder">{t(locale, 'coin.placeholder')}</p>
      <p class="result" id="result" hidden></p>
    </div>

    <button type="button" class="btn-flip" id="btn-flip">{t(locale, 'action.flip')}</button>
  </section>
</Base>

<script>
  import { ui, type Locale } from '../../lib/i18n';
  import { flipCoin } from '../../lib/coin';

  const app = document.querySelector<HTMLElement>('.coin-app')!;
  const locale = app.dataset.locale as Locale;
  const T = ui[locale];
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const coin = document.querySelector<HTMLElement>('#coin')!;
  const toss = document.querySelector<HTMLElement>('#toss')!;
  const btn = document.querySelector<HTMLButtonElement>('#btn-flip')!;
  const placeholder = document.querySelector<HTMLElement>('#placeholder')!;
  const result = document.querySelector<HTMLElement>('#result')!;

  let rotation = 0; // degrés cumulés sur l'axe X
  const rand = () => Math.random();

  function showResult(side: 'heads' | 'tails') {
    const isHeads = side === 'heads';
    result.textContent = `${isHeads ? '☀' : '☾'} ${isHeads ? T['coin.heads'] : T['coin.tails']}`;
    result.classList.toggle('is-tails', !isHeads);
    placeholder.hidden = true;
    result.hidden = false;
    btn.textContent = T['action.flipAgain'];
  }

  btn.addEventListener('click', () => {
    const side = flipCoin();

    // Face (Soleil) → rotation ≡ 0 (mod 360) ; Pile (Lune) → ≡ 180.
    const target = side === 'heads' ? 0 : 180;
    const spins = 4 + Math.floor(rand() * 5); // 4 à 8 tours
    rotation += spins * 360;
    rotation += ((target - (rotation % 360)) + 360) % 360;

    if (reduceMotion) {
      coin.style.transform = `rotateX(${rotation}deg)`;
      showResult(side);
      return;
    }

    // Chaque lancer est unique : durée, hauteur et bascule légèrement randomisées.
    const duration = Math.round(950 + rand() * 750); // 950–1700 ms
    const tossH = Math.round(60 + rand() * 60); // 60–120 px
    const tossRot = (rand() * 28 - 14).toFixed(1); // -14° à +14°

    btn.disabled = true;
    result.classList.add('is-fading');

    coin.style.transitionDuration = `${duration}ms`;
    coin.style.transform = `rotateX(${rotation}deg)`;

    toss.style.setProperty('--toss-h', `${tossH}px`);
    toss.style.setProperty('--toss-rot', `${tossRot}deg`);
    toss.style.animationDuration = `${duration}ms`;
    toss.classList.remove('is-tossing');
    void toss.offsetWidth; // relance l'animation
    toss.classList.add('is-tossing');

    window.setTimeout(() => {
      showResult(side);
      result.classList.remove('is-fading');
      btn.disabled = false;
    }, duration);
  });
</script>

<style>
  .coin-app {
    display: grid;
    justify-items: center;
    gap: 2rem;
    padding-top: 1rem;
  }
  .lede {
    text-align: center;
    max-width: 32rem;
  }
  .lede h1 {
    font-size: clamp(2.6rem, 6vw, 3.8rem);
    margin: 0 0 0.5rem;
  }
  .intro {
    color: var(--muted);
    font-size: 1.05rem;
    margin: 0;
  }

  .coin-stage {
    perspective: 1000px;
    padding: 1.5rem 0;
  }
  .coin-toss {
    width: 204px;
    height: 204px;
  }
  .coin-toss.is-tossing {
    animation: toss 1100ms ease-in-out;
  }
  .coin {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    transition: transform 1100ms cubic-bezier(0.32, 0.02, 0.18, 1);
  }
  .coin-face {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    overflow: hidden;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    background:
      radial-gradient(circle at 38% 28%,
        #fbeeb8 0%, #ecd68e 24%, #d4b25c 48%, #bd9743 72%, #94742f 90%, #6f571f 100%);
    box-shadow:
      inset 0 0 0 3px rgba(111, 82, 31, 0.55),
      inset 0 0 0 5px rgba(251, 238, 184, 0.3),
      inset 0 9px 18px rgba(255, 246, 214, 0.4),
      inset 0 -12px 22px rgba(80, 58, 20, 0.55),
      0 20px 38px rgba(0, 0, 0, 0.55);
  }
  /* tranche moletée (reeded edge) */
  .coin-face::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: repeating-conic-gradient(
      from 0deg,
      rgba(90, 66, 24, 0.6) 0deg 2.2deg,
      rgba(240, 214, 140, 0.3) 2.2deg 4.4deg
    );
    -webkit-mask: radial-gradient(circle, transparent 0 45%, #000 47% 50%, transparent 51%);
    mask: radial-gradient(circle, transparent 0 45%, #000 47% 50%, transparent 51%);
  }
  /* brillance spéculaire */
  .coin-face::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: linear-gradient(125deg, rgba(255, 252, 240, 0.6) 0%, transparent 40%);
    opacity: 0.55;
  }
  .face-sun {
    transform: rotateX(0deg) translateZ(6px);
  }
  .face-moon {
    transform: rotateX(180deg) translateZ(6px);
  }
  .coin-face svg {
    position: relative;
    width: 100%;
    height: 100%;
  }
  .emblem {
    fill: #6a4e1f;
    opacity: 0.9;
  }
  .emblem-ring {
    fill: none;
    stroke: #6a4e1f;
    stroke-width: 3;
    opacity: 0.75;
  }
  .emblem-stroke {
    stroke: #6a4e1f;
    stroke-width: 5;
    stroke-linecap: round;
    opacity: 0.9;
  }

  .coin-result {
    min-height: 3.2rem;
    display: flex;
    align-items: center;
    text-align: center;
  }
  .placeholder {
    color: var(--muted);
    font-style: italic;
    margin: 0;
  }
  .result {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 6vw, 3.2rem);
    font-weight: 600;
    margin: 0;
    color: var(--accent);
    transition: opacity 0.25s ease;
  }
  .result.is-tails {
    color: #a9b6d6; /* clair lunaire */
  }
  .result.is-fading {
    opacity: 0;
  }

  .btn-flip {
    font-family: var(--font-body);
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    padding: 0.7rem 1.9rem;
    border: 1px solid var(--accent);
    border-radius: 999px;
    background: var(--accent);
    color: var(--ground);
    cursor: pointer;
    transition: background-color 0.2s ease, box-shadow 0.2s ease;
  }
  .btn-flip:hover:not(:disabled) {
    background: #d9b45c;
    box-shadow: 0 0 24px rgba(201, 164, 76, 0.35);
  }
  .btn-flip:disabled {
    opacity: 0.6;
    cursor: default;
  }

  @keyframes toss {
    0% {
      transform: translateY(0) rotate(0deg) scale(1);
    }
    45% {
      transform: translateY(calc(-1 * var(--toss-h, 80px))) rotate(var(--toss-rot, 0deg)) scale(1.06);
    }
    100% {
      transform: translateY(0) rotate(0deg) scale(1);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .coin {
      transition: none;
    }
    .coin-toss.is-tossing {
      animation: none;
    }
  }
</style>
