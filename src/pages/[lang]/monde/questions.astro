---
import Base from '../../../layouts/Base.astro';
import { LOCALES, type Locale, t } from '../../../lib/i18n';

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;
---

<Base locale={locale} title={t(locale, 'monde.questions')}>
  <section class="questions" data-locale={locale}>
    <div class="lede">
      <p class="eyebrow">{t(locale, 'nav.monde')}</p>
      <h1>{t(locale, 'monde.questions')}</h1>
      <p class="intro">{t(locale, 'questions.intro')}</p>
    </div>

    <form class="q-add" id="q-add">
      <input
        type="text"
        id="q-input"
        maxlength="200"
        autocomplete="off"
        placeholder={t(locale, 'questions.add.ph')}
      />
      <button type="submit" class="btn-add">
        <span class="btn-add-glyph" aria-hidden="true">+</span>
        <span>{t(locale, 'questions.add')}</span>
      </button>
    </form>

    <div class="q-status">
      <span class="tally" id="tally" hidden></span>
    </div>

    <p class="empty" id="empty" hidden>{t(locale, 'questions.empty')}</p>
    <ol class="q-list" id="q-list"></ol>
  </section>
</Base>

<script>
  import { ui, type Locale } from '../../../lib/i18n';
  import { loadWorld, saveWorld, newId, type Question } from '../../../lib/world';

  const section = document.querySelector<HTMLElement>('.questions')!;
  const locale = section.dataset.locale as Locale;
  const T = ui[locale];
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const form = document.querySelector<HTMLFormElement>('#q-add')!;
  const input = document.querySelector<HTMLInputElement>('#q-input')!;
  const tally = document.querySelector<HTMLElement>('#tally')!;
  const emptyEl = document.querySelector<HTMLElement>('#empty')!;
  const list = document.querySelector<HTMLOListElement>('#q-list')!;

  const world = loadWorld();

  // Astro scope les styles via un attribut data-astro-cid-* posé sur les éléments
  // du template ; ceux créés ici en JS ne l'ont pas. On le recopie sur chaque
  // nœud créé, sinon les règles scopées (.q-item…) ne s'appliquent jamais.
  const SCOPE = section.getAttributeNames().find((n) => n.startsWith('data-astro-cid-'));
  function applyScope(root: HTMLElement) {
    if (!SCOPE) return;
    root.setAttribute(SCOPE, '');
    for (const el of root.querySelectorAll<HTMLElement>('*')) el.setAttribute(SCOPE, '');
  }

  function applyDoneState(li: HTMLElement, done: boolean) {
    li.toggleAttribute('data-done', done);
    const check = li.querySelector<HTMLButtonElement>('.q-check')!;
    check.setAttribute('aria-pressed', String(done));
    check.setAttribute('aria-label', done ? T['questions.undone'] : T['questions.done']);
  }

  function makeItem(q: Question): HTMLLIElement {
    const li = document.createElement('li');
    li.className = 'q-item';
    li.dataset.id = q.id;

    const check = document.createElement('button');
    check.type = 'button';
    check.className = 'q-check';

    const field = document.createElement('input');
    field.className = 'q-text';
    field.type = 'text';
    field.maxLength = 200;
    field.value = q.text;

    const actions = document.createElement('div');
    actions.className = 'q-actions';

    const up = document.createElement('button');
    up.type = 'button';
    up.className = 'q-move q-up';
    up.setAttribute('aria-label', T['questions.moveUp']);
    up.innerHTML = '<span aria-hidden="true">↑</span>';

    const down = document.createElement('button');
    down.type = 'button';
    down.className = 'q-move q-down';
    down.setAttribute('aria-label', T['questions.moveDown']);
    down.innerHTML = '<span aria-hidden="true">↓</span>';

    const del = document.createElement('button');
    del.type = 'button';
    del.className = 'q-del';
    del.setAttribute('aria-label', T['questions.delete']);
    del.innerHTML = '<span aria-hidden="true">×</span>';

    actions.append(up, down, del);
    li.append(check, field, actions);
    applyDoneState(li, q.done);
    applyScope(li);
    return li;
  }

  function refreshControls() {
    const total = world.questions.length;
    const done = world.questions.filter((q) => q.done).length;
    emptyEl.hidden = total > 0;
    tally.hidden = total === 0;
    const word = total === 1 ? T['questions.one'] : T['questions.many'];
    tally.textContent =
      `${total} ${word}` + (done > 0 ? ` · ${done} ${T['questions.resolvedTally']}` : '');

    // Premiers/derniers : flèches désactivées aux extrémités.
    const items = Array.from(list.querySelectorAll<HTMLElement>('.q-item'));
    items.forEach((li, i) => {
      li.querySelector<HTMLButtonElement>('.q-up')!.disabled = i === 0;
      li.querySelector<HTMLButtonElement>('.q-down')!.disabled = i === items.length - 1;
    });
  }

  for (const q of world.questions) list.appendChild(makeItem(q));
  refreshControls();

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const text = input.value.trim();
    if (!text) return;
    const q: Question = { id: newId(), text, done: false };
    world.questions.push(q);
    saveWorld(world);
    const li = makeItem(q);
    list.appendChild(li);
    if (!reduceMotion) {
      li.classList.add('reveal');
    }
    input.value = '';
    input.focus();
    refreshControls();
  });

  list.addEventListener('input', (e) => {
    const target = e.target as HTMLElement;
    if (!target.classList.contains('q-text')) return;
    const li = target.closest<HTMLElement>('.q-item');
    const q = world.questions.find((x) => x.id === li?.dataset.id);
    if (q) {
      q.text = (target as HTMLInputElement).value;
      saveWorld(world);
    }
  });

  list.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const li = target.closest<HTMLElement>('.q-item');
    if (!li) return;
    const id = li.dataset.id;
    const idx = world.questions.findIndex((x) => x.id === id);
    if (idx < 0) return;

    // Basculer résolue.
    if (target.closest('.q-check')) {
      const q = world.questions[idx];
      q.done = !q.done;
      saveWorld(world);
      applyDoneState(li, q.done);
      refreshControls();
      return;
    }

    // Réordonner.
    const move = target.closest<HTMLElement>('.q-move');
    if (move) {
      const dir = move.classList.contains('q-up') ? -1 : 1;
      const j = idx + dir;
      if (j < 0 || j >= world.questions.length) return;
      [world.questions[idx], world.questions[j]] = [world.questions[j], world.questions[idx]];
      saveWorld(world);
      if (dir === -1 && li.previousElementSibling) {
        list.insertBefore(li, li.previousElementSibling);
      } else if (dir === 1 && li.nextElementSibling) {
        list.insertBefore(li.nextElementSibling, li);
      }
      refreshControls();
      return;
    }

    // Supprimer.
    if (target.closest('.q-del')) {
      world.questions.splice(idx, 1);
      saveWorld(world);
      if (reduceMotion) {
        li.remove();
        refreshControls();
      } else {
        li.classList.add('leaving');
        li.addEventListener('transitionend', () => {
          li.remove();
          refreshControls();
        }, { once: true });
      }
    }
  });
</script>

<style>
  .questions {
    display: grid;
    gap: 1.5rem;
    max-width: 42rem;
    margin: 0 auto;
  }
  .lede {
    text-align: center;
    max-width: 34rem;
    margin: 0 auto;
  }
  .eyebrow {
    margin: 0 0 0.4rem;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.24em;
    color: var(--accent);
  }
  .lede h1 {
    font-size: clamp(2.6rem, 6vw, 3.6rem);
    margin: 0 0 0.5rem;
  }
  .intro {
    color: var(--muted);
    margin: 0;
  }

  /* ---- Ajout ---- */
  .q-add {
    display: flex;
    gap: 0.6rem;
  }
  #q-input {
    flex: 1;
    min-width: 0;
    font: inherit;
    color: var(--text);
    background: rgba(240, 226, 196, 0.03);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.6rem 1.1rem;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  #q-input::placeholder {
    color: rgba(240, 226, 196, 0.4);
    font-style: italic;
  }
  #q-input:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(201, 164, 76, 0.12);
  }
  .btn-add {
    flex: none;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-body);
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    padding: 0.6rem 1.3rem;
    border: 1px solid var(--accent);
    border-radius: 999px;
    background: var(--accent);
    color: var(--ground);
    cursor: pointer;
    transition: background-color 0.2s ease, box-shadow 0.2s ease;
  }
  .btn-add-glyph {
    font-size: 1.05rem;
    line-height: 1;
  }
  .btn-add:hover {
    background: #d9b45c;
    box-shadow: 0 0 20px rgba(201, 164, 76, 0.3);
  }

  .q-status {
    display: flex;
    justify-content: center;
    min-height: 1.4rem;
    margin-top: -0.5rem;
  }
  .tally {
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--muted);
    padding: 0.3rem 0.85rem;
    border: 1px solid var(--line);
    border-radius: 999px;
  }
  .empty {
    text-align: center;
    color: var(--muted);
    font-style: italic;
    margin: 0;
  }

  /* ---- Liste ---- */
  .q-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.55rem;
    counter-reset: q;
  }
  .q-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.5rem 0.4rem 0.55rem;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: var(--panel);
    counter-increment: q;
    transition: border-color 0.2s ease, background-color 0.25s ease, opacity 0.25s ease,
      transform 0.25s ease;
  }
  .q-item:hover {
    border-color: rgba(201, 164, 76, 0.4);
  }
  .q-item.reveal {
    animation: q-in 0.35s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .q-item.leaving {
    opacity: 0;
    transform: translateX(10px);
  }
  @keyframes q-in {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  /* Pastille numérotée = bascule « résolue ». */
  .q-check {
    flex: none;
    width: 1.85rem;
    height: 1.85rem;
    display: grid;
    place-items: center;
    font-family: var(--font-display);
    font-size: 0.95rem;
    color: var(--accent);
    background: transparent;
    border: 1px solid var(--line);
    border-radius: 50%;
    cursor: pointer;
    transition: color 0.2s ease, border-color 0.2s ease, background-color 0.2s ease;
  }
  .q-check::before {
    content: counter(q);
  }
  .q-check:hover {
    border-color: var(--accent);
    background: rgba(201, 164, 76, 0.1);
  }
  .q-item[data-done] .q-check {
    color: var(--ground);
    background: var(--accent);
    border-color: var(--accent);
  }
  .q-item[data-done] .q-check::before {
    content: '✓';
    font-family: var(--font-body);
  }

  .q-text {
    flex: 1;
    min-width: 0;
    font: inherit;
    font-size: 1.02rem;
    color: var(--text);
    background: transparent;
    border: none;
    padding: 0.35rem 0.2rem;
    transition: color 0.25s ease;
  }
  .q-text:focus {
    outline: none;
  }
  .q-item[data-done] .q-text {
    color: var(--muted);
    text-decoration: line-through;
    text-decoration-color: rgba(201, 164, 76, 0.5);
  }

  .q-actions {
    flex: none;
    display: flex;
    align-items: center;
    gap: 0.15rem;
  }
  .q-move,
  .q-del {
    flex: none;
    width: 1.85rem;
    height: 1.85rem;
    display: grid;
    place-items: center;
    line-height: 1;
    border-radius: 50%;
    border: 1px solid transparent;
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    transition: color 0.2s ease, border-color 0.2s ease, background-color 0.2s ease,
      opacity 0.2s ease;
  }
  .q-move {
    font-size: 1rem;
  }
  .q-del {
    font-size: 1.25rem;
  }
  .q-move:hover:not(:disabled) {
    color: var(--accent);
    border-color: var(--line);
    background: rgba(201, 164, 76, 0.08);
  }
  .q-move:disabled {
    opacity: 0.25;
    cursor: default;
  }
  .q-del:hover {
    color: var(--accent-2);
    border-color: var(--accent-2);
    background: rgba(181, 83, 47, 0.12);
  }

  @media (max-width: 30rem) {
    .q-actions {
      gap: 0;
    }
    .q-move,
    .q-del,
    .q-check {
      width: 1.7rem;
      height: 1.7rem;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .q-item.reveal {
      animation: none;
    }
    .q-item,
    .q-check,
    .q-move,
    .q-del,
    #q-input {
      transition: none;
    }
  }
</style>
