---
import Base from '../../../layouts/Base.astro';
import { LOCALES, type Locale, t } from '../../../lib/i18n';

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;
---

<Base locale={locale} title={t(locale, 'nav.oracles')}>
  <section class="hub">
    <div class="hub-lede">
      <h1>{t(locale, 'nav.oracles')}</h1>
      <p class="hub-tagline">{t(locale, 'oracles.intro')}</p>
    </div>

    <nav class="portals" aria-label={t(locale, 'nav.oracles')}>
      <a class="portal" href={`/${locale}/oracles/tarot/`}>
        <span class="portal-emblem" aria-hidden="true">
          <svg viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="1.6">
            <rect x="24" y="9" width="32" height="54" rx="5" />
            <path
              d="M40 22 L43.5 36.5 L58 40 L43.5 43.5 L40 58 L36.5 43.5 L22 40 L36.5 36.5 Z"
              fill="currentColor"
              stroke="none"
            />
          </svg>
        </span>
        <span class="portal-title">{t(locale, 'nav.tarot')}</span>
        <span class="portal-desc">{t(locale, 'hub.tarot.desc')}</span>
        <span class="portal-enter">{t(locale, 'hub.enter')} →</span>
      </a>

      <a class="portal" href={`/${locale}/oracles/coin/`}>
        <span class="portal-emblem" aria-hidden="true">
          <svg viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="1.6">
            <circle cx="40" cy="40" r="26" />
            <circle cx="33" cy="35" r="6.5" fill="currentColor" stroke="none" />
            <g stroke-width="1.3">
              <path d="M33 24v-5M33 51v5M22 35h-5M44 35h5M25.4 27.4l-3.5-3.5M40.6 27.4l3.5-3.5" />
            </g>
            <path
              d="M52 42a11 11 0 1 1-9.8-11 8.5 8.5 0 1 0 9.8 11Z"
              fill="currentColor"
              stroke="none"
            />
          </svg>
        </span>
        <span class="portal-title">{t(locale, 'nav.coin')}</span>
        <span class="portal-desc">{t(locale, 'hub.coin.desc')}</span>
        <span class="portal-enter">{t(locale, 'hub.enter')} →</span>
      </a>
    </nav>
  </section>
</Base>

<style>
  .hub {
    display: grid;
    gap: 3rem;
    padding-top: 2rem;
  }
  .hub-lede {
    text-align: center;
    max-width: 40rem;
    margin: 0 auto;
  }
  .hub-lede h1 {
    font-size: clamp(2.8rem, 7vw, 4.2rem);
    margin: 0 0 0.5rem;
  }
  .hub-tagline {
    color: var(--muted);
    font-size: 1.15rem;
    font-style: italic;
    margin: 0;
  }
  .portals {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem;
    max-width: 46rem;
    width: 100%;
    margin: 0 auto;
  }
  .portal {
    display: grid;
    justify-items: center;
    gap: 0.6rem;
    text-align: center;
    text-decoration: none;
    color: var(--text);
    padding: 2.5rem 1.75rem 2rem;
    border: 1px solid var(--line);
    border-radius: 16px;
    background: var(--panel);
    transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
  }
  .portal:hover,
  .portal:focus-visible {
    transform: translateY(-4px);
    border-color: var(--accent);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.45), 0 0 30px rgba(201, 164, 76, 0.15);
  }
  .portal-emblem {
    color: var(--accent);
    width: 5rem;
    height: 5rem;
  }
  .portal-emblem svg {
    width: 100%;
    height: 100%;
  }
  .portal-title {
    font-family: var(--font-display);
    font-size: 2.2rem;
    font-weight: 600;
    line-height: 1;
  }
  .portal-desc {
    color: var(--muted);
    max-width: 16rem;
  }
  .portal-enter {
    margin-top: 0.4rem;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--accent);
  }

  @media (max-width: 40rem) {
    .portals {
      grid-template-columns: 1fr;
    }
  }
</style>
