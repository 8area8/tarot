---
import Base from '../../../layouts/Base.astro';
import Listing, { type ListGroup } from '../../../components/Listing.astro';
import { LOCALES, type Locale, t } from '../../../lib/i18n';

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;

const groups: ListGroup[] = [
  {
    items: [
      { href: `/${locale}/oracles/tarot/`, name: t(locale, 'nav.tarot'), desc: t(locale, 'hub.tarot.desc'), icon: 'tarot' },
      { href: `/${locale}/oracles/coin/`, name: t(locale, 'nav.coin'), desc: t(locale, 'hub.coin.desc'), icon: 'coin' },
    ],
  },
];
---

<Base locale={locale} title={t(locale, 'nav.oracles')}>
  <section class="landing">
    <div class="landing-lede">
      <h1>{t(locale, 'nav.oracles')}</h1>
      <p class="landing-tagline">{t(locale, 'oracles.intro')}</p>
    </div>
    <Listing groups={groups} />
  </section>
</Base>

<style>
  .landing {
    display: grid;
    gap: 2.5rem;
    padding-top: 1.5rem;
  }
  .landing-lede {
    text-align: center;
    max-width: 38rem;
    margin: 0 auto;
  }
  .landing-lede h1 {
    font-size: clamp(2.8rem, 7vw, 4.2rem);
    margin: 0 0 0.5rem;
  }
  .landing-tagline {
    color: var(--muted);
    font-size: 1.15rem;
    font-style: italic;
    margin: 0;
  }
</style>
