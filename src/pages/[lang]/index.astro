  /* ---- Régions interprétatives ----
     Calque SVG dans la face avant (pivote/masqué avec elle) : un polygone par objet
     détouré. Contour discret au repos, doré au survol ; au clic, l'objet reste
     éclairé et le reste de l'image s'assombrit (voile masqué par le polygone). Le JS
     vide le calque quand la carte est inversée (l'art tourne à 180°). */
  .region-layer {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  /* Éléments SVG créés en JS → styles en :global (le scope Astro ne les atteint pas ;
     cf. mémoire « styles scopés vs DOM en JS »). */
  :global(.region-shape) {
    fill: transparent;
    stroke: rgba(201, 164, 76, 0.4);
    stroke-width: 1.5;
    vector-effect: non-scaling-stroke;
    cursor: pointer;
    pointer-events: fill;
    /* Pas d'outline navigateur : c'est un rectangle (bounding-box) autour du
       polygone ; le focus est signalé par le `stroke` (cf. :focus-visible). */
    outline: none;
    transition: stroke 0.18s ease, stroke-width 0.18s ease;
  }
  :global(.region-shape:hover),
  :global(.region-shape.is-active) {
    stroke: #fff;
    stroke-width: 2.5;
  }
  :global(.region-shape.is-focused) {
    stroke: #fff;
    stroke-width: 2.5;
  }
  /* Région focalisée (ou survolée en aperçu) : on masque le contour de TOUTES les
     autres régions — on ne veut voir que l'objet mis en avant, le reste assombri. */
  .region-layer.has-focus :global(.region-shape:not(.is-focused):not(.is-active)) {
    stroke: transparent;
  }
  :global(.region-shape:focus-visible) {
    stroke: #fff;
    stroke-width: 3;
  }
  /* Voile sombre : masqué (opacity 0) tant qu'aucune région n'est focalisée. */
  :global(.region-dim) {
    fill: rgba(10, 7, 13, 0.74);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.28s ease;
  }
  .region-layer.has-focus :global(.region-dim) {
    opacity: 1;
    pointer-events: auto;
  }
  @media (prefers-reduced-motion: reduce) {
    :global(.region-shape),
    :global(.region-dim) {
      transition: none;
    }
  }
  /* Texte de symbolique au repos : volontairement estompé pour que le survol et la
     sélection ressortent nettement (contraste fort entre les trois niveaux). */
  .symbolism .bricks :global(.brick-text) {
    color: rgba(233, 220, 196, 0.55);
  }
  /* Survol / aperçu croisé région ↔ brique : fond ambré + texte quasi plein. */
  .symbolism :global(.brick.is-active) {
    background: rgba(201, 164, 76, 0.08);
  }
  .symbolism :global(.brick.is-active .brick-text) {
    color: rgba(247, 238, 218, 0.98);
  }
  /* Verrouillé (sélection) : encart appuyé — filet d'or, fond plus marqué, halo doux,
     terme éclairci et texte en pleine lumière + légèrement gras. Déclaré après is-active. */
  .symbolism :global(.brick.is-selected) {
    background: rgba(201, 164, 76, 0.15);
    border-left-color: var(--accent);
    box-shadow: 0 0 24px rgba(201, 164, 76, 0.16);
  }
  .symbolism :global(.brick.is-selected .brick-term) {
    color: #e9cd86;
  }
  .symbolism :global(.brick.is-selected .brick-text) {
    color: #fff;
    font-weight: 500;
  }
  /* Brique dont le symbole a une région tracée : cliquable (focalise la carte). */
  .symbolism :global(.brick.is-linked) {
    cursor: pointer;
  }

  /* Respiration du dos de carte à l'état initial : le halo pulse pour inviter au tirage. */
  .flip:not(.is-flipped) .face-back {
    animation: back-breathe 3.4s ease-in-out infinite;
  }
  @keyframes back-breathe {
    0%,
    100% {
      box-shadow: 0 18px 50px rgba(0, 0, 0, 0.55), 0 0 0 1px var(--line),
        0 0 34px rgba(201, 164, 76, 0.16);
    }
    50% {
      box-shadow: 0 18px 50px rgba(0, 0, 0, 0.55), 0 0 0 1px rgba(201, 164, 76, 0.5),
        0 0 62px rgba(201, 164, 76, 0.36);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .flip:not(.is-flipped) .face-back {
      animation: none;
    }
  }

