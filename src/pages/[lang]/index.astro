---
import Base from '../../layouts/Base.astro';
import { LOCALES, type Locale, t } from '../../lib/i18n';
import { MAX_SPREAD_COLS } from '../../data/spread';

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;
const base = import.meta.env.BASE_URL;
---

<Base locale={locale} active="home">
  <section class="draw-app" data-locale={locale}>
    <div class="stage">
    <div class="lede">
      <h1>{t(locale, 'home.heading')}</h1>
    </div>

    <form class="controls" id="controls">
      <button type="submit" class="btn-draw" id="btn-draw">{t(locale, 'action.draw')}</button>

      <div class="options-disclosure">
        <button type="button" class="btn-options" id="btn-options" aria-expanded="false" aria-controls="options-panel">
          <span class="btn-options-gear" aria-hidden="true">тЪЩ</span>{t(locale, 'option.trigger')}
        </button>

        <div class="options" id="options-panel" role="group" aria-label={t(locale, 'option.trigger')} hidden>
          <p class="opt-caption">{t(locale, 'spread.label')}</p>
          <div class="spread-select" role="radiogroup" aria-label={t(locale, 'spread.label')}>
            <label class="seg"><input type="radio" name="spread" value="single" checked /><span>{t(locale, 'spread.single')}</span></label>
            <label class="seg"><input type="radio" name="spread" value="two" /><span>{t(locale, 'spread.two')}</span></label>
            <label class="seg"><input type="radio" name="spread" value="three" /><span>{t(locale, 'spread.three')}</span></label>
            <label class="seg"><input type="radio" name="spread" value="yesno" /><span>{t(locale, 'spread.yesno')}</span></label>
          </div>

          <p class="opt-caption">{t(locale, 'deck.label')}</p>
          <div class="deck-select" role="radiogroup" aria-label={t(locale, 'deck.label')}>
            <label class="seg"><input type="radio" name="deck" value="major" checked /><span>{t(locale, 'deck.major')}</span></label>
            <label class="seg"><input type="radio" name="deck" value="minor" /><span>{t(locale, 'deck.minor')}</span></label>
            <label class="seg"><input type="radio" name="deck" value="full" /><span>{t(locale, 'deck.full')}</span></label>
          </div>

          <label class="switch">
            <input type="checkbox" name="reversed" checked />
            <span class="switch-track"><span class="switch-thumb"></span></span>
            <span class="switch-text">{t(locale, 'option.reversed')}</span>
          </label>
        </div>
      </div>
    </form>

    <div class="result">
      <div class="card-slot">
        <div class="flip" id="flip">
          <div class="face face-back">
            <img src={`${base}cards/back.svg`} alt="" width="300" height="524" />
          </div>
          <div class="face face-front">
            <img id="card-img" alt="" width="300" height="524" />
          </div>
        </div>
      </div>

      <article class="reading" id="reading" aria-live="polite">
        <p class="placeholder" id="placeholder">{t(locale, 'card.placeholder')}</p>

        <div class="reading-body" id="reading-body" hidden>
          <div class="verdict" id="verdict" hidden>
            <p class="verdict-title" id="verdict-title"></p>
            <div class="oracle-scale" id="oracle-scale" aria-hidden="true">
              <span class="oracle-step" data-step="0"></span>
              <span class="oracle-step" data-step="1"></span>
              <span class="oracle-step" data-step="2"></span>
              <span class="oracle-step" data-step="3"></span>
              <span class="oracle-step" data-step="4"></span>
              <span class="oracle-step" data-step="5"></span>
            </div>
            <p class="verdict-answer" id="verdict-answer"></p>
            <p class="verdict-why" id="verdict-why"></p>
          </div>
          <p class="meta" id="card-meta"></p>
          <h2 id="reading-name" tabindex="-1"></h2>
          <p class="orientation" id="orientation"></p>
          <div class="keywords" id="keywords"></div>
          <p class="meaning" id="meaning"></p>
        </div>
      </article>

      <div class="reading-full" id="reading-full" hidden>
        <div class="symbolism" id="symbolism" hidden>
          <p class="study-title">{t(locale, 'study.image')}</p>
          <div class="bricks" id="sym-bricks"></div>
        </div>
        <div class="study" id="study" hidden>
          <p class="study-title">{t(locale, 'study.formula')}</p>
          <p class="study-sub" id="decompose-title"></p>
          <div class="bricks" id="bricks"></div>
        </div>
        <div class="reading-actions">
          <button type="button" class="btn-decode" id="btn-study" aria-pressed="false" aria-controls="study">{t(locale, 'action.study')}</button>
          <button type="button" class="btn-orient" id="btn-orient"></button>
          <button type="button" class="btn-copy" id="btn-copy">{t(locale, 'card.copy')}</button>
        </div>
      </div>
    </div>

    <div class="spread" id="spread" hidden>
      <div class="spread-cols" id="spread-cols">
        {Array.from({ length: MAX_SPREAD_COLS }).map((_, i) => (
          <div class="spread-col" data-pos={i}>
            <p class="spread-pos">
              <span class="spread-pos-label" data-pos-label></span>
              <span class="spread-pos-gloss" data-pos-gloss></span>
            </p>
            <div class="card-slot small">
              <div class="flip" data-flip>
                <div class="face face-back">
                  <img src={`${base}cards/back.svg`} alt="" width="300" height="524" />
                </div>
                <div class="face face-front">
                  <img data-card-img alt="" width="300" height="524" />
                </div>
              </div>
            </div>
            <p class="meta" data-meta></p>
            <h3 class="spread-name" data-name tabindex="-1"></h3>
            <p class="orientation" data-orientation></p>
            <div class="keywords" data-keywords></div>
            <p class="meaning" data-meaning></p>
          </div>
        ))}
      </div>

      <div class="spread-synthesis" id="spread-synthesis" hidden>
        <div class="synth-group" id="dignities-group" hidden>
          <p class="spread-signals-title">{t(locale, 'spread.dignities')}</p>
          <ul class="signals" id="dignities"></ul>
        </div>
        <div class="synth-group" id="signals-group" hidden>
          <p class="spread-signals-title">{t(locale, 'spread.signals')}</p>
          <ul class="signals" id="signals"></ul>
        </div>
        <div class="synth-group" id="quint-group" hidden>
          <p class="spread-signals-title">{t(locale, 'spread.quintessence')}</p>
          <ul class="signals" id="quint"></ul>
        </div>
      </div>

      <div class="spread-actions">
        <button type="button" class="btn-copy" id="btn-copy-spread">{t(locale, 'card.copy')}</button>
      </div>
    </div>
    </div>
  </section>
</Base>

<script>
  import { ui, type Locale } from '../../lib/i18n';
  import { drawCard, drawSpread, type DeckMode, type Draw } from '../../lib/deck';
  import { answerFor } from '../../lib/oracle';
  import { buildSignals } from '../../lib/signals';
  import { buildDignities } from '../../lib/dignities';
  import { quintessence } from '../../lib/quintessence';
  import { SUIT_NAMES, SUIT_ELEMENTS, MAJOR_CORRESPONDENCE, cards } from '../../data/cards';
  import { SYMBOLS } from '../../data/symbols';
  import { ELEMENTS, NUMBERS, COURT, JOURNEY, JOURNEY_INTRO } from '../../data/grammar';
  import { SPREADS, type SpreadType } from '../../data/spread';
  import { pushHistory, type SpreadKind } from '../../lib/history';
  import type { Card, Orientation } from '../../lib/types';

  const app = document.querySelector<HTMLElement>('.draw-app')!;
  const locale = app.dataset.locale as Locale;
  const T = ui[locale];
  // Libell├йs des 6 r├йponses de l'oracle (question ferm├йe), de ┬л Non, etтАж ┬╗ ├а ┬л Oui, etтАж ┬╗.
  const ANSWERS = [
    T['yesno.answer.0'], T['yesno.answer.1'], T['yesno.answer.2'],
    T['yesno.answer.3'], T['yesno.answer.4'], T['yesno.answer.5'],
  ];
  const BASE = import.meta.env.BASE_URL;
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  // Desktop : la symbolique s'affiche d├йpli├йe (voir syncSymbolismDisclosure).
  const wideMq = window.matchMedia('(min-width: 46rem)');
  const FLIP_MS = 430;

  const cardById = new Map(cards.map((c) => [c.id, c]));

  const form = document.querySelector<HTMLFormElement>('#controls')!;
  const btnDraw = document.querySelector<HTMLButtonElement>('#btn-draw')!;
  const flip = document.querySelector<HTMLElement>('#flip')!;
  const cardImg = document.querySelector<HTMLImageElement>('#card-img')!;
  const placeholder = document.querySelector<HTMLElement>('#placeholder')!;
  const body = document.querySelector<HTMLElement>('#reading-body')!;
  const readingFull = document.querySelector<HTMLElement>('#reading-full')!;
  const metaEl = document.querySelector<HTMLElement>('#card-meta')!;
  const nameEl = document.querySelector<HTMLHeadingElement>('#reading-name')!;
  const orientationEl = document.querySelector<HTMLElement>('#orientation')!;
  const keywordsEl = document.querySelector<HTMLElement>('#keywords')!;
  const meaningEl = document.querySelector<HTMLElement>('#meaning')!;
  const btnOrient = document.querySelector<HTMLButtonElement>('#btn-orient')!;
  const btnCopy = document.querySelector<HTMLButtonElement>('#btn-copy')!;
  const verdict = document.querySelector<HTMLElement>('#verdict')!;
  const verdictTitle = document.querySelector<HTMLElement>('#verdict-title')!;
  const verdictAnswer = document.querySelector<HTMLElement>('#verdict-answer')!;
  const verdictWhy = document.querySelector<HTMLElement>('#verdict-why')!;
  const scaleSteps = [...document.querySelectorAll<HTMLElement>('#oracle-scale .oracle-step')];
  const result = document.querySelector<HTMLElement>('.result')!;
  const btnStudy = document.querySelector<HTMLButtonElement>('#btn-study')!;
  const studyEl = document.querySelector<HTMLElement>('#study')!;
  const symbolismEl = document.querySelector<HTMLElement>('#symbolism')!;
  const decomposeTitle = document.querySelector<HTMLElement>('#decompose-title')!;
  const bricksEl = document.querySelector<HTMLElement>('#bricks')!;
  const symBricksEl = document.querySelector<HTMLElement>('#sym-bricks')!;
  const btnOptions = document.querySelector<HTMLButtonElement>('#btn-options')!;
  const optionsPanel = document.querySelector<HTMLElement>('#options-panel')!;
  const spreadEl = document.querySelector<HTMLElement>('#spread')!;
  const spreadCols = document.querySelector<HTMLElement>('#spread-cols')!;
  const synthEl = document.querySelector<HTMLElement>('#spread-synthesis')!;
  const signalsEl = document.querySelector<HTMLElement>('#signals')!;
  const signalsGroup = document.querySelector<HTMLElement>('#signals-group')!;
  const dignitiesEl = document.querySelector<HTMLElement>('#dignities')!;
  const dignitiesGroup = document.querySelector<HTMLElement>('#dignities-group')!;
  const quintEl = document.querySelector<HTMLElement>('#quint')!;
  const quintGroup = document.querySelector<HTMLElement>('#quint-group')!;
  const btnCopySpread = document.querySelector<HTMLButtonElement>('#btn-copy-spread')!;

  const ROMAN = ['', 'I', 'II', 'III', 'IV', 'V', 'VI', 'VII', 'VIII', 'IX', 'X',
    'XI', 'XII', 'XIII', 'XIV', 'XV', 'XVI', 'XVII', 'XVIII', 'XIX', 'XX', 'XXI'];

  // Glyphes ├йsot├йriques. ├Йl├йments (triangles alchimiques) par enseigne ;
  // correspondance des majeurs (plan├иte / signe / ├йl├йment) par num├йro d'arcane.
  const ELEMENT_GLYPH: Record<string, string> = { wands: 'ЁЯЬВ', cups: 'ЁЯЬД', swords: 'ЁЯЬБ', pentacles: 'ЁЯЬГ' };
  const MAJOR_GLYPH: Record<number, string> = {
    0: 'ЁЯЬБ', 1: 'тШ┐', 2: 'тШ╜', 3: 'тЩА', 4: 'тЩИ', 5: 'тЩЙ', 6: 'тЩК', 7: 'тЩЛ', 8: 'тЩМ', 9: 'тЩН', 10: 'тЩГ',
    11: 'тЩО', 12: 'ЁЯЬД', 13: 'тЩП', 14: 'тЩР', 15: 'тЩС', 16: 'тЩВ', 17: 'тЩТ', 18: 'тЩУ', 19: 'тШЙ', 20: 'ЁЯЬВ', 21: 'тЩД',
  };

  // ├Йtat courant pour la bascule d'orientation.
  let current: Card | null = null;
  let view: Orientation = 'upright';
  let study = false; // ┬л La formule ┬╗ : panneau de d├йcomposition repli├й sous la carte
  let askMode = false; // ┬л Question ferm├йe ┬╗ : affiche la jauge d'inclinaison oui/non

  // ├Йtat du tirage multi-cartes.
  let currentSpread: Draw[] | null = null;
  let currentSpreadMode: DeckMode = 'major'; // mode de jeu (pour les signaux des majeurs)
  let currentSpreadType: SpreadType = 'three'; // positions actives (deux / trois)
  let hasDrawn = false; // au moins un tirage effectu├й (fige le libell├й du bouton sur ┬л Nouveau tirage ┬╗)

  const getSpreadMode = (): 'single' | SpreadType | 'yesno' => {
    const v = new FormData(form).get('spread');
    return v === 'two' || v === 'three' || v === 'yesno' ? v : 'single';
  };

  // Avant le 1er tirage, le bouton refl├иte le type de tirage choisi.
  function updateDrawLabel() {
    if (hasDrawn) return;
    const v = getSpreadMode();
    btnDraw.textContent =
      v === 'three' ? T['action.drawThree']
      : v === 'two' ? T['action.drawTwo']
      : v === 'yesno' ? T['action.drawYesno']
      : T['action.draw'];
  }

  // Refl├иte l'├йtat ┬л La formule ┬╗ sur son bouton (libell├й + aria-pressed).
  function syncStudyBtn() {
    btnStudy.textContent = study ? T['action.studyHide'] : T['action.study'];
    btnStudy.setAttribute('aria-pressed', String(study));
    btnStudy.classList.toggle('is-on', study);
  }

  // Une ┬л brique ┬╗ de lecture (symbole, ├йl├йment, nombre, figure ou ├йtape du voyage).
  // `collapsible` тЖТ rendue en <details>/<summary> : sur mobile le texte se replie
  // sous son label (voir CSS) ; sur desktop il reste toujours d├йpli├й.
  function makeBrick(key: string, label: string, gloss: string, text: string, collapsible = false): HTMLElement {
    const wrap = document.createElement(collapsible ? 'details' : 'div');
    wrap.className = 'brick';
    const head = document.createElement(collapsible ? 'summary' : 'p');
    head.className = 'brick-head';
    if (key) {
      const k = document.createElement('span');
      k.className = 'brick-key';
      k.textContent = key;
      head.appendChild(k);
    }
    const l = document.createElement('span');
    l.className = 'brick-term';
    l.textContent = label;
    head.appendChild(l);
    if (gloss) {
      const g = document.createElement('span');
      g.className = 'brick-gloss';
      g.textContent = gloss;
      head.appendChild(g);
    }
    wrap.appendChild(head);
    if (text) {
      const p = document.createElement('p');
      p.className = 'brick-text';
      p.textContent = text;
      wrap.appendChild(p);
    }
    return wrap;
  }

  // ┬л La formule ┬╗ : d├йcompose la carte (├йl├йment ├Ч nombre/figure, ou ├йtape du voyage).
  function fillFormula(card: Card): boolean {
    bricksEl.replaceChildren();
    if (card.arcana === 'minor') {
      const suit = card.suit!;
      const el = ELEMENTS[suit];
      const rank = card.number <= 10 ? NUMBERS[card.number] : COURT[card.number];
      const rankKey = card.number <= 10 ? String(card.number) : '';
      decomposeTitle.textContent = `${el.glyph} ${el.label[locale]} ├Ч ${rank.label[locale]}`;
      bricksEl.appendChild(makeBrick(el.glyph, el.label[locale], el.gloss[locale], el.text[locale]));
      bricksEl.appendChild(makeBrick(rankKey, rank.label[locale], rank.gloss[locale], rank.text[locale]));
      return true;
    }
    if (card.number === 0) {
      decomposeTitle.textContent = T['meta.major'];
      bricksEl.appendChild(makeBrick('0', card.name[locale], '', JOURNEY_INTRO[locale]));
      return true;
    }
    const stage = JOURNEY.find((s) => s.cards.includes(card.number));
    if (stage) {
      decomposeTitle.textContent = `${T['meta.major']} ┬╖ ${stage.range}`;
      bricksEl.appendChild(makeBrick(stage.range, stage.label[locale], '', stage.text[locale]));
      return true;
    }
    return false;
  }

  // ┬л L'image ┬╗ : liste les symboles rep├йrables de l'illustration RWS.
  function fillSymbols(card: Card): boolean {
    const syms = SYMBOLS[card.id];
    if (!syms || !syms.length) return false;
    symBricksEl.replaceChildren();
    for (const s of syms) {
      symBricksEl.appendChild(makeBrick('', s.label[locale], '', s.text[locale], true));
    }
    return true;
  }

  // La symbolique (lecture par ├йl├йment) : affich├йe par d├йfaut sous la carte,
  // sauf en mode oracle (┬л question ferm├йe ┬╗) o├╣ l'on garde le verdict ├йpur├й.
  function updateSymbolism(card: Card | null) {
    if (!card || askMode) {
      symbolismEl.hidden = true;
      return;
    }
    const has = fillSymbols(card);
    symbolismEl.hidden = !has;
    if (has) syncSymbolismDisclosure();
  }

  // Ouvre/replie les briques de symbolique selon la largeur : d├йpli├йes sur desktop
  // (non repliables, cf. CSS), repli├йes sur mobile (tap pour ouvrir). Chrome r├йcent
  // masque le contenu d'un <details> ferm├й via ::details-content тЖТ on pilote `open`.
  function syncSymbolismDisclosure() {
    const open = wideMq.matches;
    symBricksEl.querySelectorAll<HTMLDetailsElement>('details.brick').forEach((d) => {
      d.open = open;
    });
  }
  wideMq.addEventListener('change', syncSymbolismDisclosure);

  // ┬л La formule ┬╗ : d├йcomposition ├йl├йment ├Ч rang (ou ├йtape du voyage),
  // repli├йe derri├иre son bouton.
  function updateFormula(card: Card | null) {
    if (!card || !study) {
      studyEl.hidden = true;
      return;
    }
    studyEl.hidden = !fillFormula(card);
  }

  // Renseigne une ligne meta (┬л coordonn├йes ├йsot├йriques ┬╗) avec un glyphe styl├й.
  function fillMeta(target: HTMLElement, card: Card) {
    target.replaceChildren();
    const push = (text: string) => target.append(document.createTextNode(text));
    const pushGlyph = (g: string) => {
      const span = document.createElement('span');
      span.className = 'glyph';
      span.textContent = g;
      target.appendChild(span);
    };
    if (card.arcana === 'major') {
      const num = card.number > 0 ? ROMAN[card.number] : '0';
      const corr = MAJOR_CORRESPONDENCE[card.number]?.[locale];
      push(`${T['meta.major']} ┬╖ ${num}`);
      if (corr) {
        push(' ┬╖ ');
        pushGlyph(MAJOR_GLYPH[card.number]);
        push(` ${corr}`);
      }
    } else {
      const suit = card.suit!;
      push(`${T['meta.minor']} ┬╖ ${SUIT_NAMES[suit][locale]} ┬╖ `);
      pushGlyph(ELEMENT_GLYPH[suit]);
      push(` ${SUIT_ELEMENTS[suit][locale]}`);
    }
  }

  // Remplit une zone de mots-cl├йs (chips) pour l'orientation donn├йe.
  function fillKeywords(target: HTMLElement, card: Card, orientation: Orientation) {
    target.replaceChildren();
    if (!card.content) return;
    for (const word of card.content.keywords[orientation][locale]) {
      const chip = document.createElement('span');
      chip.className = 'chip';
      chip.textContent = word;
      target.appendChild(chip);
    }
  }

  // Rejoue le fondu ├йchelonn├й de la lecture (canalisation du message).
  function playStagger() {
    if (reduceMotion) return;
    body.classList.remove('is-revealing');
    void body.offsetWidth;
    body.classList.add('is-revealing');
  }

  // Refl├иte la carte + orientation dans l'URL (permalien partageable / bookmarkable).
  function syncHash(card: Card, orientation: Orientation) {
    const rev = orientation === 'reversed' ? '-reversed' : '';
    // Le mode ┬л question ferm├йe ┬╗ se distingue par le pr├йfixe ask= (restaure la jauge).
    const hash = askMode ? `#ask=${card.id}${rev}` : `#${card.id}${rev}`;
    history.replaceState(null, '', hash);
  }

  // Titre de la section oracle : fixe, pos├й une fois pour toutes.
  verdictTitle.textContent = T['yesno.title'];

  // Oracle ┬л question ferm├йe ┬╗ : allume la case r├йpondue sur l'├йchelle ├а 6 crans,
  // affiche le libell├й (Non, etтАж тЖТ Oui, etтАж) et le ┬л pourquoi ┬╗ r├йdig├й.
  function renderVerdict(card: Card, orientation: Orientation) {
    const entry = answerFor({ card, orientation });
    const ans = entry ? entry.answer : 3;
    scaleSteps.forEach((s, i) => s.classList.toggle('is-active', i === ans));
    verdictAnswer.textContent = ANSWERS[ans];
    verdictAnswer.dataset.tone = ans <= 2 ? 'no' : 'yes';
    verdictWhy.textContent = entry ? entry.why[locale] : '';
  }

  function renderReading(card: Card, orientation: Orientation) {
    const reversed = orientation === 'reversed';
    cardImg.src = `${BASE}cards/${card.image}`;
    cardImg.alt = card.name[locale];
    cardImg.classList.toggle('is-reversed', reversed);

    fillMeta(metaEl, card);
    nameEl.textContent = card.name[locale];
    orientationEl.textContent = reversed ? T['card.reversed'] : T['card.upright'];
    orientationEl.classList.toggle('is-reversed', reversed);

    fillKeywords(keywordsEl, card, orientation);
    if (card.content) {
      const key = reversed ? 'reversed' : 'upright';
      meaningEl.textContent = card.content.meaning[key][locale];
      btnOrient.hidden = false;
      btnOrient.textContent = reversed ? T['card.seeUpright'] : T['card.seeReversed'];
    } else {
      meaningEl.textContent = T['card.noContent'];
      btnOrient.hidden = true;
    }
    // En mode oracle, le ┬л pourquoi ┬╗ remplace le texte d'ambiance.
    meaningEl.hidden = askMode;

    updateSymbolism(card);
    updateFormula(card);

    verdict.hidden = !askMode;
    if (askMode) renderVerdict(card, orientation);

    placeholder.hidden = true;
    body.hidden = false;
    readingFull.hidden = false;
    syncHash(card, orientation);
    playStagger();
  }

  function preload(src: string): Promise<void> {
    return new Promise((resolve) => {
      const img = new Image();
      img.onload = () => resolve();
      img.onerror = () => resolve();
      img.src = src;
    });
  }

  // Consigne le tirage dans l'historique local (relu par la page ┬л Historique ┬╗).
  // Uniquement sur un vrai tirage : ni la bascule d'orientation, ni une restauration.
  function recordDraw(kind: SpreadKind, draws: Draw[]) {
    pushHistory({
      at: Date.now(),
      kind,
      cards: draws.map((d) => ({ id: d.card.id, reversed: d.orientation === 'reversed' })),
    });
  }

  // Marque la fin d'un tirage : bouton r├йactiv├й, libell├й fig├й sur ┬л Nouveau tirage ┬╗.
  function finishDraw() {
    btnDraw.disabled = false;
    btnDraw.classList.remove('is-loading');
    btnDraw.textContent = T['action.again'];
    hasDrawn = true;
  }

  async function doSingle(mode: DeckMode, allowReversed: boolean) {
    const draw = drawCard(mode, allowReversed);
    current = draw.card;
    view = draw.orientation;
    recordDraw(askMode ? 'yesno' : 'single', [draw]);

    btnDraw.disabled = true;
    btnDraw.classList.add('is-loading');
    await preload(`${BASE}cards/${draw.card.image}`);

    const reveal = () => {
      spreadEl.hidden = true;
      result.hidden = false;
      renderReading(draw.card, draw.orientation);
      finishDraw();
      nameEl.focus();
    };

    const wasFlipped = flip.classList.contains('is-flipped');
    if (reduceMotion) {
      reveal();
      flip.classList.add('is-flipped');
    } else if (wasFlipped) {
      // Retourne face cach├йe, ├йchange en coulisse, puis re-r├йv├иle.
      flip.classList.remove('is-flipped');
      window.setTimeout(() => {
        reveal();
        flip.classList.add('is-flipped');
      }, FLIP_MS);
    } else {
      reveal();
      requestAnimationFrame(() => flip.classList.add('is-flipped'));
    }
  }

  // Remplit une colonne du spread (position + carte + lecture) pour un tirage donn├й.
  function fillSpreadColumn(col: HTMLElement, draw: Draw, position: (typeof SPREADS)[SpreadType][number]) {
    const { card, orientation } = draw;
    const reversed = orientation === 'reversed';
    col.querySelector<HTMLElement>('[data-pos-label]')!.textContent = position.label[locale];
    col.querySelector<HTMLElement>('[data-pos-gloss]')!.textContent = position.gloss[locale];
    const img = col.querySelector<HTMLImageElement>('[data-card-img]')!;
    img.src = `${BASE}cards/${card.image}`;
    img.alt = card.name[locale];
    img.classList.toggle('is-reversed', reversed);

    fillMeta(col.querySelector<HTMLElement>('[data-meta]')!, card);
    col.querySelector<HTMLElement>('[data-name]')!.textContent = card.name[locale];
    const or = col.querySelector<HTMLElement>('[data-orientation]')!;
    or.textContent = reversed ? T['card.reversed'] : T['card.upright'];
    or.classList.toggle('is-reversed', reversed);
    fillKeywords(col.querySelector<HTMLElement>('[data-keywords]')!, card, orientation);
    col.querySelector<HTMLElement>('[data-meaning]')!.textContent = card.content
      ? card.content.meaning[orientation][locale]
      : T['card.noContent'];
  }

  function fillList(el: HTMLElement, items: string[]) {
    el.replaceChildren();
    for (const s of items) {
      const li = document.createElement('li');
      li.textContent = s;
      el.appendChild(li);
    }
  }

  // Nom + chiffre romain d'un arcane majeur (pour la quintessence).
  function majorRoman(n: number): string {
    return n > 0 ? ROMAN[n] : '0';
  }

  // Synth├иse du spread : dignit├йs (relationnel) + signaux (additif) + quintessence (th├иme).
  function renderSynthesis(draws: Draw[], mode: DeckMode, type: SpreadType) {
    const positions = SPREADS[type];
    const digs = buildDignities(draws, positions, locale);
    const sigs = buildSignals(draws, mode, positions, locale);
    const q = quintessence(draws);
    const quintItems = q ? [`${q.name[locale]} ┬╖ ${majorRoman(q.number)}`] : [];
    fillList(dignitiesEl, digs);
    dignitiesGroup.hidden = digs.length === 0;
    fillList(signalsEl, sigs);
    signalsGroup.hidden = sigs.length === 0;
    fillList(quintEl, quintItems);
    quintGroup.hidden = quintItems.length === 0;
    synthEl.hidden = digs.length === 0 && sigs.length === 0 && quintItems.length === 0;
  }

  // Refl├иte le spread dans l'URL : #spread=<id>[.r],<id>[.r],<id>[.r]
  function syncHashSpread(draws: Draw[]) {
    const parts = draws.map((d) => d.card.id + (d.orientation === 'reversed' ? '.r' : ''));
    history.replaceState(null, '', `#spread=${parts.join(',')}`);
  }

  // Peuple et r├йv├иle le spread (avec ou sans animation selon les pr├йf├йrences).
  // Ne montre que les colonnes utiles (2 ou 3) ; masque le surplus.
  function paintSpread(draws: Draw[], mode: DeckMode, type: SpreadType, animate: boolean) {
    currentSpread = draws;
    currentSpreadMode = mode;
    currentSpreadType = type;
    const positions = SPREADS[type];
    const cols = [...spreadCols.querySelectorAll<HTMLElement>('.spread-col')];
    spreadCols.dataset.count = String(draws.length);
    cols.forEach((col, i) => {
      const f = col.querySelector<HTMLElement>('[data-flip]')!;
      if (i >= draws.length) {
        col.hidden = true;
        f.classList.remove('is-flipped');
        return;
      }
      col.hidden = false;
      fillSpreadColumn(col, draws[i], positions[i]);
    });
    renderSynthesis(draws, mode, type);
    result.hidden = true;
    spreadEl.hidden = false;
    cols.slice(0, draws.length).forEach((col, i) => {
      const f = col.querySelector<HTMLElement>('[data-flip]')!;
      if (!animate || reduceMotion) {
        f.classList.add('no-anim');
        f.classList.add('is-flipped');
        void f.offsetWidth;
        f.classList.remove('no-anim');
      } else {
        window.setTimeout(() => f.classList.add('is-flipped'), i * 120);
      }
    });
    syncHashSpread(draws);
  }

  async function doSpread(mode: DeckMode, allowReversed: boolean, type: SpreadType) {
    const count = SPREADS[type].length;
    const draws = drawSpread(mode, allowReversed, count);
    recordDraw(type, draws);

    btnDraw.disabled = true;
    btnDraw.classList.add('is-loading');
    await Promise.all(draws.map((d) => preload(`${BASE}cards/${d.card.image}`)));

    const cols = [...spreadCols.querySelectorAll<HTMLElement>('.spread-col')];
    const wasFlipped = cols.some((c) => c.querySelector('[data-flip]')!.classList.contains('is-flipped'));

    const reveal = () => {
      paintSpread(draws, mode, type, true);
      finishDraw();
      cols[0]?.querySelector<HTMLElement>('[data-name]')?.focus({ preventScroll: true });
    };

    if (!reduceMotion && wasFlipped) {
      cols.forEach((c) => c.querySelector('[data-flip]')!.classList.remove('is-flipped'));
      window.setTimeout(reveal, FLIP_MS);
    } else {
      reveal();
    }
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const mode = (data.get('deck') as DeckMode) ?? 'major';
    const allowReversed = data.get('reversed') === 'on';
    const spread = data.get('spread');
    if (spread === 'two' || spread === 'three') {
      askMode = false;
      await doSpread(mode, allowReversed, spread);
    } else {
      askMode = spread === 'yesno';
      await doSingle(mode, allowReversed);
    }
  });

  // Explorer l'autre orientation sans retirer une carte.
  btnOrient.addEventListener('click', () => {
    if (!current) return;
    view = view === 'upright' ? 'reversed' : 'upright';
    renderReading(current, view);
  });

  // Afficher / masquer ┬л La formule ┬╗ (d├йcomposition) sous la carte.
  btnStudy.addEventListener('click', () => {
    study = !study;
    try {
      localStorage.setItem(PREF_STUDY, study ? '1' : '0');
    } catch {
      /* stockage indisponible */
    }
    syncStudyBtn();
    updateFormula(current);
  });

  // Popover d'options : r├йv├йl├й ├а la demande pour garder le hero ├йpur├й.
  // Les r├йglages ├йtant persist├йs, la plupart des sessions ne l'ouvrent jamais.
  function setOptionsOpen(open: boolean) {
    optionsPanel.toggleAttribute('hidden', !open);
    btnOptions.setAttribute('aria-expanded', String(open));
    btnOptions.classList.toggle('is-on', open);
  }

  btnOptions.addEventListener('click', () => {
    setOptionsOpen(optionsPanel.hasAttribute('hidden'));
  });
  // Active les transitions apr├иs le 1er rendu (voir .btn-options.ready) pour
  // ├йviter le flash au chargement.
  requestAnimationFrame(() => btnOptions.classList.add('ready'));

  // Fermer au clic ext├йrieur.
  document.addEventListener('click', (e) => {
    if (optionsPanel.hasAttribute('hidden')) return;
    const target = e.target as Node;
    if (!optionsPanel.contains(target) && !btnOptions.contains(target)) {
      setOptionsOpen(false);
    }
  });

  // Fermer ├а ├Йchap (et rendre le focus au d├йclencheur).
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !optionsPanel.hasAttribute('hidden')) {
      setOptionsOpen(false);
      btnOptions.focus();
    }
  });

  // Entr├йe = nouvelle pioche (sauf si le focus est sur un contr├┤le qui g├иre lui-m├кme Entr├йe).
  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Enter' || e.repeat) return;
    const el = e.target as HTMLElement | null;
    if (el && ['INPUT', 'BUTTON', 'A', 'TEXTAREA', 'SELECT'].includes(el.tagName)) return;
    e.preventDefault();
    form.requestSubmit();
  });

  // Copier la lecture (pour le journal de partie).
  btnCopy.addEventListener('click', async () => {
    if (!current) return;
    const key = view === 'reversed' ? 'reversed' : 'upright';
    const orient = view === 'reversed' ? T['card.reversed'] : T['card.upright'];
    const meaning = current.content ? current.content.meaning[key][locale] : T['card.noContent'];
    let text = `${current.name[locale]} тАФ ${orient}\n${metaEl.textContent}\n\n${meaning}`;
    if (askMode) {
      const entry = answerFor({ card: current, orientation: view });
      const ans = entry ? ANSWERS[entry.answer] : '';
      const why = entry ? entry.why[locale] : '';
      text = `${current.name[locale]} тАФ ${orient}\n${metaEl.textContent}\n\n${T['yesno.title']} : ${ans}\n${why}`;
    }
    try {
      await navigator.clipboard.writeText(text);
      btnCopy.textContent = T['card.copied'];
      btnCopy.classList.add('is-copied');
      window.setTimeout(() => {
        btnCopy.textContent = T['card.copy'];
        btnCopy.classList.remove('is-copied');
      }, 1600);
    } catch {
      /* presse-papiers indisponible (contexte non s├йcuris├й) */
    }
  });

  // Copier le spread entier (positions + significations + signaux) pour le journal.
  btnCopySpread.addEventListener('click', async () => {
    if (!currentSpread) return;
    const positions = SPREADS[currentSpreadType];
    const blocks = currentSpread.map((d, i) => {
      const pos = positions[i];
      const orient = d.orientation === 'reversed' ? T['card.reversed'] : T['card.upright'];
      const meaning = d.card.content
        ? d.card.content.meaning[d.orientation][locale]
        : T['card.noContent'];
      return `${pos.label[locale]} тАФ ${d.card.name[locale]} (${orient})\n${meaning}`;
    });
    let text = blocks.join('\n\n');
    const dignities = buildDignities(currentSpread, positions, locale);
    if (dignities.length) {
      text += `\n\n${T['spread.dignities']} :\n` + dignities.map((s) => `- ${s}`).join('\n');
    }
    const signals = buildSignals(currentSpread, currentSpreadMode, positions, locale);
    if (signals.length) {
      text += `\n\n${T['spread.signals']} :\n` + signals.map((s) => `- ${s}`).join('\n');
    }
    const q = quintessence(currentSpread);
    if (q) {
      text += `\n\n${T['spread.quintessence']} : ${q.name[locale]} ┬╖ ${majorRoman(q.number)}`;
    }
    try {
      await navigator.clipboard.writeText(text);
      btnCopySpread.textContent = T['card.copied'];
      btnCopySpread.classList.add('is-copied');
      window.setTimeout(() => {
        btnCopySpread.textContent = T['card.copy'];
        btnCopySpread.classList.remove('is-copied');
      }, 1600);
    } catch {
      /* presse-papiers indisponible (contexte non s├йcuris├й) */
    }
  });

  // M├йmoriser les pr├йf├йrences (mode de jeu + invers├йes + apprentissage + tirage) entre les visites.
  const PREF_DECK = 'tarot.deck';
  const PREF_REVERSED = 'tarot.reversed';
  const PREF_STUDY = 'tarot.study';
  const PREF_SPREAD = 'tarot.spread';
  form.addEventListener('change', () => {
    try {
      const data = new FormData(form);
      localStorage.setItem(PREF_DECK, String(data.get('deck') ?? 'major'));
      localStorage.setItem(PREF_REVERSED, data.get('reversed') === 'on' ? '1' : '0');
      localStorage.setItem(PREF_SPREAD, getSpreadMode());
    } catch {
      /* stockage indisponible */
    }
    updateDrawLabel();
  });
  (function restorePrefs() {
    try {
      const deck = localStorage.getItem(PREF_DECK);
      if (deck) {
        const radio = form.querySelector<HTMLInputElement>(`input[name="deck"][value="${deck}"]`);
        if (radio) radio.checked = true;
      }
      const rev = localStorage.getItem(PREF_REVERSED);
      if (rev !== null) {
        const check = form.querySelector<HTMLInputElement>('input[name="reversed"]');
        if (check) check.checked = rev === '1';
      }
      const spread = localStorage.getItem(PREF_SPREAD);
      if (spread) {
        const radio = form.querySelector<HTMLInputElement>(`input[name="spread"][value="${spread}"]`);
        if (radio) radio.checked = true;
      }
      study = localStorage.getItem(PREF_STUDY) === '1';
    } catch {
      /* stockage indisponible */
    }
    syncStudyBtn();
    updateDrawLabel();
  })();

  // Permalien : afficher la carte encod├йe dans l'URL au chargement (#id ou #id-reversed).
  // Devine le mode de jeu d'un spread partag├й (le permalien ne l'encode pas) :
  // sert uniquement ├а ajuster les signaux (majeurs triviaux si tout est majeur).
  function inferMode(draws: Draw[]): DeckMode {
    if (draws.every((d) => d.card.arcana === 'major')) return 'major';
    if (draws.every((d) => d.card.arcana === 'minor')) return 'minor';
    return 'full';
  }

  (function initFromHash() {
    const raw = decodeURIComponent(location.hash.replace(/^#/, ''));
    if (!raw) return;

    if (raw.startsWith('spread=')) {
      const parts = raw.slice('spread='.length).split(',').filter(Boolean);
      const draws: Draw[] = [];
      for (const part of parts) {
        const rev = part.endsWith('.r');
        const card = cardById.get(rev ? part.slice(0, -2) : part);
        if (!card) return;
        draws.push({ card, orientation: rev ? 'reversed' : 'upright' });
      }
      // Le nombre de cartes d├йtermine le type de tirage.
      const type: SpreadType | null = draws.length === 2 ? 'two' : draws.length === 3 ? 'three' : null;
      if (!type) return;
      const radio = form.querySelector<HTMLInputElement>(`input[name="spread"][value="${type}"]`);
      if (radio) radio.checked = true;
      paintSpread(draws, inferMode(draws), type, false);
      hasDrawn = true;
      btnDraw.textContent = T['action.again'];
      return;
    }

    // Question ferm├йe partag├йe : #ask=<id>[-reversed] тЖТ restaure la jauge.
    const asked = raw.startsWith('ask=');
    let body = asked ? raw.slice('ask='.length) : raw;

    let orientation: Orientation = 'upright';
    if (body.endsWith('-reversed')) {
      body = body.slice(0, -'-reversed'.length);
      orientation = 'reversed';
    }
    const card = cardById.get(body);
    if (!card) return;
    if (asked) {
      askMode = true;
      const radio = form.querySelector<HTMLInputElement>('input[name="spread"][value="yesno"]');
      if (radio) radio.checked = true;
    }
    current = card;
    view = orientation;
    flip.classList.add('no-anim');
    renderReading(card, orientation);
    flip.classList.add('is-flipped');
    void flip.offsetWidth;
    flip.classList.remove('no-anim');
    btnDraw.textContent = T['action.again'];
  })();
</script>

<style>
  .draw-app {
    display: grid;
    gap: 3rem;
  }
  /* ├Йcran de tirage : occupe la hauteur visible (rituel immersif) sans jamais
     tronquer тАФ min-height, donc s'├йtend si la lecture s'allonge. Le contenu
     annexe (galerie, grammaire) coule naturellement en dessous. */
  .stage {
    min-height: calc(100vh - 6rem);
    min-height: calc(100svh - 6rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 2.25rem;
  }
  .lede {
    text-align: center;
    max-width: 34rem;
    margin: 0 auto;
  }
  .lede h1 {
    font-size: clamp(2.6rem, 6vw, 3.8rem);
    margin: 0;
  }

  /* ---- Contr├┤les ---- */
  /* Le CTA dor├й domine la hi├йrarchie ; les r├йglages sont repli├йs derri├иre un
     d├йclencheur discret (popover), pour garder le hero centr├й sur le rituel. */
  .controls {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.1rem;
  }

  /* D├йclencheur discret + panneau flottant ancr├й dessous. */
  .options-disclosure {
    position: relative;
    display: flex;
    justify-content: center;
  }
  .btn-options {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-body);
    font-size: 0.76rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    padding: 0.4rem 0.9rem;
    background: transparent;
    color: var(--muted);
    border: 1px solid transparent;
    border-radius: 999px;
    cursor: pointer;
  }
  /* Transitions activ├йes seulement apr├иs le 1er rendu (classe pos├йe en JS) :
     ├йvite le flash ┬л comme un appui ┬╗ au chargement (fond/bordure transparents
     qui s'estompent depuis le style par d├йfaut du navigateur). */
  .btn-options.ready {
    transition: color 0.2s ease, border-color 0.2s ease, background-color 0.2s ease;
  }
  .btn-options:hover {
    color: var(--text);
    border-color: var(--line);
  }
  .btn-options.is-on {
    color: var(--text);
    border-color: var(--line);
    background: var(--panel);
  }
  .btn-options:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .btn-options-gear {
    font-size: 1.05em;
  }

  /* Panneau : flotte sous le d├йclencheur, centr├й, au-dessus du contenu. */
  .options {
    position: absolute;
    top: calc(100% + 0.6rem);
    left: 50%;
    transform: translateX(-50%);
    z-index: 20;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    width: min(20rem, 90vw);
    padding: 1rem 1.1rem;
    border: 1px solid var(--line);
    border-radius: 14px;
    /* Popover flottant : fond opaque obligatoire (le token --panel est quasi
       transparent et deviendrait illisible par-dessus l'illustration de la carte).
       On empile la teinte --panel sur --ground opaque тЖТ m├кme rendu que les
       encadr├йs inline, sans le violet satur├й de --ground-2. */
    background: linear-gradient(var(--panel), var(--panel)), var(--ground);
    box-shadow: 0 18px 44px rgba(0, 0, 0, 0.55), 0 0 0 1px var(--line);
    animation: options-in 0.22s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .options[hidden] {
    display: none;
  }
  @keyframes options-in {
    from {
      opacity: 0;
      transform: translate(-50%, -6px);
    }
    to {
      opacity: 1;
      transform: translate(-50%, 0);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .options {
      animation: none;
    }
  }
  .opt-caption {
    margin: 0 0 -0.35rem;
    font-size: 0.66rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--muted);
  }
  .spread-select {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.25rem;
  }
  .deck-select {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.25rem;
  }
  .seg {
    cursor: pointer;
  }
  .seg input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  .seg span {
    display: block;
    padding: 0.45rem 0.4rem;
    border-radius: 9px;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    text-align: center;
    transition: color 0.2s ease, background-color 0.2s ease;
  }
  .seg:hover span {
    color: var(--text);
  }
  .seg input:checked + span {
    color: var(--text);
    background: rgba(201, 164, 76, 0.16);
  }
  .seg input:focus-visible + span {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .switch {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    cursor: pointer;
    font-size: 0.95rem;
    color: var(--muted);
  }
  .switch input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  .switch-track {
    width: 2.5rem;
    height: 1.4rem;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: var(--panel);
    position: relative;
    transition: background-color 0.2s ease, border-color 0.2s ease;
    flex: none;
  }
  .switch-thumb {
    position: absolute;
    top: 50%;
    left: 0.2rem;
    width: 1rem;
    height: 1rem;
    border-radius: 50%;
    background: var(--muted);
    transform: translateY(-50%);
    transition: transform 0.2s ease, background-color 0.2s ease;
  }
  .switch input:checked + .switch-track {
    background: rgba(201, 164, 76, 0.25);
    border-color: var(--accent);
  }
  .switch input:checked + .switch-track .switch-thumb {
    transform: translate(1.1rem, -50%);
    background: var(--accent);
  }
  .switch input:checked ~ .switch-text {
    color: var(--text);
  }
  .switch input:focus-visible + .switch-track {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .btn-draw {
    font-family: var(--font-body);
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    padding: 0.7rem 1.8rem;
    border: 1px solid var(--accent);
    border-radius: 999px;
    background: var(--accent);
    color: var(--ground);
    cursor: pointer;
    transition: background-color 0.2s ease, box-shadow 0.2s ease;
  }
  .btn-draw:hover:not(:disabled) {
    background: #d9b45c;
    box-shadow: 0 0 24px rgba(201, 164, 76, 0.35);
  }
  .btn-draw:disabled {
    opacity: 0.6;
