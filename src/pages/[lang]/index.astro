  }
  .btn-options-gear {
    font-size: 1.05em;
  }

  /* Panneau : flotte sous le déclencheur, centré, au-dessus du contenu. */
  .options {
    position: absolute;
    top: calc(100% + 0.6rem);
    left: 50%;
    transform: translateX(-50%);
    z-index: 20;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    width: min(20rem, 90vw);
    padding: 1rem 1.1rem;
    border: 1px solid var(--line);
    border-radius: 14px;
    /* Popover flottant : fond opaque obligatoire (le token --panel est quasi
       transparent et deviendrait illisible par-dessus l'illustration de la carte).
       On empile la teinte --panel sur --ground opaque → même rendu que les
       encadrés inline, sans le violet saturé de --ground-2. */
    background: linear-gradient(var(--panel), var(--panel)), var(--ground);
    box-shadow: 0 18px 44px rgba(0, 0, 0, 0.55), 0 0 0 1px var(--line);
    animation: options-in 0.22s cubic-bezier(0.2, 0.7, 0.2, 1);
