  }

  /* ---- Contrôles ---- */
  /* Le CTA doré domine la hiérarchie ; les réglages sont repliés derrière un
     déclencheur discret (popover), pour garder le hero centré sur le rituel. */
  .controls {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.1rem;
  }

  /* Déclencheur discret + panneau flottant ancré dessous. */
  .options-disclosure {
    position: relative;
    display: flex;
    justify-content: center;
  }
  .btn-options {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-body);
    font-size: 0.76rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    padding: 0.4rem 0.9rem;
    background: transparent;
    color: var(--muted);
    border: 1px solid transparent;
    border-radius: 999px;
    cursor: pointer;
  }
  /* Transitions activées seulement après le 1er rendu (classe posée en JS) :
     évite le flash « comme un appui » au chargement (fond/bordure transparents
     qui s'estompent depuis le style par défaut du navigateur). */
  .btn-options.ready {
    transition: color 0.2s ease, border-color 0.2s ease, background-color 0.2s ease;
  }
  .btn-options:hover {
    color: var(--text);
    border-color: var(--line);
