    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .btn-daily:hover {
    color: var(--text);
    border-color: var(--line);
  }
  .btn-daily:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  /* Chargement (préchargement de l'illustration) : un reflet doré balaie le bouton. */
  .btn-draw.is-loading {
    position: relative;
    overflow: hidden;
  }
  .btn-draw.is-loading::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      100deg,
