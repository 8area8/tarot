---
import Base from '../../layouts/Base.astro';
import Listing, { type ListGroup } from '../../components/Listing.astro';
import { LOCALES, type Locale, t } from '../../lib/i18n';

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;

const groups: ListGroup[] = [
  {
    title: t(locale, 'nav.personnage'),
    items: [
      { href: `/${locale}/personnage/`, name: t(locale, 'profil.heading'), desc: t(locale, 'hub.profil.desc'), icon: 'profil' },
    ],
  },
  {
    title: t(locale, 'nav.agir'),
    items: [
      { href: `/${locale}/agir/action/`, name: t(locale, 'agir.heading'), desc: t(locale, 'agir.action.desc'), icon: 'action' },
      { href: `/${locale}/agir/confrontation/`, name: t(locale, 'confront.heading'), desc: t(locale, 'agir.confront.desc'), icon: 'confrontation' },
    ],
  },
  {
    title: t(locale, 'nav.oracles'),
    items: [
      { href: `/${locale}/oracles/tarot/`, name: t(locale, 'nav.tarot'), desc: t(locale, 'hub.tarot.desc'), icon: 'tarot' },
      { href: `/${locale}/oracles/coin/`, name: t(locale, 'nav.coin'), desc: t(locale, 'hub.coin.desc'), icon: 'coin' },
    ],
  },
];
---

<Base locale={locale}>
  <section class="hub">
    <div class="hub-lede">
      <h1>{t(locale, 'site.title')}</h1>
      <p class="hub-tagline">{t(locale, 'site.tagline')}</p>
    </div>
    <Listing groups={groups} />
  </section>
</Base>

<style>
  .hub {
    display: grid;
    gap: 2.75rem;
    padding-top: 1.5rem;
  }
  .hub-lede {
    text-align: center;
    max-width: 40rem;
    margin: 0 auto;
  }
  .hub-lede h1 {
    font-size: clamp(3rem, 8vw, 5rem);
    margin: 0 0 0.5rem;
  }
  .hub-tagline {
    color: var(--muted);
    font-size: 1.2rem;
    font-style: italic;
    margin: 0;
  }
</style>
