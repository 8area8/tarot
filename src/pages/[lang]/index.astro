  }
  .btn-draw:hover:not(:disabled) {
    background: #d9b45c;
    box-shadow: 0 0 24px rgba(201, 164, 76, 0.35);
  }
  .btn-draw:disabled {
    opacity: 0.6;
    cursor: default;
  }
  /* Entrée secondaire, discrète : la carte du jour (déterministe). */
  .btn-daily {
    font-family: var(--font-body);
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    padding: 0.4rem 1rem;
    background: transparent;
    color: var(--muted);
    border: 1px solid transparent;
    border-radius: 999px;
