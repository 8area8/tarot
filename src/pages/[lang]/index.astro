---
import Base from '../../layouts/Base.astro';
import { LOCALES, type Locale, t } from '../../lib/i18n';
import { cards, SUIT_NAMES, SUIT_ELEMENTS } from '../../data/cards';
import type { Suit } from '../../lib/types';

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;
const base = import.meta.env.BASE_URL;

// Galerie : groupes ordonnés (majeurs, puis les 4 enseignes).
const SUIT_ORDER: Suit[] = ['wands', 'cups', 'swords', 'pentacles'];
const galleryGroups = [
  { heading: t(locale, 'gallery.majors'), cards: cards.filter((c) => c.arcana === 'major') },
  ...SUIT_ORDER.map((suit) => ({
    heading: `${SUIT_NAMES[suit][locale]} · ${SUIT_ELEMENTS[suit][locale]}`,
    cards: cards.filter((c) => c.suit === suit),
  })),
];
---

<Base locale={locale}>
  <section class="draw-app" data-locale={locale}>
    <div class="lede">
      <h1>{t(locale, 'home.heading')}</h1>
      <p class="intro">{t(locale, 'home.intro')}</p>
    </div>

    <form class="controls" id="controls">
      <div class="deck-select" role="radiogroup" aria-label={t(locale, 'deck.label')}>
        <label class="seg"><input type="radio" name="deck" value="major" checked /><span>{t(locale, 'deck.major')}</span></label>
        <label class="seg"><input type="radio" name="deck" value="minor" /><span>{t(locale, 'deck.minor')}</span></label>
        <label class="seg"><input type="radio" name="deck" value="full" /><span>{t(locale, 'deck.full')}</span></label>
      </div>

      <label class="switch">
        <input type="checkbox" name="reversed" checked />
        <span class="switch-track"><span class="switch-thumb"></span></span>
        <span class="switch-text">{t(locale, 'option.reversed')}</span>
      </label>

      <button type="submit" class="btn-draw" id="btn-draw">{t(locale, 'action.draw')}</button>
    </form>

    <p class="hint">{t(locale, 'action.hint')}</p>

    <div class="result">
      <div class="card-slot">
        <div class="flip" id="flip">
          <div class="face face-back">
            <img src={`${base}cards/back.svg`} alt="" width="300" height="524" />
          </div>
          <div class="face face-front">
            <img id="card-img" alt="" width="300" height="524" />
          </div>
        </div>
      </div>

      <article class="reading" id="reading" aria-live="polite">
        <p class="placeholder" id="placeholder">{t(locale, 'card.placeholder')}</p>

        <div class="reading-body" id="reading-body" hidden>
          <p class="meta" id="card-meta"></p>
          <h2 id="reading-name" tabindex="-1"></h2>
          <p class="orientation" id="orientation"></p>
          <div class="keywords" id="keywords"></div>
          <p class="meaning" id="meaning"></p>
          <button type="button" class="btn-orient" id="btn-orient"></button>
        </div>
      </article>
    </div>

    <div class="gallery-toggle">
      <button type="button" class="btn-gallery" id="btn-gallery" aria-expanded="false" aria-controls="gallery">
        {t(locale, 'gallery.show')}
      </button>
    </div>

    <section class="gallery" id="gallery" aria-label={t(locale, 'gallery.heading')} hidden>
      {galleryGroups.map((group) => (
        <div class="gallery-group">
          <h3>{group.heading}</h3>
          <div class="gallery-grid">
            {group.cards.map((card) => (
              <button type="button" class="gallery-card" data-card-id={card.id} title={card.name[locale]}>
                <img src={`${base}cards/${card.image}`} alt={card.name[locale]} width="110" height="192" loading="lazy" />
              </button>
            ))}
          </div>
        </div>
      ))}
    </section>
  </section>
</Base>

<script>
  import { ui, type Locale } from '../../lib/i18n';
  import { drawCard, type DeckMode } from '../../lib/deck';
  import { SUIT_NAMES, SUIT_ELEMENTS, MAJOR_CORRESPONDENCE, cards } from '../../data/cards';
  import type { Card, Orientation } from '../../lib/types';

  const app = document.querySelector<HTMLElement>('.draw-app')!;
  const locale = app.dataset.locale as Locale;
  const T = ui[locale];
  const BASE = import.meta.env.BASE_URL;
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const FLIP_MS = 430;

  const cardById = new Map(cards.map((c) => [c.id, c]));

  const form = document.querySelector<HTMLFormElement>('#controls')!;
  const btnDraw = document.querySelector<HTMLButtonElement>('#btn-draw')!;
  const flip = document.querySelector<HTMLElement>('#flip')!;
  const cardImg = document.querySelector<HTMLImageElement>('#card-img')!;
  const placeholder = document.querySelector<HTMLElement>('#placeholder')!;
  const body = document.querySelector<HTMLElement>('#reading-body')!;
  const metaEl = document.querySelector<HTMLElement>('#card-meta')!;
  const nameEl = document.querySelector<HTMLHeadingElement>('#reading-name')!;
  const orientationEl = document.querySelector<HTMLElement>('#orientation')!;
  const keywordsEl = document.querySelector<HTMLElement>('#keywords')!;
  const meaningEl = document.querySelector<HTMLElement>('#meaning')!;
  const btnOrient = document.querySelector<HTMLButtonElement>('#btn-orient')!;
  const result = document.querySelector<HTMLElement>('.result')!;
  const btnGallery = document.querySelector<HTMLButtonElement>('#btn-gallery')!;
  const gallery = document.querySelector<HTMLElement>('#gallery')!;

  const ROMAN = ['', 'I', 'II', 'III', 'IV', 'V', 'VI', 'VII', 'VIII', 'IX', 'X',
    'XI', 'XII', 'XIII', 'XIV', 'XV', 'XVI', 'XVII', 'XVIII', 'XIX', 'XX', 'XXI'];

  // État courant pour la bascule d'orientation.
  let current: Card | null = null;
  let view: Orientation = 'upright';

  function metaLabel(card: Card): string {
    // Ligne « coordonnées ésotériques » : type · (enseigne · élément · rang) ou (numéro · correspondance).
    if (card.arcana === 'major') {
      const num = card.number > 0 ? ROMAN[card.number] : '0';
      const corr = MAJOR_CORRESPONDENCE[card.number]?.[locale];
      const parts = [T['meta.major'], num];
      if (corr) parts.push(corr);
      return parts.join(' · ');
    }
    const suit = card.suit!;
    return [T['meta.minor'], SUIT_NAMES[suit][locale], SUIT_ELEMENTS[suit][locale]].join(' · ');
  }

  function renderReading(card: Card, orientation: Orientation) {
    const reversed = orientation === 'reversed';
    cardImg.src = `${BASE}cards/${card.image}`;
    cardImg.alt = card.name[locale];
    cardImg.classList.toggle('is-reversed', reversed);

    metaEl.textContent = metaLabel(card);
    nameEl.textContent = card.name[locale];
    orientationEl.textContent = reversed ? T['card.reversed'] : T['card.upright'];
    orientationEl.classList.toggle('is-reversed', reversed);

    keywordsEl.replaceChildren();
    if (card.content) {
      const key = reversed ? 'reversed' : 'upright';
      for (const word of card.content.keywords[key][locale]) {
        const chip = document.createElement('span');
        chip.className = 'chip';
        chip.textContent = word;
        keywordsEl.appendChild(chip);
      }
      meaningEl.textContent = card.content.meaning[key][locale];
      btnOrient.hidden = false;
      btnOrient.textContent = reversed ? T['card.seeUpright'] : T['card.seeReversed'];
    } else {
      meaningEl.textContent = T['card.noContent'];
      btnOrient.hidden = true;
    }

    placeholder.hidden = true;
    body.hidden = false;
  }

  function preload(src: string): Promise<void> {
    return new Promise((resolve) => {
      const img = new Image();
      img.onload = () => resolve();
      img.onerror = () => resolve();
      img.src = src;
    });
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const mode = (data.get('deck') as DeckMode) ?? 'major';
    const allowReversed = data.get('reversed') === 'on';

    const draw = drawCard(mode, allowReversed);
    current = draw.card;
    view = draw.orientation;

    btnDraw.disabled = true;
    await preload(`${BASE}cards/${draw.card.image}`);

    const reveal = () => {
      renderReading(draw.card, draw.orientation);
      btnDraw.disabled = false;
      btnDraw.textContent = T['action.again'];
      nameEl.focus();
    };

    const wasFlipped = flip.classList.contains('is-flipped');
    if (reduceMotion) {
      reveal();
      flip.classList.add('is-flipped');
    } else if (wasFlipped) {
      // Retourne face cachée, échange en coulisse, puis re-révèle.
      flip.classList.remove('is-flipped');
      window.setTimeout(() => {
        reveal();
        flip.classList.add('is-flipped');
      }, FLIP_MS);
    } else {
      reveal();
      requestAnimationFrame(() => flip.classList.add('is-flipped'));
    }
  });

  // Explorer l'autre orientation sans retirer une carte.
  btnOrient.addEventListener('click', () => {
    if (!current) return;
    view = view === 'upright' ? 'reversed' : 'upright';
    renderReading(current, view);
  });

  // Accès direct à une carte depuis la galerie : affichage instantané, sans choréo de pioche.
  function selectCard(card: Card, orientation: Orientation) {
    current = card;
    view = orientation;
    flip.classList.add('no-anim');
    renderReading(card, orientation);
    flip.classList.add('is-flipped');
    void flip.offsetWidth; // force le rendu avant de réactiver la transition
    flip.classList.remove('no-anim');
    btnDraw.textContent = T['action.again'];
    result.scrollIntoView({ behavior: reduceMotion ? 'auto' : 'smooth', block: 'center' });
    nameEl.focus({ preventScroll: true });
  }

  gallery.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.gallery-card');
    if (!btn) return;
    const card = cardById.get(btn.dataset.cardId!);
    if (card) selectCard(card, 'upright');
  });

  // Déplier / replier la galerie.
  btnGallery.addEventListener('click', () => {
    const willShow = gallery.hasAttribute('hidden');
    gallery.toggleAttribute('hidden', !willShow);
    btnGallery.textContent = willShow ? T['gallery.hide'] : T['gallery.show'];
    btnGallery.setAttribute('aria-expanded', String(willShow));
    if (willShow) gallery.scrollIntoView({ behavior: reduceMotion ? 'auto' : 'smooth', block: 'start' });
  });

  // Entrée = nouvelle pioche (sauf si le focus est sur un contrôle qui gère lui-même Entrée).
  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Enter' || e.repeat) return;
    const el = e.target as HTMLElement | null;
    if (el && ['INPUT', 'BUTTON', 'A', 'TEXTAREA', 'SELECT'].includes(el.tagName)) return;
    e.preventDefault();
    form.requestSubmit();
  });
</script>

<style>
  .draw-app {
    display: grid;
    gap: 2.25rem;
  }
  .lede {
    text-align: center;
    max-width: 34rem;
    margin: 0.5rem auto 0;
  }
  .lede h1 {
    font-size: clamp(2.6rem, 6vw, 3.8rem);
    margin: 0 0 0.5rem;
  }
  .intro {
    color: var(--muted);
    font-size: 1.05rem;
    margin: 0;
  }

  /* ---- Contrôles ---- */
  .controls {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 1.25rem 1.75rem;
  }
  .deck-select {
    display: inline-flex;
    padding: 0.25rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: var(--panel);
  }
  .seg {
    cursor: pointer;
  }
  .seg input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  .seg span {
    display: block;
    padding: 0.45rem 1.1rem;
    border-radius: 999px;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
    white-space: nowrap;
    transition: color 0.2s ease, background-color 0.2s ease;
  }
  .seg:hover span {
    color: var(--text);
  }
  .seg input:checked + span {
    color: var(--ground);
    background: var(--accent);
  }
  .seg input:focus-visible + span {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .switch {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    cursor: pointer;
    font-size: 0.95rem;
    color: var(--muted);
  }
  .switch input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  .switch-track {
    width: 2.5rem;
    height: 1.4rem;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: var(--panel);
    position: relative;
    transition: background-color 0.2s ease, border-color 0.2s ease;
    flex: none;
  }
  .switch-thumb {
    position: absolute;
    top: 50%;
    left: 0.2rem;
    width: 1rem;
    height: 1rem;
    border-radius: 50%;
    background: var(--muted);
    transform: translateY(-50%);
    transition: transform 0.2s ease, background-color 0.2s ease;
  }
  .switch input:checked + .switch-track {
    background: rgba(201, 164, 76, 0.25);
    border-color: var(--accent);
  }
  .switch input:checked + .switch-track .switch-thumb {
    transform: translate(1.1rem, -50%);
    background: var(--accent);
  }
  .switch input:checked ~ .switch-text {
    color: var(--text);
  }
  .switch input:focus-visible + .switch-track {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .btn-draw {
    font-family: var(--font-body);
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    padding: 0.7rem 1.8rem;
    border: 1px solid var(--accent);
    border-radius: 999px;
    background: var(--accent);
    color: var(--ground);
    cursor: pointer;
    transition: background-color 0.2s ease, box-shadow 0.2s ease;
  }
  .btn-draw:hover:not(:disabled) {
    background: #d9b45c;
    box-shadow: 0 0 24px rgba(201, 164, 76, 0.35);
  }
  .btn-draw:disabled {
    opacity: 0.6;
    cursor: default;
  }

  /* ---- Résultat ---- */
  .result {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 2.5rem;
    align-items: center;
    justify-content: center;
  }
  .card-slot {
    perspective: 1400px;
    width: min(300px, 72vw);
    aspect-ratio: 1100 / 1920;
    justify-self: center;
  }
  .flip {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    transition: transform 0.43s cubic-bezier(0.4, 0.15, 0.2, 1);
  }
  .flip.is-flipped {
    transform: rotateY(180deg);
  }
  .flip.no-anim {
    transition: none;
  }
  .face {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.55), 0 0 0 1px var(--line),
      0 0 40px rgba(201, 164, 76, 0.18);
  }
  .face img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .face-front {
    transform: rotateY(180deg);
  }
  .face-front img {
    transition: transform 0.35s cubic-bezier(0.4, 0.15, 0.2, 1);
  }
  .face-front img.is-reversed {
    transform: rotate(180deg);
  }
  @media (prefers-reduced-motion: reduce) {
    .face-front img {
      transition: none;
    }
  }

  .reading {
    max-width: 30rem;
  }
  .placeholder {
    color: var(--muted);
    font-style: italic;
    font-size: 1.1rem;
  }
  .reading-body {
    display: grid;
    gap: 0.85rem;
  }
  .meta {
    margin: 0;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--accent);
  }
  .reading-body h2 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 2.8rem);
    outline: none;
  }
  .orientation {
    margin: 0;
    font-size: 0.85rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .orientation.is-reversed {
    color: var(--accent-2);
  }
  .keywords {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0.15rem 0;
  }
  .chip {
    font-size: 0.85rem;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    border: 1px solid var(--line);
    color: var(--text);
  }
  .meaning {
    margin: 0;
    font-size: 1.12rem;
    line-height: 1.75;
  }
  .btn-orient {
    justify-self: start;
    margin-top: 0.35rem;
    font-family: var(--font-body);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    padding: 0.4rem 0.9rem;
    background: transparent;
    color: var(--accent);
    border: 1px solid var(--line);
    border-radius: 999px;
    cursor: pointer;
    transition: border-color 0.2s ease, background-color 0.2s ease;
  }
  .btn-orient:hover {
    border-color: var(--accent);
    background: rgba(201, 164, 76, 0.08);
  }

  /* ---- Astuce clavier ---- */
  .hint {
    margin: -0.75rem 0 0;
    text-align: center;
    font-size: 0.82rem;
    color: var(--muted);
  }

  /* ---- Galerie ---- */
  .gallery-toggle {
    display: flex;
    justify-content: center;
  }
  .btn-gallery {
    font-family: var(--font-body);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    padding: 0.6rem 1.4rem;
    background: transparent;
    color: var(--accent);
    border: 1px solid var(--line);
    border-radius: 999px;
    cursor: pointer;
    transition: border-color 0.2s ease, background-color 0.2s ease, color 0.2s ease;
  }
  .btn-gallery:hover {
    border-color: var(--accent);
    background: rgba(201, 164, 76, 0.08);
    color: var(--text);
  }
  .btn-gallery:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .gallery {
    display: grid;
    gap: 2rem;
  }
  .gallery[hidden] {
    display: none;
  }
  .gallery-group h3 {
    margin: 0 0 0.9rem;
    font-size: 0.8rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--accent);
    border-bottom: 1px solid var(--line);
    padding-bottom: 0.5rem;
  }
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(84px, 1fr));
    gap: 0.75rem;
  }
  .gallery-card {
    padding: 0;
    border: 0;
    background: none;
    cursor: pointer;
    border-radius: 8px;
    overflow: hidden;
    line-height: 0;
    box-shadow: 0 0 0 1px var(--line);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .gallery-card img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 1100 / 1920;
    object-fit: cover;
  }
  .gallery-card:hover,
  .gallery-card:focus-visible {
    transform: translateY(-3px);
    box-shadow: 0 8px 22px rgba(0, 0, 0, 0.5), 0 0 0 1px var(--accent),
      0 0 18px rgba(201, 164, 76, 0.25);
    outline: none;
  }
  @media (prefers-reduced-motion: reduce) {
    .gallery-card {
      transition: none;
    }
  }

  @media (max-width: 46rem) {
    .result {
      grid-template-columns: 1fr;
      gap: 1.75rem;
    }
    .reading {
      max-width: none;
      text-align: center;
    }
    .keywords {
      justify-content: center;
    }
    .btn-orient {
      justify-self: center;
    }
    /* Le sélecteur de deck débordait : 3 segments pleine largeur qui peuvent replier le texte. */
    .controls {
      gap: 1rem;
    }
    .deck-select {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      width: 100%;
    }
    .seg span {
      padding: 0.45rem 0.4rem;
      font-size: 0.72rem;
      letter-spacing: 0.08em;
      white-space: normal;
      text-align: center;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .flip {
      transition: none;
    }
  }
</style>
