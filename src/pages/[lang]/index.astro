    }
  }

  /* ---- Résultat ---- */
  /* Mise en page « journal » : carte en haut à gauche, titre + interprétation à
     droite, puis la symbolique pleine largeur sous la carte. */
  .result {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    grid-template-areas:
