---
import Base from '../../layouts/Base.astro';
import { LOCALES, type Locale, type UIKey, t } from '../../lib/i18n';
import { PRISMS, BALANCES } from '../../lib/profile';

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;
---

<Base locale={locale} title={t(locale, 'profil.heading')}>
  <section class="profil" data-locale={locale}>
    <div class="lede">
      <p class="eyebrow">{t(locale, 'profil.eyebrow')}</p>
      <h1>{t(locale, 'profil.heading')}</h1>
      <p class="intro">{t(locale, 'profil.intro')}</p>
    </div>

    <form class="profil-form" id="profil-form" autocomplete="off">
      <label class="name-field">
        <span class="field-label">{t(locale, 'profil.name.label')}</span>
        <input
          type="text"
          id="name"
          name="name"
          maxlength="40"
          placeholder={t(locale, 'profil.name.placeholder')}
        />
      </label>

      <div class="prisms">
        <h2>{t(locale, 'profil.prisms')}</h2>
        <ul class="prism-list">
          {
            PRISMS.map((p) => (
              <li class="prism-row">
                <span class="prism-name">
                  <span class:list={['dot', `dot-${p}`]} aria-hidden="true" />
                  {t(locale, `prism.${p}` as UIKey)}
                </span>
                <div class="balances" role="radiogroup" aria-label={t(locale, `prism.${p}` as UIKey)}>
                  {BALANCES.map((b) => (
                    <label class="bal">
                      <input type="radio" name={`prism-${p}`} value={b} checked={b === 'balanced'} />
                      <span>{t(locale, `balance.${b}` as UIKey)}</span>
                    </label>
                  ))}
                </div>
              </li>
            ))
          }
        </ul>
      </div>
    </form>

    <div class="prism-visual" aria-hidden="true">
      <svg class="prism-vis" viewBox="0 0 460 260" fill="none">
        <line class="beam" x1="16" y1="130" x2="150" y2="130" />
        <path class="prism-shape" d="M150 76 L150 184 L216 130 Z" />
        <g class="rays" stroke-linecap="round">
          <line class="ray ray-instinct" data-prism="instinct" data-balance="balanced" x1="216" y1="130" x2="448" y2="44" />
          <line class="ray ray-concentration" data-prism="concentration" data-balance="balanced" x1="216" y1="130" x2="448" y2="92" />
          <line class="ray ray-eloquence" data-prism="eloquence" data-balance="balanced" x1="216" y1="130" x2="448" y2="130" />
          <line class="ray ray-creativity" data-prism="creativity" data-balance="balanced" x1="216" y1="130" x2="448" y2="168" />
          <line class="ray ray-perseverance" data-prism="perseverance" data-balance="balanced" x1="216" y1="130" x2="448" y2="216" />
        </g>
      </svg>
    </div>

    <div class="profil-foot">
      <span class="saved" id="saved">{t(locale, 'profil.saved')} ✓</span>
      <button type="button" class="btn-reset" id="reset">{t(locale, 'profil.reset')}</button>
    </div>
  </section>
</Base>

<script>
  import { loadProfile, saveProfile, DEFAULT_PROFILE, PRISMS, type Prism, type Balance } from '../../lib/profile';

  const form = document.querySelector<HTMLFormElement>('#profil-form')!;
  const nameInput = document.querySelector<HTMLInputElement>('#name')!;
  const savedEl = document.querySelector<HTMLElement>('#saved')!;
  const resetBtn = document.querySelector<HTMLButtonElement>('#reset')!;
  const visual = document.querySelector<SVGElement>('.prism-vis')!;

  let profile = loadProfile();
  let savedTimer: number | undefined;

  function updateRay(prism: Prism, balance: Balance) {
    visual.querySelector(`.ray[data-prism="${prism}"]`)?.setAttribute('data-balance', balance);
  }

  function apply(p: typeof profile) {
    nameInput.value = p.name;
    for (const prism of PRISMS) {
      const balance = p.prisms[prism];
      const input = form.querySelector<HTMLInputElement>(`input[name="prism-${prism}"][value="${balance}"]`);
      if (input) input.checked = true;
      updateRay(prism, balance);
    }
  }

  function flashSaved() {
    savedEl.classList.add('is-visible');
    window.clearTimeout(savedTimer);
    savedTimer = window.setTimeout(() => savedEl.classList.remove('is-visible'), 1600);
  }

  // Initialisation depuis localStorage.
  apply(profile);

  nameInput.addEventListener('input', () => {
    profile.name = nameInput.value;
    saveProfile(profile);
    flashSaved();
  });

  form.addEventListener('change', (e) => {
    const target = e.target as HTMLInputElement;
    if (target.type !== 'radio') return;
    const prism = target.name.replace('prism-', '') as Prism;
    const balance = target.value as Balance;
    profile.prisms[prism] = balance;
    updateRay(prism, balance);
    saveProfile(profile);
    flashSaved();
  });

  resetBtn.addEventListener('click', () => {
    profile = { name: '', prisms: { ...DEFAULT_PROFILE.prisms } };
    apply(profile);
    saveProfile(profile);
    flashSaved();
  });
</script>

<style>
  .profil {
    display: grid;
    gap: 2.5rem;
    max-width: 44rem;
    margin: 0 auto;
  }
  .lede {
    text-align: center;
  }
  .eyebrow {
    margin: 0 0 0.35rem;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.24em;
    color: var(--accent);
  }
  .lede h1 {
    font-size: clamp(2.6rem, 6vw, 3.6rem);
    margin: 0 0 0.5rem;
  }
  .intro {
    color: var(--muted);
    margin: 0;
  }

  .profil-form {
    display: grid;
    gap: 2rem;
  }
  .name-field {
    display: grid;
    gap: 0.5rem;
    justify-items: center;
    text-align: center;
  }
  .field-label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--muted);
  }
  #name {
    width: min(24rem, 100%);
    font-family: var(--font-display);
    font-size: 1.8rem;
    text-align: center;
    color: var(--text);
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--line);
    padding: 0.35rem 0.5rem;
  }
  #name::placeholder {
    color: rgba(240, 226, 196, 0.35);
    font-style: italic;
  }
  #name:focus {
    outline: none;
    border-bottom-color: var(--accent);
  }

  .prisms h2 {
    text-align: center;
    font-size: 1.6rem;
    margin: 0 0 1.25rem;
  }
  .prism-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.6rem;
  }
  .prism-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem 1rem;
    padding: 0.75rem 0.25rem;
    border-bottom: 1px solid rgba(201, 164, 76, 0.12);
  }
  .prism-name {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 1.15rem;
  }
  .dot {
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 50%;
    flex: none;
    box-shadow: 0 0 8px currentColor;
  }
  .dot-instinct {
    color: #e0564c;
    background: #e0564c;
  }
  .dot-concentration {
    color: #5b8fd6;
    background: #5b8fd6;
  }
  .dot-eloquence {
    color: #5fb573;
    background: #5fb573;
  }
  .dot-creativity {
    color: #a578d6;
    background: #a578d6;
  }
  .dot-perseverance {
    color: #e8cf55;
    background: #e8cf55;
  }

  /* segmented control des équilibres */
  .balances {
    display: inline-flex;
    padding: 0.2rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: var(--panel);
  }
  .bal {
    cursor: pointer;
  }
  .bal input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  .bal span {
    display: block;
    padding: 0.35rem 0.85rem;
    border-radius: 999px;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
    white-space: nowrap;
    transition: color 0.2s ease, background-color 0.2s ease;
  }
  .bal:hover span {
    color: var(--text);
  }
  .bal input:checked + span {
    color: var(--ground);
    background: var(--accent);
  }
  .bal input:focus-visible + span {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* prisme réfractant */
  .prism-visual {
    display: flex;
    justify-content: center;
  }
  .prism-vis {
    width: min(460px, 100%);
    height: auto;
  }
  .beam {
    stroke: rgba(255, 250, 235, 0.9);
    stroke-width: 3;
    filter: drop-shadow(0 0 5px rgba(255, 250, 235, 0.6));
  }
  .prism-shape {
    stroke: var(--accent);
    stroke-width: 1.6;
    fill: rgba(201, 164, 76, 0.06);
  }
  .ray {
    stroke: currentColor;
    stroke-width: var(--w-base, 3.2);
    animation: ray-pulse var(--pulse-dur, 2.3s) ease-in-out infinite;
  }
  .ray-instinct {
    color: #e0564c;
  }
  .ray-concentration {
    color: #5b8fd6;
  }
  .ray-eloquence {
    color: #5fb573;
  }
  .ray-creativity {
    color: #a578d6;
  }
  .ray-perseverance {
    color: #e8cf55;
  }
  /* décalages : évite une pulsation synchrone mécanique */
  .ray-concentration {
    animation-delay: -0.5s;
  }
  .ray-eloquence {
    animation-delay: -1s;
  }
  .ray-creativity {
    animation-delay: -1.5s;
  }
  .ray-perseverance {
    animation-delay: -0.9s;
  }

  /* Confiant : stable et intense — faible amplitude, éclat élevé, lent. */
  .ray[data-balance='confident'] {
    --w-base: 3.4;
    --w-min: 3.1;
    --w-max: 3.7;
    --o-min: 0.9;
    --o-max: 1;
    --g-min: 6px;
    --g-max: 9px;
    --pulse-dur: 3.6s;
  }
  /* Équilibré : entre les deux. */
  .ray[data-balance='balanced'] {
    --w-base: 3.2;
    --w-min: 2.7;
    --w-max: 4.1;
    --o-min: 0.6;
    --o-max: 0.95;
    --g-min: 4px;
    --g-max: 10px;
    --pulse-dur: 2.3s;
  }
  /* Risqué : pulse fortement — grande amplitude, rapide. */
  .ray[data-balance='risky'] {
    --w-base: 3.6;
    --w-min: 2.4;
    --w-max: 5.2;
    --o-min: 0.32;
    --o-max: 1;
    --g-min: 3px;
    --g-max: 18px;
    --pulse-dur: 1.05s;
  }
  @keyframes ray-pulse {
    0%,
    100% {
      opacity: var(--o-min, 0.6);
      stroke-width: var(--w-min, 2.7);
      filter: drop-shadow(0 0 var(--g-min, 4px) currentColor);
    }
    50% {
      opacity: var(--o-max, 0.95);
      stroke-width: var(--w-max, 4.1);
      filter: drop-shadow(0 0 var(--g-max, 10px) currentColor);
    }
  }

  .profil-foot {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
  }
  .saved {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--accent);
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .saved.is-visible {
    opacity: 1;
  }
  .btn-reset {
    font-family: var(--font-body);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    padding: 0.45rem 1.1rem;
    background: transparent;
    color: var(--muted);
    border: 1px solid var(--line);
    border-radius: 999px;
    cursor: pointer;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .btn-reset:hover {
    color: var(--text);
    border-color: var(--accent);
  }

  @media (max-width: 34rem) {
    .prism-row {
      justify-content: center;
    }
    .bal span {
      padding: 0.35rem 0.7rem;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    /* Pas de pulsation : différenciation statique via les valeurs hautes. */
    .ray {
      animation: none;
      stroke-width: var(--w-max, 4.1);
      opacity: var(--o-max, 0.95);
      filter: drop-shadow(0 0 var(--g-max, 8px) currentColor);
    }
  }
</style>
