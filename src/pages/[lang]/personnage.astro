---
import Base from '../../layouts/Base.astro';
import { LOCALES, type Locale, type UIKey, t } from '../../lib/i18n';
import { PRISMS, BALANCES } from '../../lib/profile';

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;
---

<Base locale={locale} title={t(locale, 'profil.heading')}>
  <section class="profil" data-locale={locale}>
    <div class="lede">
      <h1>{t(locale, 'profil.heading')}</h1>
      <p class="intro">{t(locale, 'profil.intro')}</p>
    </div>

    <form class="profil-form" id="profil-form" autocomplete="off">
      <label class="name-field">
        <span class="field-label">{t(locale, 'profil.name.label')}</span>
        <input
          type="text"
          id="name"
          name="name"
          maxlength="40"
          placeholder={t(locale, 'profil.name.placeholder')}
        />
      </label>

      <section class="arcana" aria-labelledby="arcana-title">
        <h2 id="arcana-title">{t(locale, 'profil.arcana.title')}</h2>
        <p class="arcana-hint">{t(locale, 'profil.arcana.hint')}</p>

        <div class="arcana-card" id="arcana-card">
          <img class="arcana-back" src="/cards/back.svg" alt="" width="220" height="384" />
          <img class="arcana-front" id="arcana-img" alt="" width="220" height="384" hidden />
        </div>

        <div class="arcana-reading" id="arcana-reading" aria-live="polite" hidden>
          <h3 id="arcana-name"></h3>
          <div class="arcana-keywords" id="arcana-keywords"></div>
          <p class="arcana-meaning" id="arcana-meaning"></p>
        </div>

        <button type="button" class="btn-arcana" id="arcana-btn">{t(locale, 'profil.arcana.draw')}</button>
      </section>

      <div class="prisms-layout">
      <div class="prisms">
        <h2>{t(locale, 'profil.prisms')}</h2>
        <ul class="prism-list">
          {
            PRISMS.map((p) => (
              <li class="prism-row">
                <div class="prism-info">
                  <span class="prism-name">
                    <span class:list={['dot', `dot-${p}`]} aria-hidden="true" />
                    {t(locale, `prism.${p}` as UIKey)}
                  </span>
                  <span class="prism-desc">{t(locale, `prism.${p}.desc` as UIKey)}</span>
                </div>
                <div class="balances" role="radiogroup" aria-label={t(locale, `prism.${p}` as UIKey)}>
                  {BALANCES.map((b) => (
                    <label class="bal">
                      <input type="radio" name={`prism-${p}`} value={b} checked={b === 'balanced'} />
                      <span>{t(locale, `balance.${b}` as UIKey)}</span>
                    </label>
                  ))}
                </div>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="prism-visual" aria-hidden="true">
      <svg class="prism-vis" viewBox="0 0 260 460" fill="none">
        <line class="beam" x1="130" y1="14" x2="130" y2="150" />
        <path class="prism-shape" d="M86 150 L174 150 L130 216 Z" />
        <g class="rays" stroke-linecap="round">
          <line class="ray ray-instinct" data-prism="instinct" data-balance="balanced" pathLength="100" x1="130" y1="216" x2="44" y2="448" />
          <line class="ray ray-perseverance" data-prism="perseverance" data-balance="balanced" pathLength="100" x1="130" y1="216" x2="92" y2="448" />
          <line class="ray ray-eloquence" data-prism="eloquence" data-balance="balanced" pathLength="100" x1="130" y1="216" x2="130" y2="448" />
          <line class="ray ray-concentration" data-prism="concentration" data-balance="balanced" pathLength="100" x1="130" y1="216" x2="168" y2="448" />
          <line class="ray ray-creativity" data-prism="creativity" data-balance="balanced" pathLength="100" x1="130" y1="216" x2="216" y2="448" />
        </g>
      </svg>
      </div>
      </div>
    </form>

    <div class="profil-foot">
      <span class="saved" id="saved">{t(locale, 'profil.saved')} ✓</span>
      <button type="button" class="btn-reset" id="reset">{t(locale, 'profil.reset')}</button>
    </div>
  </section>
</Base>

<script>
  import { loadProfile, saveProfile, DEFAULT_PROFILE, PRISMS, type Prism, type Balance } from '../../lib/profile';
  import { ui, type Locale } from '../../lib/i18n';
  import { drawCard } from '../../lib/deck';
  import { cards } from '../../data/cards';

  const section = document.querySelector<HTMLElement>('.profil')!;
  const locale = section.dataset.locale as Locale;
  const T = ui[locale];
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const form = document.querySelector<HTMLFormElement>('#profil-form')!;
  const nameInput = document.querySelector<HTMLInputElement>('#name')!;
  const savedEl = document.querySelector<HTMLElement>('#saved')!;
  const resetBtn = document.querySelector<HTMLButtonElement>('#reset')!;
  const visual = document.querySelector<SVGElement>('.prism-vis')!;

  const arcanaCard = document.querySelector<HTMLElement>('#arcana-card')!;
  const arcanaImg = document.querySelector<HTMLImageElement>('#arcana-img')!;
  const arcanaBack = document.querySelector<HTMLImageElement>('.arcana-back')!;
  const arcanaReading = document.querySelector<HTMLElement>('#arcana-reading')!;
  const arcanaName = document.querySelector<HTMLElement>('#arcana-name')!;
  const arcanaKeywords = document.querySelector<HTMLElement>('#arcana-keywords')!;
  const arcanaMeaning = document.querySelector<HTMLElement>('#arcana-meaning')!;
  const arcanaBtn = document.querySelector<HTMLButtonElement>('#arcana-btn')!;

  let profile = loadProfile();
  let savedTimer: number | undefined;

  function renderArcana(id: string | null, animate: boolean) {
    const card = id ? cards.find((c) => c.id === id) : undefined;
    if (!card) {
      arcanaImg.hidden = true;
      arcanaBack.hidden = false;
      arcanaReading.hidden = true;
      arcanaBtn.textContent = T['profil.arcana.draw'];
      return;
    }
    arcanaImg.src = `/cards/${card.image}`;
    arcanaImg.alt = card.name[locale];
    arcanaImg.hidden = false;
    arcanaBack.hidden = true;
    arcanaName.textContent = card.name[locale];
    arcanaKeywords.replaceChildren();
    if (card.content) {
      for (const word of card.content.keywords.upright[locale]) {
        const chip = document.createElement('span');
        chip.className = 'arcana-chip';
        chip.textContent = word;
        arcanaKeywords.appendChild(chip);
      }
      arcanaMeaning.textContent = card.content.meaning.upright[locale];
    }
    arcanaReading.hidden = false;
    arcanaBtn.textContent = T['profil.arcana.redraw'];
    if (animate && !reduceMotion) {
      arcanaCard.classList.remove('reveal');
      void arcanaCard.offsetWidth;
      arcanaCard.classList.add('reveal');
    }
  }

  // Confiant = rai long ; équilibré = médian ; risqué = court (fraction de pathLength).
  const RAY_LENGTH: Record<Balance, number> = { confident: 1, balanced: 0.8, risky: 0.56 };

  function updateRay(prism: Prism, balance: Balance) {
    const line = visual.querySelector<SVGLineElement>(`.ray[data-prism="${prism}"]`);
    if (!line) return;
    line.setAttribute('data-balance', balance);
    // pathLength = 100 → dashoffset masque la portion lointaine ; transition CSS anime.
    line.style.strokeDashoffset = String(100 * (1 - RAY_LENGTH[balance]));
  }

  function apply(p: typeof profile) {
    nameInput.value = p.name;
    for (const prism of PRISMS) {
      const balance = p.prisms[prism];
      const input = form.querySelector<HTMLInputElement>(`input[name="prism-${prism}"][value="${balance}"]`);
      if (input) input.checked = true;
      updateRay(prism, balance);
    }
    renderArcana(p.arcana, false);
  }

  function flashSaved() {
    savedEl.classList.add('is-visible');
    window.clearTimeout(savedTimer);
    savedTimer = window.setTimeout(() => savedEl.classList.remove('is-visible'), 1600);
  }

  // Initialisation depuis localStorage.
  apply(profile);

  nameInput.addEventListener('input', () => {
    profile.name = nameInput.value;
    saveProfile(profile);
    flashSaved();
  });

  form.addEventListener('change', (e) => {
    const target = e.target as HTMLInputElement;
    if (target.type !== 'radio') return;
    const prism = target.name.replace('prism-', '') as Prism;
    const balance = target.value as Balance;
    profile.prisms[prism] = balance;
    updateRay(prism, balance);
    saveProfile(profile);
    flashSaved();
  });

  arcanaBtn.addEventListener('click', () => {
    const { card } = drawCard('major', false); // arcane fondatrice : toujours à l'endroit
    profile.arcana = card.id;
    renderArcana(card.id, true);
    saveProfile(profile);
    flashSaved();
  });

  resetBtn.addEventListener('click', () => {
    profile = { name: '', arcana: null, prisms: { ...DEFAULT_PROFILE.prisms } };
    apply(profile);
    saveProfile(profile);
    flashSaved();
  });
</script>

<style>
  .profil {
    display: grid;
    gap: 2.5rem;
    max-width: 54rem;
    margin: 0 auto;
  }
  .lede {
    text-align: center;
    max-width: 34rem;
    margin: 0 auto;
  }
  /* Sur grand écran : prismes à gauche, prisme réfractant à droite. */
  .prisms-layout {
    display: grid;
    gap: 1.5rem;
  }
  @media (min-width: 56rem) {
    .prisms-layout {
      grid-template-columns: minmax(0, 1fr) minmax(0, 16rem);
      align-items: center;
      gap: 2.5rem;
    }
    /* Sélecteur d'équilibre en vertical, à droite du texte, centré.
       Sélecteurs préfixés .prisms-layout pour surpasser la règle de base
       (même spécificité mais déclarée après → l'emporterait sinon). */
    .prisms-layout .balances {
      flex-direction: column;
      border-radius: 12px;
      padding: 0.25rem;
    }
    .prisms-layout .bal span {
      text-align: center;
      padding: 0.4rem 0.9rem;
    }
  }
  .eyebrow {
    margin: 0 0 0.35rem;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.24em;
    color: var(--accent);
  }
  .lede h1 {
    font-size: clamp(2.6rem, 6vw, 3.6rem);
    margin: 0 0 0.5rem;
  }
  .intro {
    color: var(--muted);
    margin: 0;
  }

  .profil-form {
    display: grid;
    gap: 2rem;
  }
  .name-field {
    display: grid;
    gap: 0.5rem;
    justify-items: center;
    text-align: center;
  }
  .field-label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--muted);
  }
  #name {
    width: min(24rem, 100%);
    font-family: var(--font-display);
    font-size: 1.8rem;
    text-align: center;
    color: var(--text);
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--line);
    padding: 0.35rem 0.5rem;
  }
  #name::placeholder {
    color: rgba(240, 226, 196, 0.35);
    font-style: italic;
  }
  #name:focus {
    outline: none;
    border-bottom-color: var(--accent);
  }

  /* ---- Arcane fondatrice ---- */
  .arcana {
    display: grid;
    justify-items: center;
    gap: 0.75rem;
    text-align: center;
    padding: 1.5rem 0;
    border-top: 1px solid rgba(201, 164, 76, 0.12);
    border-bottom: 1px solid rgba(201, 164, 76, 0.12);
  }
  .arcana h2 {
    font-size: 1.6rem;
    margin: 0;
  }
  .arcana-hint {
    margin: 0;
    max-width: 30rem;
    color: var(--muted);
    font-style: italic;
    font-size: 0.95rem;
  }
  .arcana-card {
    position: relative;
    width: min(200px, 58vw);
    aspect-ratio: 1100 / 1920;
    margin: 0.5rem 0;
  }
  .arcana-card img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 10px;
    box-shadow: 0 12px 34px rgba(0, 0, 0, 0.5), 0 0 0 1px var(--line), 0 0 26px rgba(201, 164, 76, 0.16);
  }
  .arcana-card.reveal .arcana-front {
    animation: arcana-reveal 0.55s ease;
  }
  @keyframes arcana-reveal {
    from {
      opacity: 0;
      transform: translateY(8px) scale(0.96);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  .arcana-reading {
    display: grid;
    gap: 0.6rem;
    max-width: 30rem;
  }
  .arcana-reading h3 {
    font-family: var(--font-display);
    font-size: 1.9rem;
    font-weight: 600;
    margin: 0;
    color: var(--accent);
  }
  .arcana-keywords {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    justify-content: center;
  }
  .arcana-chip {
    font-size: 0.8rem;
    padding: 0.2rem 0.65rem;
    border-radius: 999px;
    border: 1px solid var(--line);
    color: var(--text);
  }
  .arcana-meaning {
    margin: 0;
    line-height: 1.7;
  }
  .btn-arcana {
    font-family: var(--font-body);
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    padding: 0.55rem 1.4rem;
    border: 1px solid var(--accent);
    border-radius: 999px;
    background: transparent;
    color: var(--accent);
    cursor: pointer;
    transition: background-color 0.2s ease, box-shadow 0.2s ease;
  }
  .btn-arcana:hover {
    background: rgba(201, 164, 76, 0.1);
    box-shadow: 0 0 20px -6px var(--accent);
  }

  .prisms h2 {
    text-align: center;
    font-size: 1.6rem;
    margin: 0 0 1.25rem;
  }
  .prism-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.6rem;
  }
  .prism-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem 1rem;
    padding: 0.75rem 0.25rem;
    border-bottom: 1px solid rgba(201, 164, 76, 0.12);
  }
  .prism-info {
    display: grid;
    gap: 0.25rem;
  }
  .prism-name {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 1.15rem;
  }
  .prism-desc {
    font-size: 0.88rem;
    line-height: 1.4;
    color: var(--muted);
    max-width: 42ch;
  }
  .dot {
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 50%;
    flex: none;
    box-shadow: 0 0 8px currentColor;
  }
  .dot-instinct {
    color: #e0564c;
    background: #e0564c;
  }
  .dot-concentration {
    color: #5b8fd6;
    background: #5b8fd6;
  }
  .dot-eloquence {
    color: #5fb573;
    background: #5fb573;
  }
  .dot-creativity {
    color: #a578d6;
    background: #a578d6;
  }
  .dot-perseverance {
    color: #e8cf55;
    background: #e8cf55;
  }

  /* segmented control des équilibres */
  .balances {
    display: inline-flex;
    padding: 0.2rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: var(--panel);
  }
  .bal {
    cursor: pointer;
  }
  .bal input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  .bal span {
    display: block;
    padding: 0.35rem 0.85rem;
    border-radius: 999px;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
    white-space: nowrap;
    transition: color 0.2s ease, background-color 0.2s ease;
  }
  .bal:hover span {
    color: var(--text);
  }
  .bal input:checked + span {
    color: var(--ground);
    background: var(--accent);
  }
  .bal input:focus-visible + span {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* prisme réfractant */
  .prism-visual {
    display: flex;
    justify-content: center;
  }
  .prism-vis {
    width: min(200px, 70%);
    height: auto;
  }
  .beam {
    stroke: rgba(255, 250, 235, 0.9);
    stroke-width: 3;
    filter: drop-shadow(0 0 5px rgba(255, 250, 235, 0.6));
  }
  .prism-shape {
    stroke: var(--accent);
    stroke-width: 1.6;
    fill: rgba(201, 164, 76, 0.06);
  }
  /* Rays uniformes ; seule la LONGUEUR distingue l'équilibre.
     Longueur pilotée par stroke-dashoffset (pathLength=100), animée en douceur. */
  .ray {
    stroke: currentColor;
    stroke-width: 2.5;
    stroke-linecap: round;
    filter: drop-shadow(0 0 5px currentColor);
    stroke-dasharray: 100 100;
    transition: stroke-dashoffset 0.45s cubic-bezier(0.33, 0.1, 0.2, 1);
  }
  .ray-instinct {
    color: #e0564c;
  }
  .ray-perseverance {
    color: #e8cf55;
  }
  .ray-eloquence {
    color: #5fb573;
  }
  .ray-concentration {
    color: #5b8fd6;
  }
  .ray-creativity {
    color: #a578d6;
  }

  .profil-foot {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
  }
  .saved {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--accent);
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .saved.is-visible {
    opacity: 1;
  }
  .btn-reset {
    font-family: var(--font-body);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    padding: 0.45rem 1.1rem;
    background: transparent;
    color: var(--muted);
    border: 1px solid var(--line);
    border-radius: 999px;
    cursor: pointer;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .btn-reset:hover {
    color: var(--text);
    border-color: var(--accent);
  }

  @media (max-width: 34rem) {
    .prism-row {
      justify-content: center;
    }
    .bal span {
      padding: 0.35rem 0.7rem;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .ray {
      transition: none;
    }
  }
</style>
