---
import cormorantWoff2 from '@fontsource-variable/cormorant/files/cormorant-latin-wght-normal.woff2';
import ebGaramondWoff2 from '@fontsource-variable/eb-garamond/files/eb-garamond-latin-wght-normal.woff2';
import { type Locale, t } from '../lib/i18n';
import LangToggle from '../components/LangToggle.astro';

interface Props {
  locale: Locale;
  title?: string;
  /** Entrée de nav active : 'home' | 'cartes' | 'grammaire' | 'comment-lire'. */
  active?: string;
}

const { locale, title, active = 'home' } = Astro.props;
const pageTitle = title ? `${title} — ${t(locale, 'site.title')}` : t(locale, 'site.title');

const base = import.meta.env.BASE_URL;
const otherLocale: Locale = locale === 'fr' ? 'en' : 'fr';

// Sous-chemin courant (après /{lang}/) pour conserver la page dans les liens hreflang.
const sub = Astro.url.pathname.replace(base, '').replace(/^(fr|en)\/?/, '');
const path = `${base}${locale}/${sub}`;
const otherPath = `${base}${otherLocale}/${sub}`;

// Navigation principale. Le slug '' est la home (le tirage).
const NAV = [
  { key: 'home', slug: '', label: 'nav.draw' },
  { key: 'cartes', slug: 'cartes', label: 'nav.cards' },
  { key: 'grammaire', slug: 'grammaire', label: 'nav.grammar' },
  { key: 'comment-lire', slug: 'comment-lire', label: 'nav.method' },
] as const;

// Polices auto-hébergées en `font-display: optional` + préchargées : la police
// arrive avant le premier rendu et ne « swappe » jamais après coup (pas de glitch).
const fontFace = `
@font-face{font-family:'Cormorant Variable';font-style:normal;font-display:optional;font-weight:300 700;src:url(${cormorantWoff2}) format('woff2-variations');}
@font-face{font-family:'EB Garamond Variable';font-style:normal;font-display:optional;font-weight:400 800;src:url(${ebGaramondWoff2}) format('woff2-variations');}
`;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    <link rel="preload" href={cormorantWoff2} as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href={ebGaramondWoff2} as="font" type="font/woff2" crossorigin="anonymous" />
    <style set:html={fontFace}></style>
    <title>{pageTitle}</title>
    <meta name="description" content={t(locale, 'site.tagline')} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={t(locale, 'site.tagline')} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={locale === 'fr' ? 'fr_FR' : 'en_US'} />
    <link rel="alternate" hreflang={locale} href={path} />
    <link rel="alternate" hreflang={otherLocale} href={otherPath} />
  </head>
  <body>
    <div class="aura" aria-hidden="true"></div>
    <header class="site-header">
      <a class="brand" href={`${base}${locale}/`}>
        <span class="brand-mark" aria-hidden="true">✦</span>
        <span>{t(locale, 'site.title')}</span>
      </a>
      <nav class="site-nav" aria-label={t(locale, 'nav.label')}>
        {NAV.map((item) => (
          <a
            href={`${base}${locale}/${item.slug}`}
            class:list={['nav-link', { 'is-current': active === item.key }]}
            aria-current={active === item.key ? 'page' : undefined}
          >
            {t(locale, item.label)}
          </a>
        ))}
      </nav>
      <div class="header-utils">
        <LangToggle locale={locale} />
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <span class="footer-rule" aria-hidden="true"></span>
      <small>{t(locale, 'footer.credit')}</small>
      <small>
        <a href="https://commons.wikimedia.org/wiki/Category:Rider-Waite_tarot_deck" rel="noopener">
          {t(locale, 'footer.source')}
        </a>
      </small>
    </footer>

    <style is:global>
      :root {
        --ground: #15101e;
        --ground-2: #241a33;
        --text: #f0e2c4;
        --muted: rgba(240, 226, 196, 0.62);
        --accent: #c9a44c;
        --accent-2: #b5532f;
        --line: rgba(201, 164, 76, 0.28);
        --panel: rgba(240, 226, 196, 0.045);
        --font-display: 'Cormorant Variable', Georgia, 'Times New Roman', serif;
        --font-body: 'EB Garamond Variable', Georgia, 'Times New Roman', serif;
        --maxw: 60rem;
      }
      * {
        box-sizing: border-box;
      }
      /* L'attribut hidden doit toujours l'emporter, même sur display:grid/flex. */
      [hidden] {
        display: none !important;
      }
      html {
        color-scheme: dark;
      }
      body {
        margin: 0;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        color: var(--text);
        background: var(--ground);
        background-image:
          radial-gradient(120% 80% at 50% -10%, var(--ground-2) 0%, transparent 60%),
          radial-gradient(60% 50% at 50% 30%, rgba(201, 164, 76, 0.06) 0%, transparent 70%);
        background-attachment: fixed;
        font-family: var(--font-body);
        font-size: 18px;
        line-height: 1.65;
        -webkit-font-smoothing: antialiased;
      }
      .aura {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 0;
        background: radial-gradient(50% 40% at 50% 42%, rgba(201, 164, 76, 0.08), transparent 70%);
        will-change: transform, opacity;
        animation: aura-drift 16s ease-in-out infinite;
      }
      @keyframes aura-drift {
        0%,
        100% {
          transform: translate3d(-1.5%, -1%, 0) scale(1);
          opacity: 0.8;
        }
        50% {
          transform: translate3d(1.5%, 1.5%, 0) scale(1.12);
          opacity: 1;
        }
      }
      @media (prefers-reduced-motion: reduce) {
        .aura {
          animation: none;
        }
      }
      body > * {
        position: relative;
        z-index: 1;
      }
      a {
        color: var(--accent);
      }
      h1,
      h2 {
        font-family: var(--font-display);
        font-weight: 600;
        line-height: 1.05;
        letter-spacing: 0.01em;
      }
      .site-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 0.75rem 1rem;
        max-width: var(--maxw);
        width: 100%;
        margin: 0 auto;
        padding: 1.25rem 1.5rem;
      }
      .header-utils {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.75rem 1.25rem;
      }
      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--font-display);
        font-size: 1.35rem;
        font-weight: 600;
        color: var(--text);
        text-decoration: none;
      }
      .brand-mark {
        color: var(--accent);
      }
      .site-nav {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem 1.15rem;
      }
      .nav-link {
        font-family: var(--font-body);
        font-size: 0.82rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--muted);
        text-decoration: none;
        padding: 0.15rem 0;
        border-bottom: 1px solid transparent;
        transition: color 0.2s ease, border-color 0.2s ease;
      }
      .nav-link:hover {
        color: var(--text);
      }
      .nav-link.is-current {
        color: var(--accent);
        border-bottom-color: var(--accent);
      }
      main {
        flex: 1;
        max-width: var(--maxw);
        width: 100%;
        margin: 0 auto;
        padding: 1rem 1.5rem 2rem;
      }
      .site-footer {
        max-width: var(--maxw);
        width: 100%;
        margin: 1rem auto 2.5rem;
        padding: 0 1.5rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.6rem;
        color: var(--muted);
        text-align: center;
        font-size: 0.85rem;
      }
      .footer-rule {
        width: 4rem;
        height: 1px;
        background: var(--line);
        margin-bottom: 0.4rem;
      }
      :focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 3px;
        border-radius: 2px;
      }
      /* Titre des pages de référence (Cartes / Grammaire / Comment lire). */
      .page-title {
        font-family: var(--font-display);
        font-weight: 600;
        line-height: 1.05;
        font-size: clamp(2rem, 4vw, 2.6rem);
        text-align: center;
        margin: 0.5rem 0 2rem;
      }
      /* ---- Sections d'apprentissage partagées (Grammaire & Comment lire) ---- */
      .grammar {
        display: grid;
        gap: 2rem;
        max-width: 44rem;
        margin: 0 auto;
      }
      .grammar-group h3 {
        margin: 0 0 0.9rem;
        font-size: 0.8rem;
        font-weight: 400;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        color: var(--accent);
        border-bottom: 1px solid var(--line);
        padding-bottom: 0.5rem;
      }
      .grammar-intro {
        margin: -0.3rem 0 1rem;
        color: var(--muted);
        font-style: italic;
      }
      .grammar-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: grid;
        gap: 1.1rem;
      }
      .grammar-list .g-term {
        margin: 0 0 0.2rem;
        display: flex;
        flex-wrap: wrap;
        align-items: baseline;
        gap: 0.5rem;
        color: var(--text);
      }
      .g-glyph {
        font-size: 1.15em;
      }
      .g-key {
        min-width: 2.4rem;
        font-size: 0.8rem;
        letter-spacing: 0.08em;
        color: var(--accent);
      }
      .g-gloss {
        font-size: 0.9rem;
        font-style: italic;
        color: var(--muted);
      }
      .grammar-list .g-text {
        margin: 0;
        color: var(--muted);
        line-height: 1.65;
      }
    </style>
  </body>
</html>
