---
import cormorantWoff2 from '@fontsource-variable/cormorant/files/cormorant-latin-wght-normal.woff2';
import ebGaramondWoff2 from '@fontsource-variable/eb-garamond/files/eb-garamond-latin-wght-normal.woff2';
import { type Locale, t } from '../lib/i18n';
import LangToggle from '../components/LangToggle.astro';

interface Props {
  locale: Locale;
  title?: string;
}

const { locale, title } = Astro.props;
const pageTitle = title ? `${title} — ${t(locale, 'site.title')}` : t(locale, 'site.title');

// Variante de langue de la page courante, pour les liens hreflang.
const otherLocale: Locale = locale === 'fr' ? 'en' : 'fr';
const path = Astro.url.pathname;
const otherPath = path.replace(/^\/(fr|en)(\/|$)/, `/${otherLocale}$2`);

// Accès direct aux pages, groupés par partie (séparateurs entre groupes).
type NavEntry = { href: string; label: string } | 'sep';
const subnav: NavEntry[] = [
  { href: `/${locale}/personnage/`, label: t(locale, 'profil.heading') },
  'sep',
  { href: `/${locale}/agir/action/`, label: t(locale, 'agir.heading') },
  { href: `/${locale}/agir/confrontation/`, label: t(locale, 'confront.heading') },
  'sep',
  { href: `/${locale}/oracles/tarot/`, label: t(locale, 'nav.tarot') },
  { href: `/${locale}/oracles/coin/`, label: t(locale, 'nav.coin') },
];
const isActive = (href: string) => path === href || path.startsWith(href);

// Polices auto-hébergées en `font-display: optional` + préchargées : la police
// arrive avant le premier rendu et ne « swappe » jamais après coup (pas de glitch).
const fontFace = `
@font-face{font-family:'Cormorant Variable';font-style:normal;font-display:optional;font-weight:300 700;src:url(${cormorantWoff2}) format('woff2-variations');}
@font-face{font-family:'EB Garamond Variable';font-style:normal;font-display:optional;font-weight:400 800;src:url(${ebGaramondWoff2}) format('woff2-variations');}
`;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preload" href={cormorantWoff2} as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href={ebGaramondWoff2} as="font" type="font/woff2" crossorigin="anonymous" />
    <style set:html={fontFace}></style>
    <title>{pageTitle}</title>
    <meta name="description" content={t(locale, 'site.tagline')} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={t(locale, 'site.tagline')} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={locale === 'fr' ? 'fr_FR' : 'en_US'} />
    <link rel="alternate" hreflang={locale} href={path} />
    <link rel="alternate" hreflang={otherLocale} href={otherPath} />
  </head>
  <body>
    <div class="aura" aria-hidden="true"></div>
    <header class="site-header">
      <a class="brand" href={`/${locale}/`}>
        <span class="brand-mark" aria-hidden="true">✦</span>
        <span>{t(locale, 'site.title')}</span>
      </a>
      <nav class="header-utils">
        <a class="nav-link" href={`/${locale}/credits/`}>{t(locale, 'nav.credits')}</a>
        <LangToggle locale={locale} />
      </nav>
    </header>

    <nav class="subnav" aria-label={t(locale, 'site.title')}>
      {
        subnav.map((entry) =>
          entry === 'sep' ? (
            <span class="subnav-sep" aria-hidden="true"></span>
          ) : (
            <a
              class="subnav-link"
              href={entry.href}
              aria-current={isActive(entry.href) ? 'page' : undefined}
            >
              {entry.label}
            </a>
          ),
        )
      }
    </nav>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <span class="footer-rule" aria-hidden="true"></span>
      <small>{t(locale, 'site.tagline')}</small>
    </footer>

    <style is:global>
      :root {
        --ground: #15101e;
        --ground-2: #241a33;
        --text: #f0e2c4;
        --muted: rgba(240, 226, 196, 0.62);
        --accent: #c9a44c;
        --accent-2: #b5532f;
        --line: rgba(201, 164, 76, 0.28);
        --panel: rgba(240, 226, 196, 0.045);
        --font-display: 'Cormorant Variable', Georgia, 'Times New Roman', serif;
        --font-body: 'EB Garamond Variable', Georgia, 'Times New Roman', serif;
        --maxw: 60rem;
      }
      * {
        box-sizing: border-box;
      }
      /* L'attribut hidden doit toujours l'emporter, même sur display:grid/flex. */
      [hidden] {
        display: none !important;
      }
      html {
        color-scheme: dark;
      }
      body {
        margin: 0;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        color: var(--text);
        background: var(--ground);
        background-image:
          radial-gradient(120% 80% at 50% -10%, var(--ground-2) 0%, transparent 60%),
          radial-gradient(60% 50% at 50% 30%, rgba(201, 164, 76, 0.06) 0%, transparent 70%);
        background-attachment: fixed;
        font-family: var(--font-body);
        font-size: 18px;
        line-height: 1.65;
        -webkit-font-smoothing: antialiased;
      }
      .aura {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 0;
        background: radial-gradient(50% 40% at 50% 42%, rgba(201, 164, 76, 0.08), transparent 70%);
      }
      body > * {
        position: relative;
        z-index: 1;
      }
      a {
        color: var(--accent);
      }
      h1,
      h2 {
        font-family: var(--font-display);
        font-weight: 600;
        line-height: 1.05;
        letter-spacing: 0.01em;
      }
      .site-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 0.75rem 1rem;
        max-width: var(--maxw);
        width: 100%;
        margin: 0 auto;
        padding: 1.25rem 1.5rem;
      }
      .header-utils {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.75rem 1.25rem;
      }
      .subnav {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: center;
        gap: 0.5rem 1.1rem;
        max-width: var(--maxw);
        width: 100%;
        margin: 0 auto;
        padding: 0.15rem 1.5rem 1rem;
        border-bottom: 1px solid var(--line);
      }
      .subnav-link {
        font-size: 0.82rem;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        text-decoration: none;
        color: var(--muted);
        padding-bottom: 0.15rem;
        border-bottom: 1px solid transparent;
        transition: color 0.2s ease, border-color 0.2s ease;
      }
      .subnav-link:hover {
        color: var(--text);
      }
      .subnav-link[aria-current='page'] {
        color: var(--accent);
        border-bottom-color: var(--accent);
      }
      .subnav-sep {
        width: 1px;
        height: 0.9rem;
        background: var(--line);
      }
      @media (max-width: 40rem) {
        /* Sur mobile : défilement horizontal plutôt que retour à la ligne. */
        .subnav {
          flex-wrap: nowrap;
          overflow-x: auto;
          justify-content: flex-start;
          scrollbar-width: none;
          -webkit-overflow-scrolling: touch;
        }
        .subnav::-webkit-scrollbar {
          display: none;
        }
        .subnav-link,
        .subnav-sep {
          flex: none;
        }
      }
      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--font-display);
        font-size: 1.35rem;
        font-weight: 600;
        color: var(--text);
        text-decoration: none;
      }
      .brand-mark {
        color: var(--accent);
      }
      .nav-link {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.16em;
        text-decoration: none;
        color: var(--muted);
      }
      .nav-link:hover {
        color: var(--text);
      }
      main {
        flex: 1;
        max-width: var(--maxw);
        width: 100%;
        margin: 0 auto;
        padding: 1rem 1.5rem 2rem;
      }
      .site-footer {
        max-width: var(--maxw);
        width: 100%;
        margin: 1rem auto 2.5rem;
        padding: 0 1.5rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        color: var(--muted);
        text-align: center;
      }
      .footer-rule {
        width: 4rem;
        height: 1px;
        background: var(--line);
      }
      :focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 3px;
        border-radius: 2px;
      }
    </style>
  </body>
</html>
