---
import cormorantWoff2 from '@fontsource-variable/cormorant/files/cormorant-latin-wght-normal.woff2';
import ebGaramondWoff2 from '@fontsource-variable/eb-garamond/files/eb-garamond-latin-wght-normal.woff2';
import { DEFAULT_LOCALE, type Locale, t } from '../lib/i18n';
import LangToggle from '../components/LangToggle.astro';

interface Props {
  locale: Locale;
  title?: string;
  /** Description SEO propre à la page (défaut : accroche du site). */
  description?: string;
  /** Entrée de nav active : 'home' | 'cartes' | 'grammaire' | 'comment-lire' | 'historique'. */
  active?: string;
}

const { locale, title, description, active = 'home' } = Astro.props;
const pageTitle = title ? `${title} — ${t(locale, 'site.title')}` : t(locale, 'site.title');
const pageDescription = description ?? t(locale, 'site.tagline');

const base = import.meta.env.BASE_URL;
const isDev = import.meta.env.DEV;
const otherLocale: Locale = locale === 'fr' ? 'en' : 'fr';

// URLs absolues (obligatoires pour canonical, hreflang et Open Graph). On dérive
// tout du chemin réellement émis (Astro.url.pathname) en échangeant le segment de
// langue, pour rester aligné sur les slashes de fin réels.
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const otherURL = new URL(Astro.url.pathname.replace(`/${locale}/`, `/${otherLocale}/`), Astro.site);
const defaultURL = new URL(Astro.url.pathname.replace(`/${locale}/`, `/${DEFAULT_LOCALE}/`), Astro.site);
const homeURL = new URL(`${base}${locale}/`, Astro.site);
// Image de partage : une carte iconique (L'Étoile). WebP largement supporté aujourd'hui.
const ogImage = new URL(`${base}cards/major-17.webp`, Astro.site);

// Données structurées : le site comme WebSite (compréhension par les moteurs).
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: t(locale, 'site.title'),
  url: homeURL.href,
  inLanguage: locale,
  description: pageDescription,
};

// Navigation principale. Le slug '' est la home (le tirage).
const NAV = [
  { key: 'home', slug: '', label: 'nav.draw' },
  { key: 'cartes', slug: 'cartes', label: 'nav.cards' },
  { key: 'grammaire', slug: 'grammaire', label: 'nav.grammar' },
  { key: 'comment-lire', slug: 'comment-lire', label: 'nav.method' },
  { key: 'historique', slug: 'historique', label: 'nav.history' },
] as const;

// Polices auto-hébergées en `font-display: optional` + préchargées : la police
// arrive avant le premier rendu et ne « swappe » jamais après coup (pas de glitch).
const fontFace = `
@font-face{font-family:'Cormorant Variable';font-style:normal;font-display:optional;font-weight:300 700;src:url(${cormorantWoff2}) format('woff2-variations');}
@font-face{font-family:'EB Garamond Variable';font-style:normal;font-display:optional;font-weight:400 800;src:url(${ebGaramondWoff2}) format('woff2-variations');}
`;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    {/* Thème appliqué AVANT le rendu (pas de flash) : choix mémorisé, sinon
        préférence système, sinon sombre par défaut. */}
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('theme');
          if (t !== 'light' && t !== 'dark') {
            t = matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
          }
          document.documentElement.dataset.theme = t;
        } catch (e) {
          document.documentElement.dataset.theme = 'dark';
        }
      })();
    </script>
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    <link rel="preload" href={cormorantWoff2} as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href={ebGaramondWoff2} as="font" type="font/woff2" crossorigin="anonymous" />
    <style set:html={fontFace}></style>
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonicalURL.href} />
    <link rel="alternate" hreflang={locale} href={canonicalURL.href} />
    <link rel="alternate" hreflang={otherLocale} href={otherURL.href} />
    <link rel="alternate" hreflang="x-default" href={defaultURL.href} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={locale === 'fr' ? 'fr_FR' : 'en_US'} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:site_name" content={t(locale, 'site.title')} />
    <meta property="og:image" content={ogImage.href} />
    <meta property="og:image:alt" content={t(locale, 'site.title')} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImage.href} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
  </head>
  <body>
    <div class="aura" aria-hidden="true"></div>
    {isDev && (
      <a class="dev-link" href={`${base}fr/annotate`}>⚙ Annotation</a>
    )}
    <header class="site-header">
      <a class="brand" href={`${base}${locale}/`}>
        <span class="brand-mark" aria-hidden="true">✦</span>
        <span>{t(locale, 'site.title')}</span>
      </a>
      <nav id="site-nav" class="site-nav" aria-label={t(locale, 'nav.label')}>
        {NAV.map((item) => (
          <a
            href={`${base}${locale}/${item.slug}`}
            class:list={['nav-link', { 'is-current': active === item.key }]}
            aria-current={active === item.key ? 'page' : undefined}
          >
            {t(locale, item.label)}
          </a>
        ))}
      </nav>
      <div class="header-utils">
        <button type="button" class="theme-toggle" aria-label={t(locale, 'theme.toggle')}>
          <svg class="theme-icon icon-sun" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
            <circle cx="12" cy="12" r="4.2" />
            <path d="M12 2.5v2.4M12 19.1v2.4M4.6 4.6l1.7 1.7M17.7 17.7l1.7 1.7M2.5 12h2.4M19.1 12h2.4M4.6 19.4l1.7-1.7M17.7 6.3l1.7-1.7" />
          </svg>
          <svg class="theme-icon icon-moon" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor">
            <path d="M21 12.8A8.5 8.5 0 1 1 11.2 3a6.8 6.8 0 0 0 9.8 9.8z" />
          </svg>
        </button>
        <LangToggle locale={locale} />
        <button
          type="button"
          class="nav-toggle"
          aria-controls="site-nav"
          aria-expanded="false"
          aria-label={t(locale, 'nav.menu')}
        >
          <span class="nav-toggle-bars" aria-hidden="true"></span>
        </button>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <span class="footer-rule" aria-hidden="true"></span>
      <small>{t(locale, 'footer.credit')}</small>
      <small>
        <a href="https://commons.wikimedia.org/wiki/Category:Rider-Waite_tarot_deck" rel="noopener">
          {t(locale, 'footer.source')}
        </a>
      </small>
    </footer>

    <style is:global>
      :root {
        /* Canaux RGB partagés : permettent des couleurs adaptatives au thème via
           rgb(var(--x) / alpha), et pilotent muted/line/panel automatiquement. */
        --text-rgb: 240 226 196;
        --accent-rgb: 201 164 76;
        --ground: #15101e;
        --ground-2: #241a33;
        --text: #f0e2c4;
        --text-strong: #ffffff;
        --muted: rgb(var(--text-rgb) / 0.62);
        --accent: #c9a44c;
        --accent-2: #b5532f;
        --line: rgb(var(--accent-rgb) / 0.28);
        --panel: rgb(var(--text-rgb) / 0.045);
        --font-display: 'Cormorant Variable', Georgia, 'Times New Roman', serif;
        --font-body: 'EB Garamond Variable', Georgia, 'Times New Roman', serif;
        --maxw: 60rem;
      }
      /* Thème clair « parchemin » : encre profonde sur fond crème, or bronze
         (assez sombre pour contraster). Seuls les tokens changent → tout suit. */
      :root[data-theme='light'] {
        --text-rgb: 43 34 54;
        --accent-rgb: 176 132 40;
        --ground: #f4eede;
        --ground-2: #ece0c8;
        --text: #2b2236;
        --text-strong: #171021;
        --accent: #8a6a15;
        --accent-2: #a5431d;
        color-scheme: light;
      }
      * {
        box-sizing: border-box;
      }
      /* L'attribut hidden doit toujours l'emporter, même sur display:grid/flex. */
      [hidden] {
        display: none !important;
      }
      html {
        color-scheme: dark;
      }
      body {
        margin: 0;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        color: var(--text);
        background: var(--ground);
        background-image:
          radial-gradient(120% 80% at 50% -10%, var(--ground-2) 0%, transparent 60%),
          radial-gradient(60% 50% at 50% 30%, rgb(var(--accent-rgb) / 0.06) 0%, transparent 70%);
        background-attachment: fixed;
        font-family: var(--font-body);
        font-size: 18px;
        line-height: 1.65;
        -webkit-font-smoothing: antialiased;
      }
      .aura {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 0;
        background: radial-gradient(50% 40% at 50% 42%, rgb(var(--accent-rgb) / 0.08), transparent 70%);
        will-change: transform, opacity;
        animation: aura-drift 16s ease-in-out infinite;
      }
      @keyframes aura-drift {
        0%,
        100% {
          transform: translate3d(-1.5%, -1%, 0) scale(1);
          opacity: 0.8;
        }
        50% {
          transform: translate3d(1.5%, 1.5%, 0) scale(1.12);
          opacity: 1;
        }
      }
      @media (prefers-reduced-motion: reduce) {
        .aura {
          animation: none;
        }
      }
      body > * {
        position: relative;
        z-index: 1;
      }
      a {
        color: var(--accent);
      }
      h1,
      h2 {
        font-family: var(--font-display);
        font-weight: 600;
        line-height: 1.05;
        letter-spacing: 0.01em;
      }
      .site-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 0.75rem 1rem;
        max-width: var(--maxw);
        width: 100%;
        margin: 0 auto;
        padding: 1.25rem 1.5rem;
      }
      .header-utils {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.75rem 1.25rem;
      }
      /* Lien vers l'outil d'annotation (dev uniquement) : pastille fixe en bas à
         gauche, hors du flux de l'en-tête et à l'écart de la barre Astro (centrée). */
      .dev-link {
        position: fixed;
        left: 0.75rem;
        bottom: 0.75rem;
        z-index: 40;
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--muted);
        text-decoration: none;
        border: 1px dashed var(--line);
        border-radius: 999px;
        padding: 0.3rem 0.7rem;
        background: var(--ground);
        transition: color 0.2s ease, border-color 0.2s ease;
      }
      .dev-link:hover {
        color: var(--accent);
        border-color: var(--accent);
      }
      /* Bascule de thème : bouton icône rond. On montre l'icône de la CIBLE — en
         sombre le soleil (→ clair), en clair la lune (→ sombre). */
      .theme-toggle {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2.1rem;
        height: 2.1rem;
        padding: 0;
        background: none;
        border: 1px solid var(--line);
        border-radius: 999px;
        color: var(--accent);
        cursor: pointer;
        transition: color 0.2s ease, border-color 0.2s ease;
      }
      .theme-toggle:hover {
        color: var(--text);
        border-color: var(--accent);
      }
      .theme-icon {
        display: none;
      }
      :root[data-theme='dark'] .theme-toggle .icon-sun {
        display: block;
      }
      :root[data-theme='light'] .theme-toggle .icon-moon {
        display: block;
      }
      @media (prefers-reduced-motion: reduce) {
        .theme-toggle {
          transition: none;
        }
      }
      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--font-display);
        font-size: 1.35rem;
        font-weight: 600;
        color: var(--text);
        text-decoration: none;
      }
      .brand-mark {
        color: var(--accent);
      }
      .site-nav {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem 1.15rem;
      }
      .nav-link {
        font-family: var(--font-body);
        font-size: 0.82rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--muted);
        text-decoration: none;
        padding: 0.15rem 0;
        border-bottom: 1px solid transparent;
        transition: color 0.2s ease, border-color 0.2s ease;
      }
      .nav-link:hover {
        color: var(--text);
      }
      .nav-link.is-current {
        color: var(--accent);
        border-bottom-color: var(--accent);
      }
      /* Bouton hamburger : masqué sur desktop, révélé sous le breakpoint mobile. */
      .nav-toggle {
        display: none;
        appearance: none;
        width: 2.5rem;
        height: 2.5rem;
        padding: 0;
        align-items: center;
        justify-content: center;
        background: none;
        border: 1px solid var(--line);
        border-radius: 0.45rem;
        color: var(--text);
        cursor: pointer;
      }
      .nav-toggle-bars,
      .nav-toggle-bars::before,
      .nav-toggle-bars::after {
        content: '';
        display: block;
        width: 1.15rem;
        height: 2px;
        border-radius: 2px;
        background: currentColor;
        transition:
          transform 0.25s ease,
          opacity 0.2s ease;
      }
      .nav-toggle-bars {
        position: relative;
      }
      .nav-toggle-bars::before {
        position: absolute;
        left: 0;
        top: -6px;
      }
      .nav-toggle-bars::after {
        position: absolute;
        left: 0;
        top: 6px;
      }
      /* État ouvert : les barres se croisent en « ✕ ». */
      .site-header.is-open .nav-toggle-bars {
        background: transparent;
      }
      .site-header.is-open .nav-toggle-bars::before {
        transform: translateY(6px) rotate(45deg);
      }
      .site-header.is-open .nav-toggle-bars::after {
        transform: translateY(-6px) rotate(-45deg);
      }
      @media (max-width: 40rem) {
        .nav-toggle {
          display: inline-flex;
        }
        /* La nav passe en panneau déroulant, sur sa propre ligne pleine largeur. */
        .site-nav {
          order: 3;
          flex-basis: 100%;
          flex-direction: column;
          gap: 0;
          overflow: hidden;
          max-height: 0;
          opacity: 0;
          visibility: hidden;
          transition:
            max-height 0.28s ease,
            opacity 0.2s ease,
            visibility 0.28s;
        }
        .site-header.is-open .site-nav {
          max-height: 22rem;
          opacity: 1;
          visibility: visible;
        }
        .site-nav .nav-link {
          padding: 0.7rem 0.15rem;
          border-bottom: 1px solid var(--line);
        }
        .site-nav .nav-link:last-child {
          border-bottom: none;
        }
      }
      @media (prefers-reduced-motion: reduce) {
        .nav-toggle-bars,
        .nav-toggle-bars::before,
        .nav-toggle-bars::after,
        .site-nav {
          transition: none;
        }
      }
      main {
        flex: 1;
        max-width: var(--maxw);
        width: 100%;
        margin: 0 auto;
        padding: 1rem 1.5rem 2rem;
      }
      .site-footer {
        max-width: var(--maxw);
        width: 100%;
        margin: 1rem auto 2.5rem;
        padding: 0 1.5rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.6rem;
        color: var(--muted);
        text-align: center;
        font-size: 0.85rem;
      }
      .footer-rule {
        width: 4rem;
        height: 1px;
        background: var(--line);
        margin-bottom: 0.4rem;
      }
      :focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 3px;
        border-radius: 2px;
      }
      /* Titre des pages de référence (Cartes / Grammaire / Comment lire). */
      .page-title {
        font-family: var(--font-display);
        font-weight: 600;
        line-height: 1.05;
        font-size: clamp(2rem, 4vw, 2.6rem);
        text-align: center;
        margin: 0.5rem 0 2rem;
      }
    </style>

    <script>
      // Bascule de thème (clair/sombre) : mémorisée dans localStorage. L'application
      // avant rendu est faite par le script inline du <head> (anti-flash).
      const themeToggle = document.querySelector<HTMLButtonElement>('.theme-toggle');
      themeToggle?.addEventListener('click', () => {
        const next = document.documentElement.dataset.theme === 'light' ? 'dark' : 'light';
        document.documentElement.dataset.theme = next;
        try {
          localStorage.setItem('theme', next);
        } catch {
          /* stockage indisponible : la bascule reste valable pour la session */
        }
      });

      // Menu hamburger (mobile) : ouvre/ferme le panneau de navigation.
      const header = document.querySelector<HTMLElement>('.site-header');
      const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
      const nav = document.getElementById('site-nav');

      if (header && toggle && nav) {
        const setOpen = (open: boolean) => {
          header.classList.toggle('is-open', open);
          toggle.setAttribute('aria-expanded', String(open));
        };

        toggle.addEventListener('click', () => {
          setOpen(!header.classList.contains('is-open'));
        });

        // Fermer sur clic d'un lien de la nav.
        nav.addEventListener('click', (e) => {
          if ((e.target as HTMLElement).closest('.nav-link')) setOpen(false);
        });

        // Fermer sur Échap (et redonner le focus au bouton).
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && header.classList.contains('is-open')) {
            setOpen(false);
            toggle.focus();
          }
        });

        // Fermer sur clic en dehors de l'en-tête.
        document.addEventListener('click', (e) => {
          if (header.classList.contains('is-open') && !header.contains(e.target as Node)) {
            setOpen(false);
          }
        });
      }
    </script>
  </body>
</html>
