---
import { type Locale, t } from '../lib/i18n';
import { cards, SUIT_NAMES, SUIT_ELEMENTS } from '../data/cards';
import type { Suit } from '../lib/types';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const base = import.meta.env.BASE_URL;

// Groupes ordonnés : majeurs, puis les 4 enseignes.
const SUIT_ORDER: Suit[] = ['wands', 'cups', 'swords', 'pentacles'];
const galleryGroups = [
  { heading: t(locale, 'gallery.majors'), cards: cards.filter((c) => c.arcana === 'major') },
  ...SUIT_ORDER.map((suit) => ({
    heading: `${SUIT_NAMES[suit][locale]} · ${SUIT_ELEMENTS[suit][locale]}`,
    cards: cards.filter((c) => c.suit === suit),
  })),
];
---

<div class="gallery">
  {galleryGroups.map((group) => (
    <div class="gallery-group">
      <h3>{group.heading}</h3>
      <div class="gallery-grid">
        {group.cards.map((card) => (
          <a class="gallery-card" href={`${base}${locale}/#${card.id}`} title={card.name[locale]}>
            <img src={`${base}cards/${card.id}-thumb.webp`} alt={card.name[locale]} width="110" height="192" loading="lazy" />
            <span class="gallery-name">{card.name[locale]}</span>
          </a>
        ))}
      </div>
    </div>
  ))}
</div>

<style>
  .gallery {
    display: grid;
    gap: 2rem;
  }
  .gallery-group h3 {
    margin: 0 0 0.9rem;
    font-size: 0.8rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--accent);
    border-bottom: 1px solid var(--line);
    padding-bottom: 0.5rem;
  }
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(84px, 1fr));
    gap: 0.75rem;
  }
  /* La carte pointe vers la home avec un permalien (#id) : la home l'y révèle. */
  .gallery-card {
    position: relative;
    display: block;
    border-radius: 8px;
    overflow: hidden;
    line-height: 0;
    text-decoration: none;
    color: inherit;
    box-shadow: 0 0 0 1px var(--line);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .gallery-card img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 1100 / 1920;
    object-fit: cover;
  }
  /* Légende au survol / focus. */
  .gallery-name {
    position: absolute;
    inset: auto 0 0 0;
    padding: 1.4rem 0.4rem 0.4rem;
    font-size: 0.72rem;
    line-height: 1.2;
    text-align: center;
    color: var(--text);
    background: linear-gradient(to top, rgba(21, 16, 30, 0.95), transparent);
    opacity: 0;
    transition: opacity 0.18s ease;
    pointer-events: none;
  }
  .gallery-card:hover .gallery-name,
  .gallery-card:focus-visible .gallery-name {
    opacity: 1;
  }
  .gallery-card:hover,
  .gallery-card:focus-visible {
    transform: translateY(-3px);
    box-shadow: 0 8px 22px rgba(0, 0, 0, 0.5), 0 0 0 1px var(--accent),
      0 0 18px rgba(201, 164, 76, 0.25);
    outline: none;
  }
  @media (prefers-reduced-motion: reduce) {
    .gallery-card,
    .gallery-name {
      transition: none;
    }
  }
</style>
