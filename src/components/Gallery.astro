---
import { type Locale, t } from '../lib/i18n';
import { cards, SUIT_NAMES, SUIT_ELEMENTS } from '../data/cards';
import type { Suit } from '../lib/types';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const base = import.meta.env.BASE_URL;

// Couleur d'accent par enseigne (cohérente avec la grammaire) ; majeurs en or.
const ELEM_COLOR: Record<Suit, string> = {
  wands: '#cf6b3d',
  cups: '#5b96b3',
  swords: '#b0a0d8',
  pentacles: '#8ba85a',
};

const SUIT_ORDER: Suit[] = ['wands', 'cups', 'swords', 'pentacles'];

// Groupes ordonnés : majeurs, puis les 4 enseignes. `arcana` sert au filtre
// (major / <suit>) ; `short` alimente la barre de saut.
const galleryGroups = [
  {
    id: 'g-major',
    arcana: 'major',
    color: 'var(--accent)',
    heading: t(locale, 'gallery.majors'),
    short: t(locale, 'gallery.filterMajors'),
    cards: cards.filter((c) => c.arcana === 'major'),
  },
  ...SUIT_ORDER.map((suit) => ({
    id: `g-${suit}`,
    arcana: suit,
    color: ELEM_COLOR[suit],
    heading: `${SUIT_NAMES[suit][locale]} · ${SUIT_ELEMENTS[suit][locale]}`,
    short: SUIT_NAMES[suit][locale],
    cards: cards.filter((c) => c.suit === suit),
  })),
];

const filters = [
  { key: 'all', label: t(locale, 'gallery.filterAll') },
  { key: 'major', label: t(locale, 'gallery.filterMajors') },
  { key: 'minor', label: t(locale, 'gallery.filterMinors') },
];
---

<div class="gallery" data-locale={locale}>
  <div class="gallery-controls">
    <div class="gallery-filters" role="group" aria-label={t(locale, 'gallery.filterAll')}>
      {filters.map((f) => (
        <button type="button" class:list={['gallery-filter', { 'is-on': f.key === 'all' }]} data-filter={f.key}>
          {f.label}
        </button>
      ))}
    </div>
    <input
      type="search"
      class="gallery-search"
      id="gallery-search"
      placeholder={t(locale, 'gallery.search')}
      aria-label={t(locale, 'gallery.search')}
      autocomplete="off"
    />
  </div>

  <nav class="gallery-jump" aria-label={t(locale, 'gallery.jump')}>
    {galleryGroups.map((g) => (
      <a class="gallery-jump-link" href={`#${g.id}`} data-arcana={g.arcana}>{g.short}</a>
    ))}
  </nav>

  <p class="gallery-none" id="gallery-none" hidden>{t(locale, 'gallery.none')}</p>

  {galleryGroups.map((group) => (
    <section id={group.id} class="gallery-group" data-arcana={group.arcana} style={`--elem: ${group.color}`} aria-labelledby={`h-${group.id}`}>
      <h2 id={`h-${group.id}`} class="gallery-h">{group.heading}</h2>
      <ul class="gallery-grid">
        {group.cards.map((card) => (
          <li class="gallery-cell" data-name={card.name[locale]}>
            <a class="gallery-card" href={`${base}${locale}/#${card.id}`} data-id={card.id} title={card.name[locale]}>
              <img src={`${base}cards/${card.id}-thumb.webp`} alt={card.name[locale]} width="110" height="192" loading="lazy" decoding="async" />
            </a>
            <span class="gallery-caption">{card.name[locale]}</span>
          </li>
        ))}
      </ul>
    </section>
  ))}

  <!-- Aperçu en place : rempli et piloté en JS (progressive enhancement :
       sans JS, chaque carte reste un lien vers la home). -->
  <div class="lightbox" id="lightbox" hidden>
    <div class="lb-backdrop" data-close></div>
    <div class="lb-panel" role="dialog" aria-modal="true" aria-labelledby="lb-name">
      <button type="button" class="lb-close" data-close aria-label={t(locale, 'gallery.close')}>✕</button>
      <div class="lb-img">
        <img id="lb-img" alt="" width="300" height="524" />
      </div>
      <div class="lb-body">
        <p class="lb-meta" id="lb-meta"></p>
        <h3 class="lb-name" id="lb-name"></h3>
        <p class="lb-orient" id="lb-orient"></p>
        <div class="lb-keywords" id="lb-keywords"></div>
        <p class="lb-meaning" id="lb-meaning"></p>
        <div class="lb-actions">
          <button type="button" class="lb-btn" id="lb-orient-btn"></button>
          <a class="lb-btn lb-home" id="lb-home">{t(locale, 'gallery.viewOnHome')}</a>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  import { ui, type Locale } from '../lib/i18n';
  import { cards, SUIT_NAMES, SUIT_ELEMENTS, MAJOR_CORRESPONDENCE } from '../data/cards';
  import type { Card, Orientation } from '../lib/types';

  const root = document.querySelector<HTMLElement>('.gallery')!;
  const locale = root.dataset.locale as Locale;
  const T = ui[locale];
  const BASE = import.meta.env.BASE_URL;

  const byId = new Map(cards.map((c) => [c.id, c]));
  const ROMAN = ['0', 'I', 'II', 'III', 'IV', 'V', 'VI', 'VII', 'VIII', 'IX', 'X',
    'XI', 'XII', 'XIII', 'XIV', 'XV', 'XVI', 'XVII', 'XVIII', 'XIX', 'XX', 'XXI'];

  // ---- Filtres + recherche ----
  const filterBtns = [...root.querySelectorAll<HTMLButtonElement>('.gallery-filter')];
  const search = root.querySelector<HTMLInputElement>('#gallery-search')!;
  const noneEl = root.querySelector<HTMLElement>('#gallery-none')!;
  const sections = [...root.querySelectorAll<HTMLElement>('.gallery-group')];
  let filter = 'all';

  // Normalise pour une recherche insensible aux accents et à la casse.
  const norm = (s: string) => s.normalize('NFD').replace(/\p{Diacritic}/gu, '').toLowerCase();

  function applyFilter() {
    const q = norm(search.value.trim());
    let anyVisible = false;
    for (const section of sections) {
      const arc = section.dataset.arcana!;
      const isMajor = arc === 'major';
      const arcMatch = filter === 'all' || (filter === 'major' && isMajor) || (filter === 'minor' && !isMajor);
      let sectionVisible = false;
      for (const cell of section.querySelectorAll<HTMLElement>('.gallery-cell')) {
        const show = arcMatch && (!q || norm(cell.dataset.name ?? '').includes(q));
        cell.hidden = !show;
        if (show) sectionVisible = true;
      }
      section.hidden = !sectionVisible;
      if (sectionVisible) anyVisible = true;
    }
    noneEl.hidden = anyVisible;
  }

  for (const btn of filterBtns) {
    btn.addEventListener('click', () => {
      filter = btn.dataset.filter!;
      filterBtns.forEach((b) => b.classList.toggle('is-on', b === btn));
      applyFilter();
    });
  }
  search.addEventListener('input', applyFilter);

  // Saut vers une enseigne : réinitialise le filtre et la recherche pour que la
  // cible soit visible, puis laisse l'ancre défiler.
  for (const link of root.querySelectorAll<HTMLAnchorElement>('.gallery-jump-link')) {
    link.addEventListener('click', () => {
      filter = 'all';
      filterBtns.forEach((b) => b.classList.toggle('is-on', b.dataset.filter === 'all'));
      search.value = '';
      applyFilter();
    });
  }

  // ---- Aperçu en place (lightbox) ----
  const lightbox = root.querySelector<HTMLElement>('#lightbox')!;
  const lbImg = root.querySelector<HTMLImageElement>('#lb-img')!;
  const lbMeta = root.querySelector<HTMLElement>('#lb-meta')!;
  const lbName = root.querySelector<HTMLElement>('#lb-name')!;
  const lbOrient = root.querySelector<HTMLElement>('#lb-orient')!;
  const lbKeywords = root.querySelector<HTMLElement>('#lb-keywords')!;
  const lbMeaning = root.querySelector<HTMLElement>('#lb-meaning')!;
  const lbOrientBtn = root.querySelector<HTMLButtonElement>('#lb-orient-btn')!;
  const lbHome = root.querySelector<HTMLAnchorElement>('#lb-home')!;
  const lbClose = root.querySelector<HTMLButtonElement>('.lb-close')!;

  let lbCard: Card | null = null;
  let lbView: Orientation = 'upright';
  let lastFocused: HTMLElement | null = null;

  function metaText(card: Card): string {
    if (card.arcana === 'major') {
      const num = card.number > 0 ? ROMAN[card.number] : '0';
      const corr = MAJOR_CORRESPONDENCE[card.number]?.[locale];
      return corr ? `${T['meta.major']} · ${num} · ${corr}` : `${T['meta.major']} · ${num}`;
    }
    const suit = card.suit!;
    return `${T['meta.minor']} · ${SUIT_NAMES[suit][locale]} · ${SUIT_ELEMENTS[suit][locale]}`;
  }

  function renderLightbox() {
    if (!lbCard) return;
    const card = lbCard;
    const reversed = lbView === 'reversed';
    lbImg.src = `${BASE}cards/${card.image}`;
    lbImg.alt = card.name[locale];
    lbImg.classList.toggle('is-reversed', reversed);
    lbMeta.textContent = metaText(card);
    lbName.textContent = card.name[locale];
    lbOrient.textContent = reversed ? T['card.reversed'] : T['card.upright'];
    lbOrient.classList.toggle('is-reversed', reversed);

    lbKeywords.replaceChildren();
    if (card.content) {
      for (const word of card.content.keywords[lbView][locale]) {
        const chip = document.createElement('span');
        chip.className = 'lb-chip';
        chip.textContent = word;
        lbKeywords.appendChild(chip);
      }
      lbMeaning.textContent = card.content.meaning[lbView][locale];
      lbOrientBtn.hidden = false;
      lbOrientBtn.textContent = reversed ? T['card.seeUpright'] : T['card.seeReversed'];
    } else {
      lbMeaning.textContent = T['card.noContent'];
      lbOrientBtn.hidden = true;
    }
    lbHome.href = `${BASE}${locale}/#${card.id}`;
  }

  function openLightbox(card: Card, trigger: HTMLElement) {
    lbCard = card;
    lbView = 'upright';
    lastFocused = trigger;
    renderLightbox();
    lightbox.hidden = false;
    document.body.style.overflow = 'hidden';
    lbClose.focus();
  }

  function closeLightbox() {
    lightbox.hidden = true;
    document.body.style.overflow = '';
    lastFocused?.focus();
    lastFocused = null;
  }

  // Clic sur une carte → aperçu (on intercepte le lien vers la home).
  root.addEventListener('click', (e) => {
    const link = (e.target as HTMLElement).closest<HTMLAnchorElement>('.gallery-card');
    if (!link) return;
    e.preventDefault();
    const card = byId.get(link.dataset.id ?? '');
    if (card) openLightbox(card, link);
  });

  lbOrientBtn.addEventListener('click', () => {
    lbView = lbView === 'upright' ? 'reversed' : 'upright';
    renderLightbox();
  });

  for (const el of lightbox.querySelectorAll<HTMLElement>('[data-close]')) {
    el.addEventListener('click', closeLightbox);
  }
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !lightbox.hidden) closeLightbox();
  });
  // Piège de focus minimal : Tab boucle dans le panneau tant qu'il est ouvert.
  lightbox.addEventListener('keydown', (e) => {
    if (e.key !== 'Tab' || lightbox.hidden) return;
    const focusables = [...lightbox.querySelectorAll<HTMLElement>('button, a[href]')].filter((el) => !el.hidden);
    if (!focusables.length) return;
    const first = focusables[0];
    const last = focusables[focusables.length - 1];
    if (e.shiftKey && document.activeElement === first) {
      e.preventDefault();
      last.focus();
    } else if (!e.shiftKey && document.activeElement === last) {
      e.preventDefault();
      first.focus();
    }
  });
</script>

<style>
  .gallery {
    display: grid;
    gap: 1.5rem;
  }

  /* ---- Barre de contrôles : filtres + recherche ---- */
  .gallery-controls {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem 1rem;
  }
  .gallery-filters {
    display: flex;
    gap: 0.3rem;
  }
  .gallery-filter {
    font-family: var(--font-body);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
    background: transparent;
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.35rem 0.85rem;
    cursor: pointer;
    transition: color 0.2s ease, border-color 0.2s ease, background-color 0.2s ease;
  }
  .gallery-filter:hover {
    color: var(--text);
  }
  .gallery-filter.is-on {
    color: var(--text);
    border-color: var(--accent);
    background: rgba(201, 164, 76, 0.16);
  }
  .gallery-filter:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .gallery-search {
    flex: 1 1 12rem;
    max-width: 20rem;
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--text);
    background: rgba(240, 226, 196, 0.04);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.45rem 1rem;
  }
  .gallery-search::placeholder {
    color: var(--muted);
  }
  .gallery-search:focus-visible {
    outline: none;
    border-color: var(--accent);
    background: rgba(201, 164, 76, 0.06);
  }

  /* ---- Barre de saut vers une enseigne ---- */
  .gallery-jump {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.5rem;
  }
  .gallery-jump-link {
    font-family: var(--font-body);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
    text-decoration: none;
    padding: 0.28rem 0.7rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .gallery-jump-link:hover {
    color: var(--text);
    border-color: var(--accent);
  }

  .gallery-none {
    text-align: center;
    color: var(--muted);
    font-style: italic;
    margin: 3rem auto;
  }

  /* ---- Groupes ---- */
  .gallery-group {
    scroll-margin-top: 1.5rem;
    margin-top: 1rem;
  }
  .gallery-h {
    margin: 0 0 0.9rem;
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--elem);
    border-bottom: 1px solid color-mix(in srgb, var(--elem) 40%, var(--line));
    padding-bottom: 0.5rem;
  }
  .gallery-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(88px, 1fr));
    gap: 0.9rem 0.75rem;
  }
  .gallery-cell {
    display: grid;
    gap: 0.35rem;
    grid-template-rows: auto 1fr;
  }
  .gallery-card {
    display: block;
    border-radius: 8px;
    overflow: hidden;
    line-height: 0;
    box-shadow: 0 0 0 1px var(--line);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .gallery-card img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 1100 / 1920;
    object-fit: cover;
  }
  .gallery-card:hover,
  .gallery-card:focus-visible {
    transform: translateY(-3px);
    box-shadow: 0 8px 22px rgba(0, 0, 0, 0.5), 0 0 0 1px var(--accent),
      0 0 18px rgba(201, 164, 76, 0.25);
    outline: none;
  }
  /* Nom toujours visible (indispensable au tactile, sans survol). */
  .gallery-caption {
    font-size: 0.72rem;
    line-height: 1.25;
    text-align: center;
    color: var(--muted);
  }

  /* ---- Aperçu en place ---- */
  .lightbox[hidden] {
    display: none;
  }
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 50;
    display: grid;
    place-items: center;
    padding: 1.5rem;
  }
  .lb-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(10, 7, 16, 0.78);
    backdrop-filter: blur(3px);
  }
  .lb-panel {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 1.5rem;
    width: min(44rem, 100%);
    max-height: min(88vh, 44rem);
    overflow-y: auto;
    padding: 1.5rem;
    border: 1px solid var(--line);
    border-radius: 16px;
    background: linear-gradient(var(--panel), var(--panel)), var(--ground);
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.6), 0 0 0 1px var(--line);
    animation: lb-in 0.22s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  @keyframes lb-in {
    from {
      opacity: 0;
      transform: translateY(8px) scale(0.98);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .lb-panel {
      animation: none;
    }
  }
  .lb-close {
    position: absolute;
    top: 0.6rem;
    right: 0.6rem;
    width: 2rem;
    height: 2rem;
    display: grid;
    place-items: center;
    border: 1px solid transparent;
    border-radius: 999px;
    background: transparent;
    color: var(--muted);
    font-size: 0.85rem;
    cursor: pointer;
    transition: color 0.2s ease, background 0.2s ease;
  }
  .lb-close:hover,
  .lb-close:focus-visible {
    color: var(--accent-2);
    background: rgba(181, 83, 47, 0.14);
    outline: none;
  }
  .lb-img {
    width: min(190px, 40vw);
    aspect-ratio: 1100 / 1920;
    perspective: 1000px;
  }
  .lb-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 10px;
    box-shadow: 0 14px 40px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(201, 164, 76, 0.5);
    transition: transform 0.35s cubic-bezier(0.4, 0.15, 0.2, 1);
  }
  .lb-img img.is-reversed {
    transform: rotate(180deg);
  }
  @media (prefers-reduced-motion: reduce) {
    .lb-img img {
      transition: none;
    }
  }
  .lb-body {
    display: grid;
    gap: 0.55rem;
    align-content: start;
  }
  .lb-meta {
    margin: 0;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--accent);
  }
  .lb-name {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    font-weight: 600;
    line-height: 1.1;
    color: var(--text);
  }
  .lb-orient {
    margin: 0;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--muted);
  }
  .lb-orient.is-reversed {
    color: var(--accent-2);
  }
  .lb-keywords {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 0.1rem 0;
  }
  .lb-keywords :global(.lb-chip) {
    font-size: 0.78rem;
    padding: 0.2rem 0.65rem;
    border-radius: 999px;
    border: 1px solid var(--line);
    color: var(--text);
  }
  .lb-meaning {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--text);
  }
  .lb-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 0.4rem;
  }
  .lb-btn {
    font-family: var(--font-body);
    font-size: 0.76rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 0.4rem 0.9rem;
    background: transparent;
    color: var(--accent);
    border: 1px solid var(--line);
    border-radius: 999px;
    cursor: pointer;
    text-decoration: none;
    transition: border-color 0.2s ease, background-color 0.2s ease;
  }
  .lb-btn:hover,
  .lb-btn:focus-visible {
    border-color: var(--accent);
    background: rgba(201, 164, 76, 0.1);
    outline: none;
  }
  /* Empilement sous une certaine largeur : image au-dessus, texte dessous. */
  @media (max-width: 34rem) {
    .lb-panel {
      grid-template-columns: 1fr;
      justify-items: center;
      text-align: center;
    }
    .lb-img {
      width: min(160px, 45vw);
    }
    .lb-keywords,
    .lb-actions {
      justify-content: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .gallery-card {
      transition: none;
    }
  }
</style>
