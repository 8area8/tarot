---
export interface ListItem {
  href: string;
  name: string;
  desc: string;
  icon: 'profil' | 'acteurs' | 'questions' | 'action' | 'confrontation' | 'tarot' | 'coin';
}
export interface ListGroup {
  title?: string;
  items: ListItem[];
}
interface Props {
  groups: ListGroup[];
}

const { groups } = Astro.props;

const EMBLEMS: Record<ListItem['icon'], string> = {
  profil: `<svg viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="2">
    <path d="M40 12 L64 60 H16 Z" />
    <path d="M14 40 H30" stroke-width="1.6" />
    <path d="M46 44 l18 -7M47 50 l17 0M46 56 l18 7" stroke-width="1.6" opacity="0.9" />
  </svg>`,
  acteurs: `<svg viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="2">
    <circle cx="30" cy="30" r="9" />
    <path d="M15 58 a15 15 0 0 1 30 0" stroke-linecap="round" />
    <circle cx="52" cy="34" r="8" opacity="0.65" />
    <path d="M41 60 a12 12 0 0 1 24 0" opacity="0.65" stroke-linecap="round" />
  </svg>`,
  questions: `<svg viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="2">
    <circle cx="40" cy="40" r="28" />
    <path d="M31 32 a9 9 0 1 1 13 8 c-3 2 -4 4 -4 7" stroke-linecap="round" />
    <circle cx="40" cy="57" r="1.8" fill="currentColor" stroke="none" />
  </svg>`,
  action: `<svg viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="2">
    <circle cx="40" cy="40" r="28" />
    <path d="M40 55 V27 M30 37 l10 -10 l10 10" stroke-linecap="round" stroke-linejoin="round" />
  </svg>`,
  confrontation: `<svg viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="2">
    <circle cx="40" cy="40" r="28" />
    <path d="M32 30 l-10 10 l10 10 M48 30 l10 10 l-10 10" stroke-linecap="round" stroke-linejoin="round" />
    <line x1="40" y1="22" x2="40" y2="58" opacity="0.5" />
  </svg>`,
  tarot: `<svg viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="2">
    <rect x="24" y="9" width="32" height="54" rx="5" />
    <path d="M40 22 L43.5 36.5 L58 40 L43.5 43.5 L40 58 L36.5 43.5 L22 40 L36.5 36.5 Z" fill="currentColor" stroke="none" />
  </svg>`,
  coin: `<svg viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="2">
    <circle cx="40" cy="40" r="26" />
    <circle cx="33" cy="35" r="6.5" fill="currentColor" stroke="none" />
    <path d="M33 24v-5M33 51v5M22 35h-5M44 35h5M25.4 27.4l-3.5-3.5M40.6 27.4l3.5-3.5" stroke-width="1.6" />
    <path d="M52 42a11 11 0 1 1-9.8-11 8.5 8.5 0 1 0 9.8 11Z" fill="currentColor" stroke="none" />
  </svg>`,
};
---

<div class="listing">
  {
    groups.map((group) => (
      <section class="listing-group">
        {group.title && <h2 class="listing-title">{group.title}</h2>}
        <ul class="listing-items">
          {group.items.map((it) => (
            <li>
              <a class="listing-row" href={it.href}>
                <span class="row-emblem" aria-hidden="true" set:html={EMBLEMS[it.icon]} />
                <span class="row-text">
                  <span class="row-name">{it.name}</span>
                  <span class="row-desc">{it.desc}</span>
                </span>
                <span class="row-arrow" aria-hidden="true">→</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))
  }
</div>

<style>
  .listing {
    display: grid;
    gap: 2.25rem;
    max-width: 40rem;
    width: 100%;
    margin: 0 auto;
  }
  .listing-group {
    display: grid;
    gap: 0.65rem;
  }
  .listing-title {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    margin: 0 0 0.15rem;
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--accent);
  }
  .listing-title::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--line);
  }
  .listing-items {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.6rem;
  }
  .listing-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.9rem 1.1rem;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: var(--panel);
    text-decoration: none;
    color: var(--text);
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
  }
  .listing-row:hover,
  .listing-row:focus-visible {
    transform: translateX(4px);
    border-color: var(--accent);
    background: rgba(201, 164, 76, 0.06);
    box-shadow: 0 12px 30px -14px rgba(0, 0, 0, 0.7), 0 0 22px -10px var(--accent);
  }
  .row-emblem {
    flex: none;
    width: 2.4rem;
    height: 2.4rem;
    color: var(--accent);
  }
  .row-emblem :global(svg) {
    width: 100%;
    height: 100%;
    display: block;
  }
  .row-text {
    display: grid;
    gap: 0.1rem;
    flex: 1;
    min-width: 0;
  }
  .row-name {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 600;
    line-height: 1.1;
  }
  .row-desc {
    color: var(--muted);
    font-size: 0.92rem;
  }
  .row-arrow {
    flex: none;
    color: var(--accent);
    font-size: 1.1rem;
    opacity: 0.55;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .listing-row:hover .row-arrow,
  .listing-row:focus-visible .row-arrow {
    transform: translateX(4px);
    opacity: 1;
  }
  @media (prefers-reduced-motion: reduce) {
    .listing-row,
    .row-arrow {
      transition: none;
    }
  }
</style>
