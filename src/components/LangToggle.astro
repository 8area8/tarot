---
import { type Locale, t } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const other: Locale = locale === 'fr' ? 'en' : 'fr';
// Conserve la page courante en changeant de langue (/fr/cartes ↔ /en/cartes).
const base = import.meta.env.BASE_URL;
const sub = Astro.url.pathname.replace(base, '').replace(/^(fr|en)\/?/, '');
const href = `${base}${other}/${sub}`;
---

<a class="lang-toggle" href={href} hreflang={other} rel="alternate">
  {t(locale, 'lang.switch')}
</a>

<style>
  .lang-toggle {
    font-family: var(--font-body);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    text-decoration: none;
    color: var(--accent);
    padding: 0.35rem 0.85rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    transition: border-color 0.2s ease, background-color 0.2s ease;
  }
  .lang-toggle:hover {
    border-color: var(--accent);
    background: rgba(201, 164, 76, 0.08);
  }
</style>
