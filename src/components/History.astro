---
import { type Locale, t } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<div class="history" data-locale={locale}>
  <div class="history-controls" id="history-controls" hidden>
    <div class="history-toolbar">
      <input
        type="search"
        class="history-search"
        id="history-search"
        placeholder={t(locale, 'history.search')}
        aria-label={t(locale, 'history.search')}
        autocomplete="off"
      />
      <div class="history-actions">
        <button type="button" id="history-export" class="history-action">{t(locale, 'history.export')}</button>
        <button type="button" id="history-clear" class="history-action history-clear">{t(locale, 'history.clear')}</button>
      </div>
    </div>
    <div class="history-filterrow">
      <div class="history-filters" role="group" aria-label={t(locale, 'history.filterAll')}>
        <button type="button" class="history-filter is-on" data-kind="all">{t(locale, 'history.filterAll')}</button>
        <button type="button" class="history-filter" data-kind="single">{t(locale, 'spread.single')}</button>
        <button type="button" class="history-filter" data-kind="two">{t(locale, 'spread.two')}</button>
        <button type="button" class="history-filter" data-kind="three">{t(locale, 'spread.three')}</button>
      </div>
      <div class="history-tags" id="history-tags" hidden></div>
    </div>
  </div>

  <p class="history-empty" id="history-empty" hidden>
    <span>{t(locale, 'history.empty')}</span>
    <a class="history-cta" href={`${base}${locale}/`}>{t(locale, 'action.draw')} →</a>
  </p>
  <p class="history-none" id="history-none" hidden>{t(locale, 'history.none')}</p>

  <div class="history-list" id="history-list"></div>
</div>

<script>
  import { ui, type Locale } from '../lib/i18n';
  import { cards } from '../data/cards';
  import { readHistory, removeAt, clearHistory, updateAt, hashFor, type SpreadKind } from '../lib/history';

  const root = document.querySelector<HTMLElement>('.history')!;
  const locale = root.dataset.locale as Locale;
  const T = ui[locale];
  const BASE = import.meta.env.BASE_URL;

  const controlsEl = document.querySelector<HTMLElement>('#history-controls')!;
  const filterBtns = [...root.querySelectorAll<HTMLButtonElement>('.history-filter')];
  const searchEl = document.querySelector<HTMLInputElement>('#history-search')!;
  const tagsBar = document.querySelector<HTMLElement>('#history-tags')!;
  const listEl = document.querySelector<HTMLElement>('#history-list')!;
  const emptyEl = document.querySelector<HTMLElement>('#history-empty')!;
  const noneEl = document.querySelector<HTMLElement>('#history-none')!;
  const clearBtn = document.querySelector<HTMLButtonElement>('#history-clear')!;
  const exportBtn = document.querySelector<HTMLButtonElement>('#history-export')!;

  const byId = new Map(cards.map((c) => [c.id, c]));

  const KIND_LABEL: Record<SpreadKind, string> = {
    single: T['spread.single'],
    two: T['spread.two'],
    three: T['spread.three'],
  };

  const intl = locale === 'fr' ? 'fr-FR' : 'en-US';
  const dayFmt = new Intl.DateTimeFormat(intl, { dateStyle: 'long' });
  const timeFmt = new Intl.DateTimeFormat(intl, { timeStyle: 'short' });
  const fullFmt = new Intl.DateTimeFormat(intl, { dateStyle: 'medium', timeStyle: 'short' });

  const norm = (s: string) => s.normalize('NFD').replace(/\p{Diacritic}/gu, '').toLowerCase();

  // ---- État de filtrage / d'édition ----
  let kindFilter: 'all' | SpreadKind = 'all';
  let query = '';
  let activeTag: string | null = null;
  let openEdit: number | null = null; // index (dans l'ordre de readHistory) de l'entrée annotée
  let refocusTag: number | null = null; // réoriente le focus après ajout d'un tag
  let confirmDelete: number | null = null; // index de l'entrée en attente de confirmation de retrait

  // En-tête de jour : « Aujourd'hui », « Hier », sinon la date longue.
  function dayBucket(ts: number): string {
    const startOf = (d: Date) => new Date(d.getFullYear(), d.getMonth(), d.getDate()).getTime();
    const diff = Math.round((startOf(new Date()) - startOf(new Date(ts))) / 86400000);
    if (diff <= 0) return T['history.today'];
    if (diff === 1) return T['history.yesterday'];
    return dayFmt.format(new Date(ts));
  }

  // ---- Barre de tags (filtre) ----
  function renderTagBar(all: ReturnType<typeof readHistory>) {
    const counts = new Map<string, number>();
    for (const e of all) for (const tag of e.tags ?? []) counts.set(tag, (counts.get(tag) ?? 0) + 1);
    const tags = [...counts.keys()].sort((a, b) => a.localeCompare(b, intl));
    if (activeTag && !counts.has(activeTag)) activeTag = null;

    tagsBar.replaceChildren();
    tagsBar.hidden = tags.length === 0;
    for (const tag of tags) {
      const b = document.createElement('button');
      b.type = 'button';
      b.className = 'history-tagfilter';
      b.classList.toggle('is-on', activeTag === tag);
      b.textContent = `#${tag} · ${counts.get(tag)}`;
      b.addEventListener('click', () => {
        activeTag = activeTag === tag ? null : tag;
        render();
      });
      tagsBar.appendChild(b);
    }
  }

  // ---- Éditeur (note + tags) d'une entrée ----
  function buildEditor(entry: ReturnType<typeof readHistory>[number], index: number): HTMLElement {
    const box = document.createElement('div');
    box.className = 'history-editor';

    const noteCap = document.createElement('p');
    noteCap.className = 'history-editor-cap';
    noteCap.textContent = T['history.noteLabel'];
    box.appendChild(noteCap);

    const ta = document.createElement('textarea');
    ta.className = 'history-note-input';
    ta.rows = 3;
    ta.placeholder = T['history.notePlaceholder'];
    ta.value = entry.note ?? '';
    // Persiste à chaque frappe, sans re-render : le focus (et le curseur) restent
    // dans le textarea. La valeur est donc toujours à jour pour tout render ultérieur.
    ta.addEventListener('input', () => {
      updateAt(index, { note: ta.value.trim() ? ta.value : undefined });
    });
    box.appendChild(ta);

    const tagCap = document.createElement('p');
    tagCap.className = 'history-editor-cap';
    tagCap.textContent = T['history.tagsLabel'];
    box.appendChild(tagCap);

    const tagsWrap = document.createElement('div');
    tagsWrap.className = 'history-editor-tags';
    for (const tag of entry.tags ?? []) {
      const chip = document.createElement('span');
      chip.className = 'history-tag is-removable';
      chip.textContent = `#${tag}`;
      const x = document.createElement('button');
      x.type = 'button';
      x.className = 'history-tag-x';
      x.setAttribute('aria-label', T['history.removeTag']);
      x.textContent = '✕';
      x.addEventListener('click', () => {
        const next = (entry.tags ?? []).filter((tg) => tg !== tag);
        updateAt(index, { tags: next.length ? next : undefined });
        render();
      });
      chip.appendChild(x);
      tagsWrap.appendChild(chip);
    }
    const tagInput = document.createElement('input');
    tagInput.className = 'history-tag-input';
    tagInput.dataset.idx = String(index);
    tagInput.placeholder = T['history.addTag'];
    tagInput.setAttribute('aria-label', T['history.addTag']);
    tagInput.addEventListener('keydown', (e) => {
      if (e.key !== 'Enter') return;
      e.preventDefault();
      const v = tagInput.value.trim().replace(/^#+/, '').slice(0, 24);
      if (!v) return;
      const cur = entry.tags ?? [];
      if (!cur.includes(v)) {
        updateAt(index, { tags: [...cur, v] });
        refocusTag = index;
        render();
      } else {
        tagInput.value = '';
      }
    });
    tagsWrap.appendChild(tagInput);
    box.appendChild(tagsWrap);
    return box;
  }

  // ---- Une entrée ----
  function buildItem(entry: ReturnType<typeof readHistory>[number], index: number): HTMLElement {
    const li = document.createElement('li');
    li.className = 'history-item';
    li.classList.toggle('is-confirming', confirmDelete === index);

    const top = document.createElement('div');
    top.className = 'history-top';

    // Bloc rejouable : le tirage se relance sur la home via son permalien.
    const link = document.createElement('a');
    link.className = 'history-link';
    link.href = `${BASE}${locale}/${hashFor(entry)}`;

    const thumbs = document.createElement('div');
    thumbs.className = 'history-thumbs';
    const names: string[] = [];
    for (const c of entry.cards) {
      const card = byId.get(c.id);
      const name = card ? card.name[locale] : c.id;
      names.push(c.reversed ? `${name} (${T['card.reversed']})` : name);
      if (!card) continue;
      const img = document.createElement('img');
      img.src = `${BASE}cards/${card.id}-thumb.webp`;
      img.alt = card.name[locale];
      img.width = 60;
      img.height = 105;
      img.loading = 'lazy';
      img.decoding = 'async';
      img.classList.toggle('is-reversed', c.reversed);
      thumbs.appendChild(img);
    }

    const meta = document.createElement('div');
    meta.className = 'history-meta';
    const kindEl = document.createElement('p');
    kindEl.className = 'history-kind';
    kindEl.textContent = `${KIND_LABEL[entry.kind]} · ${timeFmt.format(new Date(entry.at))}`;
    const namesEl = document.createElement('p');
    namesEl.className = 'history-names';
    namesEl.textContent = names.join(' · ');
    meta.append(kindEl, namesEl);
    link.append(thumbs, meta);

    // Actions : annoter (bascule l'éditeur) + retirer.
    const side = document.createElement('div');
    side.className = 'history-side';
    const editBtn = document.createElement('button');
    editBtn.type = 'button';
    editBtn.className = 'history-edit';
    editBtn.classList.toggle('is-on', openEdit === index);
    // Signale d'un coup d'œil les tirages déjà annotés (note ou tags).
    editBtn.classList.toggle('has-note', Boolean(entry.note) || Boolean(entry.tags?.length));
    editBtn.setAttribute('aria-label', openEdit === index ? T['history.editDone'] : T['history.edit']);
    editBtn.textContent = openEdit === index ? '✓' : '✎';
    editBtn.addEventListener('click', () => {
      openEdit = openEdit === index ? null : index;
      confirmDelete = null;
      render();
    });
    const remove = document.createElement('button');
    remove.type = 'button';
    remove.className = 'history-remove';
    remove.setAttribute('aria-label', T['history.remove']);
    remove.textContent = '✕';
    // Retrait en deux temps : le clic arme une confirmation (voir la barre plus bas).
    remove.addEventListener('click', () => {
      confirmDelete = index;
      openEdit = null;
      render();
    });
    side.append(editBtn, remove);

    top.append(link, side);
    li.appendChild(top);

    // Vue lecture : aperçu de la note + tags cliquables (masqués pendant l'édition).
    if (openEdit !== index) {
      if (entry.note) {
        const note = document.createElement('p');
        note.className = 'history-note';
        note.textContent = entry.note;
        li.appendChild(note);
      }
      if (entry.tags?.length) {
        const row = document.createElement('div');
        row.className = 'history-tagrow';
        for (const tag of entry.tags) {
          const b = document.createElement('button');
          b.type = 'button';
          b.className = 'history-tag';
          b.classList.toggle('is-on', activeTag === tag);
          b.textContent = `#${tag}`;
          b.addEventListener('click', () => {
            activeTag = activeTag === tag ? null : tag;
            render();
          });
          row.appendChild(b);
        }
        li.appendChild(row);
      }
    } else {
      li.appendChild(buildEditor(entry, index));
    }

    // Confirmation de retrait (en place, sans popup système).
    if (confirmDelete === index) {
      const bar = document.createElement('div');
      bar.className = 'history-confirm';
      const msg = document.createElement('span');
      msg.className = 'history-confirm-msg';
      msg.textContent = T['history.removeConfirm'];
      const yes = document.createElement('button');
      yes.type = 'button';
      yes.className = 'history-confirm-yes';
      yes.textContent = T['history.removeYes'];
      yes.addEventListener('click', () => {
        removeAt(index);
        confirmDelete = null;
        if (openEdit === index) openEdit = null;
        render();
      });
      const no = document.createElement('button');
      no.type = 'button';
      no.className = 'history-confirm-no';
      no.textContent = T['history.cancel'];
      no.addEventListener('click', () => {
        confirmDelete = null;
        render();
      });
      bar.append(msg, yes, no);
      li.appendChild(bar);
    }

    return li;
  }

  function render() {
    const all = readHistory();
    const hasAny = all.length > 0;
    controlsEl.hidden = !hasAny;
    clearBtn.hidden = !hasAny;
    exportBtn.hidden = !hasAny;
    emptyEl.hidden = hasAny;

    renderTagBar(all);

    const q = norm(query);
    const shown = all
      .map((e, i) => ({ e, i }))
      .filter(({ e }) => {
        if (kindFilter !== 'all' && e.kind !== kindFilter) return false;
        if (activeTag && !(e.tags ?? []).includes(activeTag)) return false;
        if (!q) return true;
        if (e.note && norm(e.note).includes(q)) return true;
        return e.cards.some((c) => {
          const card = byId.get(c.id);
          return card ? norm(card.name[locale]).includes(q) : false;
        });
      });

    noneEl.hidden = !(hasAny && shown.length === 0);

    listEl.replaceChildren();
    let bucket: string | null = null;
    let ul: HTMLUListElement | null = null;
    for (const { e, i } of shown) {
      const b = dayBucket(e.at);
      if (b !== bucket) {
        bucket = b;
        const h = document.createElement('h2');
        h.className = 'history-day';
        h.textContent = b;
        listEl.appendChild(h);
        ul = document.createElement('ul');
        ul.className = 'history-group';
        listEl.appendChild(ul);
      }
      ul!.appendChild(buildItem(e, i));
    }

    if (refocusTag !== null) {
      listEl.querySelector<HTMLInputElement>(`.history-tag-input[data-idx="${refocusTag}"]`)?.focus();
      refocusTag = null;
    }
  }

  // ---- Contrôles ----
  for (const btn of filterBtns) {
    btn.addEventListener('click', () => {
      kindFilter = btn.dataset.kind as typeof kindFilter;
      filterBtns.forEach((b) => b.classList.toggle('is-on', b === btn));
      render();
    });
  }
  searchEl.addEventListener('input', () => {
    query = searchEl.value;
    render();
  });

  clearBtn.addEventListener('click', () => {
    if (!window.confirm(T['history.clearConfirm'])) return;
    clearHistory();
    openEdit = null;
    activeTag = null;
    confirmDelete = null;
    render();
  });

  // Export : copie le journal entier en Markdown (dates, cartes, tags, notes).
  exportBtn.addEventListener('click', async () => {
    const all = readHistory();
    if (!all.length) return;
    const text = all
      .map((e) => {
        const cardsTxt = e.cards
          .map((c) => {
            const card = byId.get(c.id);
            const n = card ? card.name[locale] : c.id;
            return c.reversed ? `${n} (${T['card.reversed']})` : n;
          })
          .join(' · ');
        let block = `## ${KIND_LABEL[e.kind]} — ${fullFmt.format(new Date(e.at))}\n${cardsTxt}`;
        if (e.tags?.length) block += `\n${e.tags.map((tg) => `#${tg}`).join(' ')}`;
        if (e.note) block += `\n${e.note}`;
        return block;
      })
      .join('\n\n');
    try {
      await navigator.clipboard.writeText(text);
      exportBtn.textContent = T['card.copied'];
      exportBtn.classList.add('is-copied');
      window.setTimeout(() => {
        exportBtn.textContent = T['history.export'];
        exportBtn.classList.remove('is-copied');
      }, 1600);
    } catch {
      /* presse-papiers indisponible */
    }
  });

  render();
</script>

<!--
  is:global obligatoire : les entrées sont créées en JS (createElement), donc
  elles n'ont pas l'attribut de scope qu'Astro n'ajoute qu'aux éléments du
  template. Un <style> scopé ne les toucherait pas. Tout est préfixé « .history ».
-->
<style is:global>
  .history {
    max-width: 44rem;
    margin: 0 auto;
  }

  /* ---- Bandeau d'outils : recherche (proéminente) + actions discrètes ---- */
  .history-controls {
    display: grid;
    gap: 0.85rem;
    margin-bottom: 1.6rem;
  }
  .history-toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem 1.25rem;
  }
  .history-search {
    flex: 1 1 14rem;
    min-width: 0;
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--text);
    background: rgba(240, 226, 196, 0.04);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.5rem 1.1rem;
    transition: border-color 0.2s ease, background-color 0.2s ease;
  }
  .history-search::placeholder {
    color: var(--muted);
    font-style: italic;
  }
  .history-search:focus-visible {
    outline: none;
    border-color: var(--accent);
    background: rgba(201, 164, 76, 0.06);
  }
  /* Actions utilitaires en texte : présentes mais en retrait du journal. */
  .history-actions {
    display: flex;
    gap: 1.1rem;
    flex-shrink: 0;
  }
  .history-action {
    font-family: var(--font-body);
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
    background: transparent;
    border: none;
    padding: 0.2rem 0;
    cursor: pointer;
    border-bottom: 1px solid transparent;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .history-action:hover,
  .history-action.is-copied {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }
  .history-clear:hover {
    color: var(--accent-2);
    border-bottom-color: var(--accent-2);
  }

  /* ---- Rangée de filtres : type de tirage + tags (les deux filtrent) ---- */
  /* Hiérarchie subtile : les types sont des pilules cernées (des « modes »),
     les tags sont plus légers (bordure au survol seulement). */
  .history-filterrow {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 0.9rem;
  }
  .history-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }
  .history-filter {
    font-family: var(--font-body);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
    background: transparent;
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.32rem 0.8rem;
    cursor: pointer;
    transition: color 0.2s ease, border-color 0.2s ease, background-color 0.2s ease;
  }
  .history-filter:hover {
    color: var(--text);
  }
  .history-filter.is-on {
    color: var(--text);
    border-color: var(--accent);
    background: rgba(201, 164, 76, 0.16);
  }
  .history-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem 0.4rem;
  }
  .history-tagfilter {
    font-family: var(--font-body);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    color: var(--muted);
    background: transparent;
    border: 1px solid transparent;
    border-radius: 999px;
    padding: 0.25rem 0.6rem;
    cursor: pointer;
    transition: color 0.2s ease, border-color 0.2s ease, background-color 0.2s ease;
  }
  .history-tagfilter:hover {
    color: var(--text);
    border-color: var(--line);
  }
  .history-tagfilter.is-on {
    color: var(--ground);
    background: var(--accent);
    border-color: var(--accent);
  }

  .history-empty {
    text-align: center;
    color: var(--muted);
    font-style: italic;
    margin: 4rem auto;
    display: grid;
    gap: 1.2rem;
    justify-items: center;
  }
  .history-cta {
    font-family: var(--font-body);
    font-style: normal;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    padding: 0.6rem 1.5rem;
    border: 1px solid var(--accent);
    border-radius: 999px;
    background: rgba(201, 164, 76, 0.12);
    color: var(--accent);
    text-decoration: none;
    transition: background-color 0.2s ease;
  }
  .history-cta:hover {
    background: rgba(201, 164, 76, 0.22);
  }
  .history-none {
    text-align: center;
    color: var(--muted);
    font-style: italic;
    margin: 3rem auto;
  }

  /* ---- Liste groupée par jour ---- */
  .history-day {
    margin: 1.4rem 0 0.7rem;
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--accent);
    border-bottom: 1px solid var(--line);
    padding-bottom: 0.4rem;
  }
  .history-day:first-child {
    margin-top: 0;
  }
  .history-group {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.55rem;
  }
  .history-item {
    display: grid;
    align-content: start;
    gap: 0.55rem;
    padding: 0.7rem 0.8rem;
    border-radius: 11px;
    background: linear-gradient(180deg, rgba(240, 226, 196, 0.06), rgba(240, 226, 196, 0.02));
    box-shadow: inset 0 0 0 1px var(--line);
    transition: box-shadow 0.2s ease;
  }
  .history-item:hover,
  .history-item:focus-within {
    box-shadow: inset 0 0 0 1px var(--accent), 0 8px 24px rgba(0, 0, 0, 0.4);
  }
  .history-top {
    display: flex;
    align-items: stretch;
    gap: 0.6rem;
  }
  .history .history-link {
    flex: 1;
    min-width: 0;
    display: flex;
    align-items: center;
    gap: 0.85rem;
    text-decoration: none;
    color: inherit;
    border-radius: 8px;
  }
  .history .history-link:focus-visible {
    outline: none;
  }
  .history .history-link:hover .history-names,
  .history .history-link:focus-visible .history-names {
    color: var(--accent);
  }
  .history-thumbs {
    display: flex;
    gap: 0.25rem;
    flex-shrink: 0;
  }
  .history-thumbs img {
    display: block;
    width: 38px;
    height: auto;
    aspect-ratio: 1100 / 1920;
    object-fit: cover;
    border-radius: 4px;
    box-shadow: 0 2px 7px rgba(0, 0, 0, 0.4), 0 0 0 1px var(--line);
  }
  .history-thumbs img.is-reversed {
    transform: rotate(180deg);
  }
  .history-meta {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .history-kind {
    margin: 0;
    font-size: 0.66rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--muted);
  }
  .history-names {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.15rem;
    line-height: 1.2;
    color: var(--text);
    transition: color 0.18s ease;
  }
  /* Cluster d'actions : annoter + retirer — toujours visibles, cernées comme de
