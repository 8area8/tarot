---
import { type Locale, t } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<div class="history" data-locale={locale}>
  <div class="history-bar">
    <button type="button" id="history-clear" class="history-clear" hidden>
      {t(locale, 'history.clear')}
    </button>
  </div>
  <p class="history-empty" id="history-empty" hidden>{t(locale, 'history.empty')}</p>
  <ul class="history-list" id="history-list"></ul>
</div>

<script>
  import { ui, type Locale } from '../lib/i18n';
  import { cards } from '../data/cards';
  import { answerFor } from '../lib/oracle';
  import { readHistory, removeAt, clearHistory, hashFor, type SpreadKind } from '../lib/history';

  const root = document.querySelector<HTMLElement>('.history')!;
  const locale = root.dataset.locale as Locale;
  const T = ui[locale];
  const BASE = import.meta.env.BASE_URL;

  const listEl = document.querySelector<HTMLUListElement>('#history-list')!;
  const emptyEl = document.querySelector<HTMLElement>('#history-empty')!;
  const clearBtn = document.querySelector<HTMLButtonElement>('#history-clear')!;

  const byId = new Map(cards.map((c) => [c.id, c]));

  // Libellé du type de tirage (réutilise les clés d'UI existantes).
  const KIND_LABEL: Record<SpreadKind, string> = {
    single: T['spread.single'],
    yesno: T['spread.yesno'],
    two: T['spread.two'],
    three: T['spread.three'],
  };

  // Libellés des 6 réponses de l'oracle (pour rappeler la réponse d'une question fermée).
  const ANSWERS = [
    T['yesno.answer.0'], T['yesno.answer.1'], T['yesno.answer.2'],
    T['yesno.answer.3'], T['yesno.answer.4'], T['yesno.answer.5'],
  ];

  // Date + heure localisées (« 15 juil. 2026, 14:32 »).
  const dtf = new Intl.DateTimeFormat(locale === 'fr' ? 'fr-FR' : 'en-US', {
    dateStyle: 'medium',
    timeStyle: 'short',
  });

  function render() {
    const entries = readHistory();
    emptyEl.hidden = entries.length > 0;
    clearBtn.hidden = entries.length === 0;
    listEl.replaceChildren();

    entries.forEach((entry, index) => {
      const li = document.createElement('li');
      li.className = 'history-item';

      // Le tirage entier est un lien qui le rejoue sur la home (via le hash).
      const link = document.createElement('a');
      link.className = 'history-link';
      link.href = `${BASE}${locale}/${hashFor(entry)}`;

      const thumbs = document.createElement('div');
      thumbs.className = 'history-thumbs';
      const names: string[] = [];
      for (const c of entry.cards) {
        const card = byId.get(c.id);
        const name = card ? card.name[locale] : c.id;
        names.push(c.reversed ? `${name} (${T['card.reversed']})` : name);
        if (!card) continue;
        const img = document.createElement('img');
        img.src = `${BASE}cards/${card.image}`;
        img.alt = card.name[locale];
        img.width = 60;
        img.height = 105;
        img.loading = 'lazy';
        img.classList.toggle('is-reversed', c.reversed);
        thumbs.appendChild(img);
      }

      const meta = document.createElement('div');
      meta.className = 'history-meta';
      const kindEl = document.createElement('p');
      kindEl.className = 'history-kind';
      // Pour une question fermée, on recalcule la réponse déterministe (carte + orientation).
      let kindText = KIND_LABEL[entry.kind];
      if (entry.kind === 'yesno') {
        const c0 = entry.cards[0];
        const card0 = byId.get(c0.id);
        const a = card0 ? answerFor({ card: card0, orientation: c0.reversed ? 'reversed' : 'upright' }) : null;
        if (a) kindText += ` · ${ANSWERS[a.answer]}`;
      }
      kindEl.textContent = `${kindText} · ${dtf.format(new Date(entry.at))}`;
      const namesEl = document.createElement('p');
      namesEl.className = 'history-names';
      namesEl.textContent = names.join(' · ');
      meta.append(kindEl, namesEl);

      link.append(thumbs, meta);

      const remove = document.createElement('button');
      remove.type = 'button';
      remove.className = 'history-remove';
      remove.dataset.index = String(index);
      remove.setAttribute('aria-label', T['history.remove']);
      remove.textContent = '✕';

      li.append(link, remove);
      listEl.appendChild(li);
    });
  }

  // Suppression d'une entrée (délégation : les items sont regénérés à chaque rendu).
  listEl.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.history-remove');
    if (!btn) return;
    removeAt(Number(btn.dataset.index));
    render();
  });

  clearBtn.addEventListener('click', () => {
    if (!window.confirm(T['history.clearConfirm'])) return;
    clearHistory();
    render();
  });

  render();
</script>

<!--
  is:global obligatoire : les entrées sont créées en JS (createElement), donc
  elles n'ont pas l'attribut de scope qu'Astro n'ajoute qu'aux éléments du
  template. Un <style> scopé ne les toucherait pas. Tout est préfixé « .history ».
-->
<style is:global>
  .history {
    max-width: 44rem;
    margin: 0 auto;
  }
  .history-bar {
    display: flex;
    justify-content: flex-end;
    min-height: 1.5rem;
    margin-bottom: 1rem;
  }
  .history-clear {
    font-family: var(--font-body);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--muted);
    background: transparent;
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.35rem 0.9rem;
    cursor: pointer;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .history-clear:hover {
    color: var(--accent-2);
    border-color: var(--accent-2);
  }
  .history-empty {
    text-align: center;
    color: var(--muted);
    font-style: italic;
    margin: 4rem auto;
  }
  .history-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.55rem;
  }
  /* Croix positionnée par-dessus l'entrée : le lien réserve un padding à droite. */
  .history-item {
    position: relative;
  }
  /* Le tirage entier est cliquable : il se rejoue sur la home. Rangée compacte. */
  .history .history-link {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.55rem 2.8rem 0.55rem 0.6rem;
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    background: linear-gradient(
      180deg,
      rgba(240, 226, 196, 0.06),
      rgba(240, 226, 196, 0.025)
    );
    box-shadow: inset 0 0 0 1px var(--line);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .history .history-link:hover,
  .history .history-link:focus-visible {
    transform: translateY(-2px);
    box-shadow: inset 0 0 0 1px var(--accent), 0 8px 22px rgba(0, 0, 0, 0.5),
      0 0 18px rgba(201, 164, 76, 0.15);
    outline: none;
  }
  .history-thumbs {
    display: flex;
    gap: 0.25rem;
    flex-shrink: 0;
  }
  .history-thumbs img {
    display: block;
    width: 40px;
    height: auto;
    aspect-ratio: 1100 / 1920;
    object-fit: cover;
    border-radius: 4px;
    box-shadow: 0 2px 7px rgba(0, 0, 0, 0.4), 0 0 0 1px var(--line);
  }
  .history-thumbs img.is-reversed {
    transform: rotate(180deg);
  }
  /* Méta serrée : surtitre juste au-dessus des noms, sans blanc vertical. */
  .history-meta {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  /* Surtitre : type de tirage + date, discret et doré comme les titres de section. */
  .history-kind {
    margin: 0;
    font-size: 0.66rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--accent);
  }
  .history-names {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.15rem;
    line-height: 1.2;
    color: var(--text);
  }
  .history .history-remove {
    position: absolute;
    top: 50%;
    right: 0.5rem;
    transform: translateY(-50%);
    z-index: 1;
    width: 1.7rem;
    height: 1.7rem;
    display: grid;
    place-items: center;
    padding: 0;
    border: 1px solid transparent;
    border-radius: 999px;
    background: transparent;
    color: var(--muted);
    font-size: 0.78rem;
    line-height: 1;
    cursor: pointer;
    opacity: 0.5;
    transition: opacity 0.2s ease, color 0.2s ease, background 0.2s ease;
  }
  .history .history-remove:hover,
  .history .history-remove:focus-visible {
    opacity: 1;
    color: var(--accent-2);
    background: rgba(181, 83, 47, 0.14);
    outline: none;
  }
  @media (prefers-reduced-motion: reduce) {
    .history .history-link {
      transition: none;
    }
  }
</style>
