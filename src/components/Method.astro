---
import { type Locale, t } from '../lib/i18n';
import { METHOD, METHOD_INTRO, METHOD_EXAMPLE } from '../data/method';
import { SPREADS } from '../data/spread';
import { cards } from '../data/cards';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const base = import.meta.env.BASE_URL;

// Un lien contextuel : ancre same-page (« #… ») ou page interne (préfixée /{lang}/).
const hrefFor = (href: string) => (href.startsWith('#') ? href : `${base}${locale}/${href}`);

const byId = new Map(cards.map((c) => [c.id, c]));
const positions = SPREADS.three;
const example = METHOD_EXAMPLE.entries.map((e, i) => ({
  card: byId.get(e.id)!,
  position: positions[i],
  read: e.read,
}));
const quintCard = byId.get(METHOD_EXAMPLE.quintId)!;
// Réutilise les intitulés d'étapes pour les encadrés de l'exemple (cohérence, pas de doublon).
const forcesTitle = METHOD[4].title[locale];
const quintTitle = METHOD[5].title[locale];
---

<div class="method">
  <p class="method-lede">{METHOD_INTRO[locale]}</p>

  <!-- Les 7 étapes en parcours numéroté -->
  <ol class="method-steps">
    {METHOD.map((s, i) => (
      <li id={`step-${i + 1}`} class="method-step">
        <span class="method-num" aria-hidden="true">{i + 1}</span>
        <div class="method-step-body">
          <h2 class="method-step-title">{s.title[locale]}</h2>
          <p class="method-text">{s.text[locale]}</p>
          {s.see && (
            <p class="method-see">
              {s.see.map((link) => (
                <a class="method-see-link" href={hrefFor(link.href)}>{link.label[locale]} →</a>
              ))}
            </p>
          )}
        </div>
      </li>
    ))}
  </ol>

  <!-- Exemple guidé : un vrai tirage lu selon la méthode -->
  <section id="exemple" class="method-example" aria-labelledby="h-exemple">
    <h2 id="h-exemple" class="method-h">{t(locale, 'method.example')}</h2>
    <p class="method-intro">{METHOD_EXAMPLE.intro[locale]}</p>

    <ol class="method-spread">
      {example.map((e, i) => (
        <li class="method-cardrow">
          <a class="method-card-link" href={`${base}${locale}/#${e.card.id}`} title={e.card.name[locale]}>
            <img src={`${base}cards/${e.card.id}-thumb.webp`} alt={e.card.name[locale]} width="110" height="192" loading="lazy" decoding="async" />
          </a>
          <div class="method-cardrow-body">
            <p class="method-pos">
              <span class="method-pos-badge" aria-hidden="true">{i + 1}</span>
              <span class="method-pos-label">{e.position.label[locale]}</span>
              <span class="method-pos-gloss">{e.position.gloss[locale]}</span>
            </p>
            <p class="method-card-name">{e.card.name[locale]}</p>
            <p class="method-text">{e.read[locale]}</p>
          </div>
        </li>
      ))}
    </ol>

    <div class="method-callout">
      <p class="method-callout-h">{forcesTitle}</p>
      <p class="method-text">{METHOD_EXAMPLE.forces[locale]}</p>
    </div>

    <div class="method-callout method-quint">
      <a class="method-quint-card" href={`${base}${locale}/#${quintCard.id}`} title={quintCard.name[locale]}>
        <img src={`${base}cards/${quintCard.id}-thumb.webp`} alt={quintCard.name[locale]} width="110" height="192" loading="lazy" decoding="async" />
      </a>
      <div class="method-quint-body">
        <p class="method-callout-h">{quintTitle}</p>
        <p class="method-text">{METHOD_EXAMPLE.quintText[locale]}</p>
      </div>
    </div>

    <p class="method-cta">
      <a class="method-cta-btn" href={`${base}${locale}/`}>{t(locale, 'method.cta')}</a>
    </p>
  </section>
</div>

<style>
  .method {
    max-width: 44rem;
    margin: 0 auto;
    display: grid;
    gap: 2.5rem;
  }
  .method-lede {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.3rem;
    line-height: 1.5;
    color: var(--text);
    text-align: center;
    max-width: 38rem;
    justify-self: center;
  }
  .method-text {
    margin: 0;
    color: var(--muted);
    line-height: 1.7;
  }

  /* ---- Parcours des étapes : chemin numéroté ---- */
  .method-steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.6rem;
  }
  .method-step {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0 1.1rem;
    position: relative;
  }
  /* Filet reliant les pastilles (le « chemin »). Tracé depuis le centre du numéro. */
  .method-step:not(:last-child)::before {
    content: '';
    position: absolute;
    left: 1.1rem;
    top: 2.2rem;
    bottom: -1.6rem;
    width: 1px;
    background: linear-gradient(var(--line), transparent);
  }
  .method-num {
    grid-row: 1 / 3;
    display: grid;
    place-items: center;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 999px;
    border: 1px solid var(--accent);
    background: rgba(201, 164, 76, 0.1);
    color: var(--accent);
    font-family: var(--font-display);
    font-size: 1.15rem;
    line-height: 1;
  }
  .method-step-title {
    margin: 0.25rem 0 0.4rem;
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 600;
    line-height: 1.15;
    color: var(--text);
  }
  .method-see {
    margin: 0.55rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.9rem;
  }
  .method-see-link {
    font-family: var(--font-body);
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    color: var(--accent);
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s ease;
  }
  .method-see-link:hover {
    border-bottom-color: var(--accent);
  }

  /* ---- Exemple guidé ---- */
  .method-example {
    scroll-margin-top: 1.5rem;
    display: grid;
    gap: 1.3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--line);
  }
  .method-h {
    margin: 0;
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--accent);
  }
  .method-intro {
    margin: 0;
    color: var(--muted);
    font-style: italic;
  }
  .method-spread {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.1rem;
  }
  .method-cardrow {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.1rem;
    align-items: start;
  }
  .method-card-link {
    display: block;
    width: 76px;
    line-height: 0;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 0 0 1px var(--line);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .method-card-link img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 1100 / 1920;
    object-fit: cover;
  }
  .method-card-link:hover,
  .method-card-link:focus-visible {
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.45), 0 0 0 1px var(--accent);
    outline: none;
  }
  .method-cardrow-body {
    display: grid;
    gap: 0.3rem;
    min-width: 0;
  }
  .method-pos {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.35rem 0.55rem;
  }
  .method-pos-badge {
    display: inline-grid;
    place-items: center;
    width: 1.4rem;
    height: 1.4rem;
    border-radius: 999px;
    border: 1px solid var(--line);
    color: var(--accent);
    font-size: 0.75rem;
  }
  .method-pos-label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--accent);
  }
  .method-pos-gloss {
    font-size: 0.85rem;
    font-style: italic;
    color: var(--muted);
  }
  .method-card-name {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.2rem;
    color: var(--text);
  }

  /* Encadrés « peser les forces » + « quintessence ». */
  .method-callout {
    padding: 1.1rem 1.2rem;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: rgba(240, 226, 196, 0.03);
  }
  .method-callout-h {
    margin: 0 0 0.4rem;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--accent);
  }
  .method-quint {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.1rem;
    align-items: center;
    background: rgba(201, 164, 76, 0.05);
  }
  .method-quint-card {
    display: block;
    width: 72px;
    line-height: 0;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 0 0 1px rgba(201, 164, 76, 0.5);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .method-quint-card img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 1100 / 1920;
    object-fit: cover;
  }
  .method-quint-card:hover,
  .method-quint-card:focus-visible {
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.45), 0 0 0 1px var(--accent);
    outline: none;
  }

  .method-cta {
    margin: 0.5rem 0 0;
    text-align: center;
  }
  .method-cta-btn {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    padding: 0.65rem 1.6rem;
    border: 1px solid var(--accent);
    border-radius: 999px;
    background: rgba(201, 164, 76, 0.12);
    color: var(--accent);
    text-decoration: none;
    transition: background-color 0.2s ease, box-shadow 0.2s ease;
  }
  .method-cta-btn:hover {
    background: rgba(201, 164, 76, 0.22);
    box-shadow: 0 0 20px rgba(201, 164, 76, 0.2);
  }

  @media (prefers-reduced-motion: reduce) {
    .method-card-link,
    .method-quint-card,
    .method-cta-btn {
      transition: none;
    }
  }
</style>
